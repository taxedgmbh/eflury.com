            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Financial Analytics",
              "description": "Data-driven insights through powerful dashboards and reporting with Power BI and advanced analytics.",
              "provider": {
                "@type": "Person",
                "name": "Emanuel Aaron Flury"
              },
