---
import { type Language, routes } from '../i18n/utils';
import '../styles/global.css';
import '../styles/apple-components.css';
import '../styles/scroll-indicator.css';
import ExitIntent from '../components/ExitIntent.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';

interface Props {
  title: string;
  description: string;
  lang: Language;
  keywords?: string;
  /** Override hreflang URLs for pages with different paths per language */
  hreflangEn?: string;
  hreflangDe?: string;
}

const { title, description, lang, keywords, hreflangEn, hreflangDe } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Map paths to their localized equivalents for proper hreflang generation
const localizedPaths: Record<string, { en: string; de: string }> = {
  // Legal pages with different slugs
  '/en/privacy/': { en: '/en/privacy/', de: '/de/datenschutz/' },
  '/de/datenschutz/': { en: '/en/privacy/', de: '/de/datenschutz/' },
  '/en/terms/': { en: '/en/terms/', de: '/de/nutzungsbedingungen/' },
  '/de/nutzungsbedingungen/': { en: '/en/terms/', de: '/de/nutzungsbedingungen/' },
  '/en/disclaimer/': { en: '/en/disclaimer/', de: '/de/haftungsausschluss/' },
  '/de/haftungsausschluss/': { en: '/en/disclaimer/', de: '/de/haftungsausschluss/' },
  '/en/code-of-conduct/': { en: '/en/code-of-conduct/', de: '/de/verhaltenskodex/' },
  '/de/verhaltenskodex/': { en: '/en/code-of-conduct/', de: '/de/verhaltenskodex/' },
  '/en/imprint/': { en: '/en/imprint/', de: '/de/impressum/' },
  '/de/impressum/': { en: '/en/imprint/', de: '/de/impressum/' },
  // Services with different slugs
  '/en/services/finance-automation/': { en: '/en/services/finance-automation/', de: '/de/services/finanzen-automatisierung/' },
  '/de/services/finanzen-automatisierung/': { en: '/en/services/finance-automation/', de: '/de/services/finanzen-automatisierung/' },
  '/en/services/data-quality/': { en: '/en/services/data-quality/', de: '/de/services/datenqualitaet/' },
  '/de/services/datenqualitaet/': { en: '/en/services/data-quality/', de: '/de/services/datenqualitaet/' },
  '/en/services/ai-audit/': { en: '/en/services/ai-audit/', de: '/de/services/ki-audit/' },
  '/de/services/ki-audit/': { en: '/en/services/ai-audit/', de: '/de/services/ki-audit/' },
  '/en/services/managed-ai-operations/': { en: '/en/services/managed-ai-operations/', de: '/de/services/ki-betrieb/' },
  '/de/services/ki-betrieb/': { en: '/en/services/managed-ai-operations/', de: '/de/services/ki-betrieb/' },
  '/en/trust/': { en: '/en/trust/', de: '/de/sicherheit/' },
  '/de/sicherheit/': { en: '/en/trust/', de: '/de/sicherheit/' },
  '/en/method/': { en: '/en/method/', de: '/de/methode/' },
  '/de/methode/': { en: '/en/method/', de: '/de/methode/' },
  '/en/contact/': { en: '/en/contact/', de: '/de/kontakt/' },
  '/de/kontakt/': { en: '/en/contact/', de: '/de/kontakt/' },
  '/en/industries/': { en: '/en/industries/', de: '/de/branchen/' },
  '/de/branchen/': { en: '/en/industries/', de: '/de/branchen/' },
  '/en/industries/finance-teams/': { en: '/en/industries/finance-teams/', de: '/de/branchen/finanzteams/' },
  '/de/branchen/finanzteams/': { en: '/en/industries/finance-teams/', de: '/de/branchen/finanzteams/' },
  '/en/industries/professional-services/': { en: '/en/industries/professional-services/', de: '/de/branchen/dienstleister/' },
  '/de/branchen/dienstleister/': { en: '/en/industries/professional-services/', de: '/de/branchen/dienstleister/' },
  '/en/industries/reporting-data/': { en: '/en/industries/reporting-data/', de: '/de/branchen/reporting-daten/' },
  '/de/branchen/reporting-daten/': { en: '/en/industries/reporting-data/', de: '/de/branchen/reporting-daten/' },
  '/en/careers/': { en: '/en/careers/', de: '/de/karriere/' },
  '/de/karriere/': { en: '/en/careers/', de: '/de/karriere/' },
  '/en/careers/spontaneous-application/': { en: '/en/careers/spontaneous-application/', de: '/de/karriere/initiativbewerbung/' },
  '/de/karriere/initiativbewerbung/': { en: '/en/careers/spontaneous-application/', de: '/de/karriere/initiativbewerbung/' },
  '/en/guides/': { en: '/en/guides/', de: '/de/leitfaeden/' },
  '/de/leitfaeden/': { en: '/en/guides/', de: '/de/leitfaeden/' },
};

// Generate hreflang URLs for language alternates
const getHrefLangUrl = (targetLang: Language) => {
  // Check if explicit hreflang props were provided
  if (targetLang === 'en' && hreflangEn) return hreflangEn;
  if (targetLang === 'de' && hreflangDe) return hreflangDe;

  const pathname = Astro.url.pathname;

  // Root redirect page
  if (pathname === '/') {
    return `https://eflury.com/${targetLang}/`;
  }

  // Check if this path has a localized mapping
  if (localizedPaths[pathname]) {
    return `https://eflury.com${localizedPaths[pathname][targetLang]}`;
  }

  // Default: simple path replacement for pages with same slugs
  return `https://eflury.com${pathname.replace(/^\/(en|de)\//, `/${targetLang}/`)}`;
};

const ogImage = 'https://eflury.com/images/og-image.png';
const twitterImage = 'https://eflury.com/images/og-image.png';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang for language alternates (SEO) -->
    <link rel="alternate" hreflang="en" href={getHrefLangUrl('en')} />
    <link rel="alternate" hreflang="de" href={getHrefLangUrl('de')} />
    <link rel="alternate" hreflang="x-default" href={getHrefLangUrl('en')} />

    <!-- RSS autodiscovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={lang === 'de' ? 'eFlury Blog (Deutsch)' : 'eFlury Blog (English)'}
      href={`https://eflury.com/${lang}/rss.xml`}
    />

    <!-- Favicon (square PNG ≥48px required for Google Search; SVG for modern browsers) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon-tab.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />

    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'de_CH'} />
    <meta property="og:locale:alternate" content={lang === 'en' ? 'de_CH' : 'en_US'} />
    <meta property="og:site_name" content="Emanuel Flury - AI Consulting" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={twitterImage} />
    <meta property="twitter:image:alt" content={title} />

    <!-- Apple System Fonts - No external font loading needed -->
    <!-- Using -apple-system, BlinkMacSystemFont, SF Pro Display/Text -->

    <!-- Icons - Now using Lucide (modern, tree-shakeable) -->
    <!-- Font Awesome removed for better performance -->

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6320666588"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-6320666588', {
        'send_page_view': true,
        'cookie_flags': 'SameSite=None;Secure'
      });

      // Track CTA clicks
      window.trackEvent = function(category, action, label) {
        gtag('event', action, {
          'event_category': category,
          'event_label': label
        });
      };
    </script>

    <!-- Local Business Schema for Local SEO -->
    <LocalBusinessSchema lang={lang} />

    <!-- Dark Mode Script - Prevent Flash -->
    <script is:inline>
      // Initialize theme before page renders to prevent flash
      const theme = localStorage.getItem('theme') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    </script>

    <!-- Keyboard Navigation Detection -->
    <script is:inline>
      // Add class when user is tabbing for better accessibility
      function handleFirstTab(e) {
        if (e.key === 'Tab') {
          document.body.classList.add('user-is-tabbing');
          window.removeEventListener('keydown', handleFirstTab);
          window.addEventListener('mousedown', handleMouseDownOnce);
        }
      }

      function handleMouseDownOnce() {
        document.body.classList.remove('user-is-tabbing');
        window.removeEventListener('mousedown', handleMouseDownOnce);
        window.addEventListener('keydown', handleFirstTab);
      }

      window.addEventListener('keydown', handleFirstTab);
    </script>

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#022554" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Emanuel Flury" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="mobile-web-app-capable" content="yes" />

    <!-- Service Worker Registration -->
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js')
            .then((registration) => {
              console.log('SW registered:', registration.scope);
            })
            .catch((error) => {
              console.log('SW registration failed:', error);
            });
        });
      }
    </script>

    <!-- Page-specific schema markup (named slot for child pages) -->
    <slot name="head" />

    <!-- Modern Web APIs -->
    <script is:inline>
      // Web Share API
      if (navigator.share) {
        window.sharePage = async function() {
          try {
            await navigator.share({
              title: document.title,
              text: document.querySelector('meta[name="description"]')?.content || '',
              url: window.location.href
            });
          } catch (err) {
            console.log('Share cancelled');
          }
        };
      }

      // Intersection Observer for animations
      if ('IntersectionObserver' in window) {
        const observerOptions = {
          root: null,
          rootMargin: '0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate-in');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        // Observe elements with data-animate attribute
        document.addEventListener('DOMContentLoaded', () => {
          document.querySelectorAll('[data-animate]').forEach(el => {
            observer.observe(el);
          });
        });
      }
    </script>
  </head>
  <body>
    <slot />
    <ExitIntent lang={lang} />
  </body>
</html>
