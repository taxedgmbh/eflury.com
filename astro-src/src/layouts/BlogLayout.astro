---
/**
 * Blog Post Layout
 * Layout for individual blog posts with E-E-A-T optimizations
 * - BlogPostingSchema for structured data
 * - AuthorBio for author expertise display
 */

import MainLayout from './MainLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AIChatbot from '../components/AIChatbot.astro';
import BlogPostingSchema from '../components/BlogPostingSchema.astro';
import AuthorBio from '../components/AuthorBio.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { ArrowLeft, Calendar, User, Clock, Tag } from 'lucide-astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
  slug: string;
  lang: 'en' | 'de';
  languageSwitchUrl?: string;
}

const { title, description, pubDate, updatedDate, author, image, imageAlt, tags = [], slug, lang, languageSwitchUrl } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString(lang === 'de' ? 'de-CH' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString(lang === 'de' ? 'de-CH' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const backLabel = lang === 'de' ? 'Zurück zum Blog' : 'Back to Blog';
const updatedLabel = lang === 'de' ? 'Aktualisiert' : 'Updated';
const readingTimeLabel = lang === 'de' ? 'Lesezeit' : 'Reading time';

// hreflang alternates: blog slugs differ per language, so MainLayout's default
// /en/<->/de/ prefix swap would advertise non-existent URLs. languageSwitchUrl
// already points at the translated post (or the blog index as fallback).
const otherLang = lang === 'en' ? 'de' : 'en';
const selfUrl = `https://eflury.com/${lang}/blog/${slug}/`;
const otherPath = languageSwitchUrl ?? `/${otherLang}/blog/`;
const otherUrl = `https://eflury.com${otherPath.endsWith('/') ? otherPath : `${otherPath}/`}`;
const hreflangEn = lang === 'en' ? selfUrl : otherUrl;
const hreflangDe = lang === 'de' ? selfUrl : otherUrl;
---

<MainLayout
  title={`${title} | Emanuel Flury Blog`}
  description={description}
  keywords={tags.join(', ')}
  lang={lang}
  hreflangEn={hreflangEn}
  hreflangDe={hreflangDe}
>
  <BlogPostingSchema
    title={title}
    description={description}
    pubDate={pubDate}
    updatedDate={updatedDate}
    author={author}
    image={image}
    tags={tags}
    lang={lang}
    url={Astro.url.pathname}
  />
  <Header lang={lang} languageSwitchUrl={languageSwitchUrl} />

  <article class="blog-post">
    <div class="container">
      <a href={`/${lang}/blog`} class="back-link">
        <ArrowLeft size={18} />
        {backLabel}
      </a>

      <header class="post-header">
        <div class="meta">
          <span class="date">
            <Calendar size={16} />
            {formattedPubDate}
          </span>
          <a href={`/${lang}/about`} class="author">
            <User size={16} />
            {author}
          </a>
          <span class="reading-time">
            <Clock size={16} />
            ~5 min {readingTimeLabel}
          </span>
        </div>

        <h1>{title}</h1>
        <p class="description">{description}</p>

        {tags.length > 0 && (
          <div class="tags">
            <Tag size={14} />
            {tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {image && (
        <div class="featured-image">
          <img src={image} alt={imageAlt || title} loading="eager" />
        </div>
      )}

      <div class="post-content">
        <slot />
      </div>

      {updatedDate && (
        <p class="updated-notice">
          {updatedLabel}: {formattedUpdatedDate}
        </p>
      )}

      <AuthorBio lang={lang} />

      <RelatedPosts
        currentSlug={slug}
        currentTags={tags}
        lang={lang}
      />

      <div class="post-footer">
        <a href={`/${lang}/blog`} class="back-link">
          <ArrowLeft size={18} />
          {backLabel}
        </a>
      </div>
    </div>
  </article>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .blog-post {
    padding-top: var(--header-height);
    padding-bottom: 4rem;
    background: #ffffff;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 3rem);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 400;
    font-size: 0.9rem;
    margin: 2rem 0;
    transition: all 0.2s ease;
    opacity: 0.8;
  }

  .back-link:hover {
    gap: 0.75rem;
    opacity: 1;
    color: var(--eflury-teal, #0d9488);
  }

  .post-header {
    margin-bottom: 3rem;
    padding-top: 1rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .meta span {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .meta :global(svg) {
    color: var(--eflury-teal, #0d9488);
    opacity: 0.7;
  }

  .meta a.author {
    text-decoration: none;
    color: var(--text-secondary);
    transition: color 0.2s ease;
  }

  .meta a.author:hover {
    color: var(--eflury-teal, #0d9488);
  }

  .post-header h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--eflury-navy, #022554);
    line-height: 1.15;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .post-header .description {
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    font-weight: 400;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-secondary);
    margin-top: 1.5rem;
  }

  .tag {
    padding: 0.35rem 0.9rem;
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 2px;
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .tag:hover {
    border-color: var(--eflury-teal, #0d9488);
    color: var(--eflury-teal, #0d9488);
  }

  /* National Geographic-style full-bleed hero image */
  .featured-image {
    margin: 0 calc(-1 * clamp(1.5rem, 5vw, 3rem));
    margin-bottom: 3rem;
    position: relative;
    width: calc(100% + 2 * clamp(1.5rem, 5vw, 3rem));
    max-width: 100vw;
    height: clamp(400px, 60vh, 700px);
    overflow: hidden;
    background: #000;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.95);
  }

  /* National Geographic-inspired typography */
  .post-content {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    line-height: 1.9;
    color: #1a1a1a;
    font-weight: 400;
    max-width: 720px;
    margin: 0 auto;
  }

  .post-content :global(h2) {
    font-size: clamp(1.85rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--eflury-navy, #022554);
    margin: 4rem 0 1.5rem;
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .post-content :global(h3) {
    font-size: clamp(1.45rem, 3vw, 1.85rem);
    font-weight: 600;
    color: var(--eflury-navy, #022554);
    margin: 3rem 0 1rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .post-content :global(p) {
    margin-bottom: 1.75rem;
  }

  /* Drop cap for first paragraph */
  .post-content :global(p:first-of-type::first-letter) {
    font-size: 5em;
    line-height: 0.85;
    float: left;
    margin: 0.1em 0.1em 0 0;
    font-weight: 700;
    color: var(--eflury-navy, #022554);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 2rem;
    padding-left: 2rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.8;
  }

  .post-content :global(a) {
    color: var(--eflury-teal, #0d9488);
    text-decoration: none;
    border-bottom: 1px solid var(--eflury-teal, #0d9488);
    transition: all 0.2s ease;
  }

  .post-content :global(a:hover) {
    color: #0f766e;
    border-bottom-color: #0f766e;
  }

  /* National Geographic-style pull quotes */
  .post-content :global(blockquote) {
    border: none;
    padding: 3rem 0;
    margin: 3.5rem 0;
    font-style: italic;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    line-height: 1.6;
    color: var(--eflury-navy, #022554);
    font-weight: 500;
    text-align: center;
    position: relative;
    letter-spacing: -0.01em;
  }

  .post-content :global(blockquote::before) {
    content: '"';
    position: absolute;
    top: -0.25rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 6rem;
    line-height: 1;
    color: var(--eflury-teal, #0d9488);
    opacity: 0.2;
    font-family: Georgia, serif;
  }

  .post-content :global(blockquote p) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote strong) {
    display: block;
    margin-top: 1rem;
    font-size: 0.85rem;
    font-weight: 400;
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
  }

  .post-content :global(code) {
    background: #f5f5f5;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .post-content :global(pre) {
    background: #1a1a1a;
    color: #f5f5f5;
    padding: 2rem;
    border-radius: 4px;
    overflow-x: auto;
    margin: 3rem 0;
    line-height: 1.6;
  }

  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
  }

  /* Full-bleed images within content */
  .post-content :global(img) {
    max-width: calc(100% + 2 * clamp(1.5rem, 5vw, 3rem));
    width: calc(100% + 2 * clamp(1.5rem, 5vw, 3rem));
    margin-left: calc(-1 * clamp(1.5rem, 5vw, 3rem));
    height: auto;
    margin-top: 3rem;
    margin-bottom: 3rem;
    display: block;
  }

  /* Elegant dividers */
  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border-color) 50%, transparent);
    margin: 4rem auto;
    max-width: 200px;
  }

  /* Table styling */
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 3rem 0;
    font-size: 0.95rem;
  }

  .post-content :global(th) {
    background: #f8f8f8;
    padding: 1rem;
    text-align: left;
    font-weight: 600;
    border-bottom: 2px solid var(--eflury-navy, #022554);
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }

  .post-content :global(td) {
    padding: 1rem;
    border-bottom: 1px solid #e5e5e5;
  }

  .post-content :global(tr:hover) {
    background: #fafafa;
  }

  .updated-notice {
    margin-top: 2rem;
    padding: 1rem;
    background: var(--bg-secondary);
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .meta {
      gap: 1rem;
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
