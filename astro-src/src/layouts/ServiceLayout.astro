---
/**
 * Service Page Layout
 * Template for individual service pillar pages
 * Optimized for E-E-A-T with FAQSchema and ServiceSchema
 */

import MainLayout from './MainLayout.astro';
import Header from '../components/Header.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';
import AIChatbot from '../components/AIChatbot.astro';
import FAQSchema from '../components/FAQSchema.astro';
import AuthorBio from '../components/AuthorBio.astro';
import { ArrowLeft, ArrowRight, CheckCircle2, Clock, Target, Zap, ChevronDown, ChevronUp } from 'lucide-astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  keywords: string;
  lang: 'en' | 'de';
  serviceType: string;
  heroTitle: string;
  heroSubtitle: string;
  heroDescription: string;
  problemTitle: string;
  problems: string[];
  solutionTitle: string;
  solutionDescription: string;
  benefits: { title: string; description: string }[];
  processTitle: string;
  processSteps: { title: string; description: string }[];
  faqs: FAQ[];
  ctaTitle: string;
  ctaDescription: string;
  ctaButtonText: string;
  relatedCaseStudy?: {
    title: string;
    link: string;
    metric: string;
  };
}

const {
  title,
  description,
  keywords,
  lang,
  serviceType,
  heroTitle,
  heroSubtitle,
  heroDescription,
  problemTitle,
  problems,
  solutionTitle,
  solutionDescription,
  benefits,
  processTitle,
  processSteps,
  faqs,
  ctaTitle,
  ctaDescription,
  ctaButtonText,
  relatedCaseStudy
} = Astro.props;

const backLabel = lang === 'de' ? 'Zurück zu Services' : 'Back to Services';
const viewCaseStudyLabel = lang === 'de' ? 'Fallstudie ansehen' : 'View Case Study';

// Service Schema for structured data
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": title,
  "description": description,
  "provider": {
    "@type": "ProfessionalService",
    "name": "eflury.com",
    "url": "https://eflury.com"
  },
  "areaServed": {
    "@type": "Country",
    "name": "Switzerland"
  },
  "serviceType": serviceType
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'de' ? 'Startseite' : 'Home',
      "item": `https://eflury.com/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": `https://eflury.com/${lang}/services`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": `https://eflury.com${Astro.url.pathname}`
    }
  ]
};
---

<MainLayout
  title={`${title} | eflury.com`}
  description={description}
  keywords={keywords}
  lang={lang}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <FAQSchema faqs={faqs} lang={lang} />

  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Services', href: `/${lang}/services` }, { label: serviceType }]} />

  <main class="service-page">
    <div class="container">

      <!-- Hero Section -->
      <section class="hero-section">
        <span class="hero-badge">{heroSubtitle}</span>
        <h1 class="hero-title">{heroTitle}</h1>
        <p class="hero-description">{heroDescription}</p>

        {relatedCaseStudy && (
          <div class="case-study-callout">
            <span class="callout-metric">{relatedCaseStudy.metric}</span>
            <a href={relatedCaseStudy.link} class="callout-link">
              {relatedCaseStudy.title}
              <ArrowRight size={16} />
            </a>
          </div>
        )}
      </section>

      <!-- Problem Section -->
      <section class="problem-section">
        <h2 class="section-title">{problemTitle}</h2>
        <ul class="problem-list">
          {problems.map((problem) => (
            <li class="problem-item">
              <Target size={20} class="problem-icon" />
              <span>{problem}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Solution Section -->
      <section class="solution-section">
        <h2 class="section-title">{solutionTitle}</h2>
        <p class="solution-description">{solutionDescription}</p>

        <div class="benefits-grid">
          {benefits.map((benefit) => (
            <div class="benefit-card">
              <CheckCircle2 size={24} class="benefit-icon" />
              <h3 class="benefit-title">{benefit.title}</h3>
              <p class="benefit-description">{benefit.description}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Process Section -->
      <slot name="showcase" />

      <section class="process-section">
        <h2 class="section-title">{processTitle}</h2>
        <div class="process-timeline">
          {processSteps.map((step, index) => (
            <div class="process-step">
              <div class="step-number">{index + 1}</div>
              <div class="step-content">
                <h3 class="step-title">{step.title}</h3>
                <p class="step-description">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="faq-section">
        <h2 class="section-title">{lang === 'de' ? 'Häufige Fragen' : 'Frequently Asked Questions'}</h2>
        <div class="faq-list">
          {faqs.map((faq, index) => (
            <details class="faq-item">
              <summary class="faq-question">
                <span>{faq.question}</span>
                <ChevronDown size={20} class="faq-chevron" />
              </summary>
              <div class="faq-answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Author/Expert Section -->
      <AuthorBio lang={lang} />

      <!-- CTA Section -->
      <section class="cta-section">
        <h2 class="cta-title">{ctaTitle}</h2>
        <p class="cta-description">{ctaDescription}</p>
        <div class="cta-buttons">
          <a href={`/${lang}/#contact`} class="cta-button primary">
            {ctaButtonText}
            <ArrowRight size={18} />
          </a>
          <a href={`/${lang}/pricing`} class="cta-button secondary">
            {lang === 'de' ? 'Preise ansehen' : 'View Pricing'}
          </a>
        </div>
      </section>
    </div>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .service-page {
    padding-bottom: 4rem;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--teal-text, #096b62);
    text-decoration: none;
    font-weight: 500;
    margin: 2rem 0;
    transition: gap 0.2s ease;
  }

  .back-link:hover {
    gap: 0.75rem;
  }

  /* Hero Section */
  .hero-section {
    text-align: center;
    padding: 3rem 0 4rem;
    border-bottom: 1px solid var(--border-color);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    color: var(--teal-text, #096b62);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .hero-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 700px;
    margin: 0 auto;
  }

  .case-study-callout {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 1rem 1.5rem;
    background: var(--bg-secondary);
    border-radius: 12px;
    border: 1px solid var(--border-color);
  }

  .callout-metric {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--teal-text, #096b62);
  }

  .callout-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .callout-link:hover {
    color: var(--teal-text, #096b62);
  }

  /* Section Titles */
  .section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--eflury-navy, #022554);
    margin-bottom: 1.5rem;
  }

  :global([data-theme="dark"]) .section-title {
    color: var(--text-primary);
  }

  /* Problem Section */
  .problem-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .problem-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .problem-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem;
    background: rgba(220, 38, 38, 0.05);
    border-radius: 12px;
    border-left: 4px solid #dc2626;
  }

  .problem-icon {
    color: #dc2626;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .problem-item span {
    color: var(--text-primary);
    font-size: 1.05rem;
    line-height: 1.5;
  }

  /* Solution Section */
  .solution-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .solution-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .benefit-card {
    padding: 1.5rem;
    background: var(--bg-secondary);
    border-radius: 16px;
    border: 1px solid var(--border-color);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .benefit-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .benefit-icon {
    color: var(--teal-text, #096b62);
    margin-bottom: 1rem;
  }

  .benefit-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .benefit-description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  /* Process Section */
  .process-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .process-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .process-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-number {
    width: 48px;
    height: 48px;
    background: var(--eflury-navy, #022554);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  :global([data-theme="dark"]) .step-number {
    background: var(--eflury-teal, #0d9488);
  }

  .step-content {
    flex: 1;
    padding-top: 0.5rem;
  }

  .step-title {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .step-description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* FAQ Section */
  .faq-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--border-color);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
  }

  .faq-question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    list-style: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question span {
    flex: 1;
    padding-right: 1rem;
  }

  .faq-chevron {
    color: var(--text-tertiary);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.25rem;
  }

  .faq-answer p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* CTA Section */
  .cta-section {
    text-align: center;
    padding: 4rem 0;
    margin-top: 2rem;
    background: linear-gradient(135deg, rgba(13, 148, 136, 0.08) 0%, rgba(2, 37, 84, 0.05) 100%);
    border-radius: 24px;
    margin-left: -1rem;
    margin-right: -1rem;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .cta-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .cta-description {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    border-radius: 100px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-button.primary {
    background: var(--eflury-navy, #022554);
    color: white;
  }

  .cta-button.primary:hover {
    background: var(--action-teal, #096b62);
    transform: translateY(-2px);
  }

  .cta-button.secondary {
    background: transparent;
    color: var(--eflury-navy, #022554);
    border: 2px solid var(--eflury-navy, #022554);
  }

  .cta-button.secondary:hover {
    background: var(--eflury-navy, #022554);
    color: white;
  }

  :global([data-theme="dark"]) .cta-button.primary {
    background: var(--action-teal, #0f766e);
  }

  :global([data-theme="dark"]) .cta-button.secondary {
    color: var(--teal-text, #096b62);
    border-color: var(--teal-text, #096b62);
  }

  :global([data-theme="dark"]) .cta-button.secondary:hover {
    background: var(--eflury-teal, #0d9488);
    color: white;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hero-section {
      padding: 2rem 0 3rem;
    }

    .hero-title {
      font-size: 1.75rem;
    }

    .hero-description {
      font-size: 1.1rem;
    }

    .case-study-callout {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .cta-section {
      padding: 3rem 1.5rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .cta-button {
      width: 100%;
      max-width: 300px;
      justify-content: center;
    }
  }
</style>
