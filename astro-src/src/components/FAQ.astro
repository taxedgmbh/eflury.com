---
import { type Language, useTranslations } from '../i18n/utils';
import { ChevronDown, Search, X } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Get FAQ data from translations
const faqData = (t('faq.questions') as any) || [];

// Search placeholder text
const searchPlaceholder = lang === 'en' ? 'Search questions...' : 'Fragen durchsuchen...';
const noResultsText = lang === 'en' ? 'No matching questions found. Try different keywords.' : 'Keine passenden Fragen gefunden. Versuchen Sie andere Suchbegriffe.';
const clearSearchText = lang === 'en' ? 'Clear search' : 'Suche löschen';
---

<section class="faq section-padding" id="faq">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('faq.title')}</h2>
      <p class="section-subtitle">{t('faq.subtitle')}</p>
    </div>

    <!-- FAQ Search Input -->
    <div class="faq-search-container">
      <div class="faq-search-wrapper">
        <Search size={20} class="search-icon" />
        <input
          type="text"
          id="faq-search"
          class="faq-search-input"
          placeholder={searchPlaceholder}
          aria-label={searchPlaceholder}
        />
        <button
          id="faq-search-clear"
          class="search-clear-btn"
          aria-label={clearSearchText}
          style="display: none;"
        >
          <X size={18} />
        </button>
      </div>
      <p id="faq-results-count" class="faq-results-count" style="display: none;"></p>
    </div>

    <!-- No Results Message -->
    <div id="faq-no-results" class="faq-no-results" style="display: none;">
      <p>{noResultsText}</p>
    </div>

    <div class="faq-container">
      {faqData.map((item: any, index: number) => (
        <div class="faq-item" data-faq-index={index}>
          <button class="faq-question" aria-expanded="false" aria-controls={`faq-answer-${index}`}>
            <span class="question-text">{item.question}</span>
            <ChevronDown size={20} class="faq-icon" />
          </button>
          <div class="faq-answer" id={`faq-answer-${index}`} role="region">
            <div class="answer-content">
              <p>{item.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // FAQ Accordion and Search functionality
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('.faq-item');
    const searchInput = document.getElementById('faq-search') as HTMLInputElement;
    const clearBtn = document.getElementById('faq-search-clear') as HTMLButtonElement;
    const resultsCount = document.getElementById('faq-results-count') as HTMLParagraphElement;
    const noResults = document.getElementById('faq-no-results') as HTMLDivElement;

    // FAQ Accordion functionality
    faqItems.forEach((item) => {
      const question = item.querySelector('.faq-question') as HTMLButtonElement;
      const answer = item.querySelector('.faq-answer') as HTMLDivElement;
      const icon = question?.querySelector('.faq-icon') as HTMLElement;

      question?.addEventListener('click', () => {
        const isExpanded = question.getAttribute('aria-expanded') === 'true';

        // Close all other FAQ items
        faqItems.forEach((otherItem) => {
          if (otherItem !== item) {
            const otherQuestion = otherItem.querySelector('.faq-question') as HTMLButtonElement;
            const otherAnswer = otherItem.querySelector('.faq-answer') as HTMLDivElement;
            const otherIcon = otherQuestion?.querySelector('.faq-icon') as HTMLElement;

            otherQuestion?.setAttribute('aria-expanded', 'false');
            otherAnswer?.classList.remove('active');
            if (otherIcon) {
              otherIcon.classList.remove('rotate');
              const svg = otherIcon.querySelector('svg');
              if (svg) svg.style.transform = 'rotate(0deg)';
            }
          }
        });

        // Toggle current item
        question.setAttribute('aria-expanded', (!isExpanded).toString());
        answer?.classList.toggle('active');
        if (icon) {
          icon.classList.toggle('rotate');
          const svg = icon.querySelector('svg');
          if (svg) {
            svg.style.transition = 'transform var(--transition-base)';
            svg.style.transform = isExpanded ? 'rotate(0deg)' : 'rotate(180deg)';
          }
        }

        // Track FAQ interaction
        if (window.trackEvent) {
          window.trackEvent('User Interaction', 'faq_click', question.textContent || '');
        }
      });
    });

    // FAQ Search functionality
    function filterFAQs(searchTerm: string) {
      const term = searchTerm.toLowerCase().trim();
      let visibleCount = 0;

      faqItems.forEach((item) => {
        const questionText = item.querySelector('.question-text')?.textContent?.toLowerCase() || '';
        const answerText = item.querySelector('.answer-content p')?.textContent?.toLowerCase() || '';
        const matches = term === '' || questionText.includes(term) || answerText.includes(term);

        if (matches) {
          (item as HTMLElement).style.display = '';
          (item as HTMLElement).classList.remove('faq-hidden');
          visibleCount++;
        } else {
          (item as HTMLElement).style.display = 'none';
          (item as HTMLElement).classList.add('faq-hidden');
        }
      });

      // Update UI based on results
      if (term !== '') {
        clearBtn.style.display = 'flex';

        if (visibleCount === 0) {
          noResults.style.display = 'block';
          resultsCount.style.display = 'none';
        } else {
          noResults.style.display = 'none';
          resultsCount.style.display = 'block';
          const countText = document.documentElement.lang === 'de'
            ? `${visibleCount} Ergebnis${visibleCount !== 1 ? 'se' : ''} gefunden`
            : `${visibleCount} result${visibleCount !== 1 ? 's' : ''} found`;
          resultsCount.textContent = countText;
        }
      } else {
        clearBtn.style.display = 'none';
        noResults.style.display = 'none';
        resultsCount.style.display = 'none';
      }

      // Track search
      if (term !== '' && window.trackEvent) {
        window.trackEvent('User Interaction', 'faq_search', term);
      }
    }

    // Debounce function for search
    let searchTimeout: number;
    searchInput?.addEventListener('input', (e) => {
      clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(() => {
        filterFAQs((e.target as HTMLInputElement).value);
      }, 200);
    });

    // Clear search button
    clearBtn?.addEventListener('click', () => {
      searchInput.value = '';
      filterFAQs('');
      searchInput.focus();
    });

    // Keyboard support: Escape to clear search
    searchInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        filterFAQs('');
      }
    });
  });
</script>

<style>
  .faq {
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  /* FAQ Search Styles */
  .faq-search-container {
    max-width: 500px;
    margin: 0 auto 2rem;
  }

  .faq-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    color: var(--text-secondary);
    pointer-events: none;
    z-index: 1;
  }

  .faq-search-input {
    width: 100%;
    padding: 1rem 3rem;
    font-size: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    background: var(--card-bg);
    color: var(--text-primary);
    transition: all var(--transition-base);
  }

  .faq-search-input::placeholder {
    color: var(--text-secondary);
  }

  .faq-search-input:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.1);
  }

  .search-clear-btn {
    position: absolute;
    right: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    border-radius: 50%;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .search-clear-btn:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
  }

  .faq-results-count {
    text-align: center;
    margin-top: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .faq-no-results {
    max-width: 500px;
    margin: 0 auto 2rem;
    padding: 2rem;
    text-align: center;
    background: var(--bg-secondary);
    border-radius: 12px;
    border: 1px dashed var(--border-color);
  }

  .faq-no-results p {
    color: var(--text-secondary);
    margin: 0;
  }

  /* Animation for filtering */
  .faq-item {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .faq-item.faq-hidden {
    opacity: 0;
    transform: scale(0.95);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .faq-container {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: var(--transition-smooth);
  }

  .faq-item:hover {
    border-color: var(--primary-green);
    box-shadow: var(--shadow-soft);
  }

  .faq-question {
    width: 100%;
    padding: 1.5rem 2rem;
    background: transparent;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    transition: var(--transition-smooth);
  }

  .faq-question:hover {
    background: var(--bg-secondary);
  }

  .faq-question:focus {
    outline: 2px solid var(--primary-green);
    outline-offset: -2px;
  }

  .question-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    flex: 1;
  }

  .faq-icon {
    color: var(--primary);
    transition: transform var(--transition-base);
    flex-shrink: 0;
  }

  .faq-icon.rotate {
    transform: rotate(180deg);
  }
  
  .faq-icon svg {
    width: 20px;
    height: 20px;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .faq-answer.active {
    max-height: 500px;
  }

  .answer-content {
    padding: 0 2rem 1.5rem 2rem;
  }

  .answer-content p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin: 0;
  }

  @media (max-width: 768px) {
    .faq-search-container {
      padding: 0 1rem;
    }

    .faq-search-input {
      padding: 0.875rem 2.75rem;
      font-size: 16px; /* Prevents iOS zoom on focus */
    }

    .search-icon {
      left: 0.875rem;
    }

    .faq-question {
      padding: 1.25rem 1.5rem;
    }

    .question-text {
      font-size: 1rem;
    }

    .answer-content {
      padding: 0 1.5rem 1.25rem 1.5rem;
    }

    .faq-no-results {
      margin: 0 1rem 2rem;
      padding: 1.5rem;
    }
  }
</style>
