const categories = [
  {
    label: de ? 'KI & Agenten' : 'AI & Agents',
    tools: [
      { name: 'Claude (Anthropic)', si: 'anthropic' },
      { name: 'Claude Code', si: 'claude' },
      { name: 'Agent Skills', icon: Layers },
    ],
  },
  {
    label: de ? 'Integration & Automatisierung' : 'Integration & Automation',
    tools: [
      { name: 'MCP (Model Context Protocol)', icon: Cable },
      { name: 'n8n', si: 'n8n' },
      { name: 'Make', si: 'make' },
    ],
  },
  {
    label: de ? 'Daten & Analytik' : 'Data & Analytics',
    tools: [
      { name: 'Power BI', icon: BarChart3 },
      { name: 'Python', si: 'python' },
    ],
  },
  {
    label: de ? 'Business-Systeme' : 'Business Systems',
    tools: [
      { name: 'bexio', icon: Calculator },
      { name: 'ABACUS', icon: Boxes },
      { name: 'Microsoft 365', icon: LayoutGrid },
      { name: 'HubSpot', si: 'hubspot' },
      { name: 'Google Workspace', si: 'google' },
      { name: 'Notion', si: 'notion' },
    ],
  },
  {
    label: 'Hosting (EU/CH)',
    tools: [
      { name: 'AWS Bedrock (EU)', icon: Cloud },
      { name: de ? 'Exoscale (Schweiz)' : 'Exoscale (Switzerland)', si: 'exoscale' },
    ],
  },
];
---

<section class="tech-partners">
  <div class="container">
    <h2 class="section-title">{t('tech_partners.section_title')}</h2>
    <p class="section-subtitle">{t('tech_partners.section_subtitle')}</p>

    <div class="stack-card">
      {categories.map((category) => (
        <div class="stack-row">
          <span class="stack-label">{category.label}</span>
          <div class="stack-chips">
            {category.tools.map((tool) => (
              <span class="stack-chip">
                {tool.si ? (
                  <svg class="chip-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={si[tool.si]} /></svg>
                ) : (
                  <tool.icon size={15} class="chip-icon" />
                )}
                {tool.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="trust-badges">
      <span class="badge">
        <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
        GDPR Compliant
      </span>
      <span class="badge">
        <span class="flag-icon">&#127464;&#127469;</span>
        Swiss Hosting
      </span>
    </div>
  </div>
</section>

<style>
  .tech-partners {
    background: var(--bg-primary);
    padding: 5rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto 3rem;
  }

  .stack-card {
    max-width: 880px;
    margin: 0 auto 3rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 18px;
    overflow: hidden;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem 1.75rem;
  }

  .stack-row + .stack-row {
    border-top: 1px solid var(--border-color);
  }

  .stack-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-text);
    padding-top: 0.5rem;
    line-height: 1.4;
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4375rem 0.9375rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    cursor: default;
  }

  .stack-chip :global(.chip-icon) {
    width: 15px;
    height: 15px;
    color: var(--teal-text);
    opacity: 0.85;
    flex-shrink: 0;
  }

  .stack-chip:hover {
    border-color: var(--teal-text);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .stack-row {
      grid-template-columns: 1fr;
      gap: 0.625rem;
      padding: 1.125rem 1.25rem;
    }

    .stack-label {
      padding-top: 0;
    }
  }

  .trust-badges {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .badge-icon {
    width: 16px;
    height: 16px;
    color: var(--teal-text);
  }

  .flag-icon {
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .tech-partners {
      padding: 4rem 1.5rem;
    }

    .section-subtitle {
      margin-bottom: 2rem;
    }

    .partner-categories {
      gap: 2rem;
    }

    .logos {
      gap: 0.75rem;
    }

    .logo-text {
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      min-width: 100px;
    }

    .trust-badges {
      gap: 1rem;
    }

    .badge {
      padding: 0.5rem 0.875rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      min-width: auto;
      padding: 0.625rem 0.875rem;
      font-size: 0.8rem;
    }
  }
</style>
