---
import { type Language, useTranslations } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const de = lang === 'de';

const categories = [
  {
    label: de ? 'KI & Agenten' : 'AI & Agents',
    logos: ['Claude (Anthropic)', 'Claude Code', 'Agent Skills']
  },
  {
    label: de ? 'Integration & Automatisierung' : 'Integration & Automation',
    logos: ['MCP (Model Context Protocol)', 'n8n']
  },
  {
    label: de ? 'Daten & Analytik' : 'Data & Analytics',
    logos: ['Power BI', 'Python']
  },
  {
    label: de ? 'Business-Systeme' : 'Business Systems',
    logos: ['bexio', 'ABACUS', 'Microsoft 365', 'HubSpot', 'Google Workspace', 'Notion']
  },
  {
    label: 'Hosting (EU/CH)',
    logos: ['AWS Bedrock (EU)', de ? 'Exoscale (Schweiz)' : 'Exoscale (Switzerland)']
  }
];
---

<section class="tech-partners">
  <div class="container">
    <h2 class="section-title">{t('tech_partners.section_title')}</h2>

    <div class="stack-card">
      {categories.map((category) => (
        <div class="stack-row">
          <span class="stack-label">{category.label}</span>
          <div class="stack-chips">
            {category.logos.map((logo) => (
              <span class="stack-chip">{logo}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="trust-badges">
      <span class="badge">
        <svg class="badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
        GDPR Compliant
      </span>
      <span class="badge">
        <span class="flag-icon">&#127464;&#127469;</span>
        Swiss Hosting
      </span>
    </div>
  </div>
</section>

<style>
  .tech-partners {
    background: var(--bg-primary);
    padding: 5rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
    text-align: center;
    margin-bottom: 3.5rem;
    letter-spacing: -0.02em;
  }

  .stack-card {
    max-width: 880px;
    margin: 0 auto 3rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 18px;
    overflow: hidden;
  }

  .stack-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem 1.75rem;
  }

  .stack-row + .stack-row {
    border-top: 1px solid var(--border-color);
  }

  .stack-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--eflury-teal);
    padding-top: 0.5rem;
    line-height: 1.4;
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.4375rem 0.9375rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
    cursor: default;
  }

  .stack-chip:hover {
    border-color: var(--eflury-teal);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .stack-row {
      grid-template-columns: 1fr;
      gap: 0.625rem;
      padding: 1.125rem 1.25rem;
    }

    .stack-label {
      padding-top: 0;
    }
  }

  .trust-badges {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .badge-icon {
    width: 16px;
    height: 16px;
    color: var(--eflury-teal);
  }

  .flag-icon {
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .tech-partners {
      padding: 4rem 1.5rem;
    }

    .section-title {
      margin-bottom: 2.5rem;
    }

    .partner-categories {
      gap: 2rem;
    }

    .logos {
      gap: 0.75rem;
    }

    .logo-text {
      padding: 0.75rem 1rem;
      font-size: 0.85rem;
      min-width: 100px;
    }

    .trust-badges {
      gap: 1rem;
    }

    .badge {
      padding: 0.5rem 0.875rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .logo-text {
      min-width: auto;
      padding: 0.625rem 0.875rem;
      font-size: 0.8rem;
    }
  }
</style>
