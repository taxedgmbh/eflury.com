---
import { type Language, useTranslations, routes } from '../i18n/utils';
import { Linkedin, Github, Mail, Phone, Shield, FileText, Cookie, AlertCircle, Users, Scale, ExternalLink } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentRoutes = routes[lang];
const currentYear = new Date().getFullYear();

// Legal section translations
const legalTitle = lang === 'en' ? 'Legal & Compliance' : 'Rechtliches & Compliance';
const legalLinks = {
  privacy: { label: lang === 'en' ? 'Privacy Policy' : 'Datenschutz', desc: lang === 'en' ? 'How we protect your data' : 'Wie wir Ihre Daten schützen' },
  terms: { label: lang === 'en' ? 'Terms of Service' : 'Nutzungsbedingungen', desc: lang === 'en' ? 'Service agreement' : 'Servicevereinbarung' },
  cookies: { label: lang === 'en' ? 'Cookie Policy' : 'Cookie-Richtlinie', desc: lang === 'en' ? 'Cookie usage info' : 'Cookie-Nutzungsinfo' },
  disclaimer: { label: lang === 'en' ? 'Disclaimer' : 'Haftungsausschluss', desc: lang === 'en' ? 'Legal notices' : 'Rechtliche Hinweise' },
  conduct: { label: lang === 'en' ? 'Code of Conduct' : 'Verhaltenskodex', desc: lang === 'en' ? 'Professional standards' : 'Professionelle Standards' },
  dataProtection: { label: lang === 'en' ? 'Swiss Data Protection' : 'Schweizer Datenschutz', desc: lang === 'en' ? 'FDPIC guidelines' : 'EDÖB-Richtlinien' },
};
---

<footer class="footer">
  <div class="footer-container">
    <!-- Column 1: Brand & Description -->
    <div class="footer-section footer-brand">
      <h3 class="footer-logo">Emanuel Flury</h3>
      <p class="footer-tagline">{t('footer.tagline')}</p>
      <p class="footer-description">{t('footer.description')}</p>

      <!-- Social Media Links -->
      <div class="social-links">
        <a href="https://linkedin.com/in/emanuelflury" target="_blank" rel="noopener" title="LinkedIn" aria-label="Visit LinkedIn profile">
          <Linkedin size={20} />
        </a>
        <a href="https://github.com/taxedgmbh" target="_blank" rel="noopener" title="GitHub" aria-label="Visit GitHub profile">
          <Github size={20} />
        </a>
        <a href="mailto:me@eflury.com" title="Email" aria-label="Send email">
          <Mail size={20} />
        </a>
        <a href="tel:+41799107787" title="Phone" aria-label="Call phone number">
          <Phone size={20} />
        </a>
      </div>
    </div>

    <!-- Column 2: Services -->
    <div class="footer-section">
      <h4>{t('footer.sections.services')}</h4>
      <ul class="footer-links">
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.automation')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.tax')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.analytics')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.consulting')}</a></li>
      </ul>
    </div>

    <!-- Column 3: Contact -->
    <div class="footer-section">
      <h4>{lang === 'en' ? 'Contact' : 'Kontakt'}</h4>
      <ul class="footer-links">
        <li><a href="mailto:me@eflury.com">me@eflury.com</a></li>
        <li><a href="tel:+41799107787">+41 79 910 77 87</a></li>
        <li><span>Grenchen, Switzerland</span></li>
      </ul>
    </div>

    <!-- Column 4: Legal & Compliance -->
    <div class="footer-section footer-legal">
      <h4>{legalTitle}</h4>
      <ul class="footer-links legal-list">
        <li>
          <a href={currentRoutes.privacy} class="legal-link">
            <Shield size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.privacy.label}</span>
              <span class="legal-desc">{legalLinks.privacy.desc}</span>
            </div>
          </a>
        </li>
        <li>
          <a href={currentRoutes.terms} class="legal-link">
            <FileText size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.terms.label}</span>
              <span class="legal-desc">{legalLinks.terms.desc}</span>
            </div>
          </a>
        </li>
        <li>
          <a href={currentRoutes.cookies} class="legal-link">
            <Cookie size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.cookies.label}</span>
              <span class="legal-desc">{legalLinks.cookies.desc}</span>
            </div>
          </a>
        </li>
        <li>
          <a href="/disclaimer.html" class="legal-link">
            <AlertCircle size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.disclaimer.label}</span>
              <span class="legal-desc">{legalLinks.disclaimer.desc}</span>
            </div>
          </a>
        </li>
        <li>
          <a href="/code-of-conduct.html" class="legal-link">
            <Users size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.conduct.label}</span>
              <span class="legal-desc">{legalLinks.conduct.desc}</span>
            </div>
          </a>
        </li>
        <li>
          <a href="https://www.edoeb.admin.ch/edoeb/en/home.html" target="_blank" rel="noopener" class="legal-link external">
            <Scale size={16} class="legal-icon" />
            <div class="legal-text">
              <span class="legal-label">{legalLinks.dataProtection.label} <ExternalLink size={12} class="external-icon" /></span>
              <span class="legal-desc">{legalLinks.dataProtection.desc}</span>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <p class="copyright">&copy; {currentYear} Emanuel Flury. {lang === 'en' ? 'All rights reserved.' : 'Alle Rechte vorbehalten.'}</p>
      <p class="made-with">{t('footer.made_with')}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 4rem 0 0;
    margin-top: 5rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 3rem;
  }

  .footer-section h3,
  .footer-section h4 {
    color: var(--primary-green);
    margin-bottom: 1rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .footer-description {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .social-links a:hover {
    background: var(--primary);
    color: var(--apple-white);
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  
  .social-links a svg {
    transition: transform var(--transition-fast);
  }
  
  .social-links a:hover svg {
    transform: scale(1.1);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition-smooth);
    display: inline-block;
  }

  .footer-links a:hover {
    color: var(--primary-green);
    transform: translateX(5px);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border-color);
    background: var(--bg-primary);
  }

  .footer-bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright,
  .made-with {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin: 0;
  }

  /* Legal Links - Small & Hidden Style (like Apple, Google) */
  .legal-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .legal-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.75rem;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    padding: 0.25rem 0.5rem;
    border-right: 1px solid rgba(107, 114, 128, 0.3);
  }

  .legal-links a:last-child {
    border-right: none;
  }

  .legal-links a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  @media (max-width: 1024px) {
    .footer-bottom-container {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .legal-links {
      order: 2;
    }

    .copyright {
      order: 1;
    }

    .made-with {
      order: 3;
    }
  }

  /* Legal Links - Professional Style with Icons */
  .footer-legal h4 {
    margin-bottom: 1.25rem;
  }

  .legal-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .legal-list li {
    margin-bottom: 0;
  }

  .legal-link {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 8px;
    background: transparent;
    border: 1px solid transparent;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .legal-link:hover {
    background: var(--bg-secondary);
    border-color: var(--border-color);
    transform: translateX(0);
  }

  .legal-icon {
    color: var(--primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .legal-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .legal-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .legal-desc {
    font-size: 0.75rem;
    color: var(--text-secondary);
    opacity: 0.8;
  }

  .external-icon {
    opacity: 0.6;
  }

  .legal-link.external .legal-label {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .footer {
      padding-bottom: calc(80px + env(safe-area-inset-bottom)); /* Space for bottom nav */
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 max(var(--spacing-lg), env(safe-area-inset-left)) 0 max(var(--spacing-lg), env(safe-area-inset-right));
    }

    .footer-bottom-container {
      padding: 0 max(var(--spacing-lg), env(safe-area-inset-left)) 0 max(var(--spacing-lg), env(safe-area-inset-right));
    }

    .legal-links {
      flex-direction: column;
      gap: 0.75rem;
    }

    .legal-links a {
      border-right: none;
      border-bottom: 1px solid rgba(107, 114, 128, 0.2);
      padding: 0.5rem 0;
    }

    .legal-links a:last-child {
      border-bottom: none;
    }

    /* Legal section mobile adjustments */
    .legal-link {
      padding: 0.625rem 0.5rem;
    }

    .legal-desc {
      display: none; /* Hide descriptions on mobile for cleaner look */
    }

    .footer-legal {
      margin-top: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-color);
    }
  }
</style>
