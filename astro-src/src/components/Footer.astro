---
import { type Language, routes } from '../i18n/utils';
import { Linkedin, Mail, Phone } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const de = lang === 'de';
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || '0x4AAAAAACNCvv3pA4hrcbKM';
const r = routes[lang];
const currentYear = new Date().getFullYear();

const t = {
  positioning: de
    ? 'KI-Automatisierung für Schweizer KMU — Fixpreise, Human-in-the-Loop, alles dokumentiert.'
    : 'AI automation for Swiss SMEs — fixed prices, human-in-the-loop, everything documented.',
  services: de ? 'Leistungen' : 'Services',
  industries: de ? 'Einsatzbereiche' : 'Where We Help',
  company: de ? 'Unternehmen' : 'Company',
  resources: de ? 'Ressourcen' : 'Resources',
  newsletterTitle: de ? 'KI-Tipps für KMU' : 'AI Tips for SMEs',
  newsletterSubtitle: de
    ? 'Ein praxisnaher Impuls pro Monat — plus direkter Zugang zu unseren drei Playbooks.'
    : 'One practical insight per month — plus instant access to our three playbooks.',
  newsletterChips: de
    ? ['EU AI Act', 'revDSG & Schatten-KI', 'Datenqualität']
    : ['EU AI Act', 'revDSG & Shadow AI', 'Data Quality'],
  newsletterPlaceholder: de ? 'ihre@email.ch' : 'your@email.com',
  newsletterButton: de ? 'Abonnieren' : 'Subscribe',
  newsletterMicro: de ? 'Kostenlos. Kein Spam. Jederzeit abbestellbar.' : 'Free. No spam. Unsubscribe anytime.',
  newsletterPrivacy: de ? 'Datenschutz' : 'Privacy',
  newsletterSuccessCta: de ? 'Zu Ihren Playbooks' : 'Get your playbooks',
  rights: de ? 'Alle Rechte vorbehalten.' : 'All rights reserved.',
  companyLine: de
    ? 'eFlury Consulting · Einzelfirma · Grenchen, Schweiz'
    : 'eFlury Consulting · Sole Proprietorship · Grenchen, Switzerland',
};

const columns = [
  {
    title: t.services,
    links: [
      { label: de ? 'Übersicht' : 'Overview', href: r.services },
      { label: de ? 'KI-Audit' : 'AI Audit', href: r.servicesAiAudit },
      { label: 'Claude Skills', href: r.servicesClaudeSkills },
      { label: 'MCP Integration', href: r.servicesMcpIntegration },
      { label: de ? 'Finanzautomatisierung' : 'Finance Automation', href: r.servicesFinanceAutomation },
      { label: 'Power BI', href: r.servicesPowerBi },
      { label: de ? 'Datenqualität' : 'Data Quality', href: r.servicesDataQuality },
      { label: de ? 'KI-Betrieb' : 'Managed Operations', href: r.servicesManagedOps },
    ],
  },
  {
    title: t.industries,
    links: [
      { label: de ? 'Übersicht' : 'Overview', href: r.industries },
      { label: de ? 'Finanzen & Back Office' : 'Finance & Back Office', href: r.industriesFinanceTeams },
      { label: de ? 'Kundenkommunikation & Annahme' : 'Customer Communication & Intake', href: r.industriesProfessionalServices },
      { label: de ? 'Reporting & Daten' : 'Reporting & Data', href: r.industriesReportingData },
    ],
  },
  {
    title: t.company,
    links: [
      { label: de ? 'Über uns' : 'About', href: `/${lang}/about/` },
      { label: de ? 'Unsere Methode' : 'Our Method', href: r.method },
      { label: de ? 'Sicherheit & Vertrauen' : 'Trust & Security', href: r.trust },
      { label: de ? 'Preise' : 'Pricing', href: `/${lang}/pricing/` },
      { label: de ? 'Karriere' : 'Careers', href: r.careers },
    ],
  },
  {
    title: t.resources,
    links: [
      { label: de ? 'Referenzen' : 'Case Studies', href: `/${lang}/case-studies/` },
      { label: 'Insights', href: `/${lang}/blog/` },
      { label: de ? 'Leitfäden' : 'Guides', href: r.guides },
      { label: 'SkopaAI', href: `/${lang}/skopaai/` },
      { label: de ? 'Kontakt' : 'Contact', href: r.contact },
    ],
  },
];

const legalLinks = [
  { label: de ? 'Datenschutz' : 'Privacy', href: r.privacy },
  { label: de ? 'AGB' : 'Terms', href: r.terms },
  { label: 'Cookies', href: r.cookies },
  { label: de ? 'Haftung' : 'Disclaimer', href: r.disclaimer },
  { label: de ? 'Verhaltenskodex' : 'Code of Conduct', href: r.codeOfConduct },
  { label: de ? 'Impressum' : 'Imprint', href: r.imprint },
];
---

<footer class="footer">
  <div class="footer-main">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={r.home} class="brand-mark"><img src="/images/favicon-tab.png" alt="" class="brand-icon" width="34" height="34" loading="lazy" /> eFlury <span>Consulting</span></a>
        <p class="brand-positioning">{t.positioning}</p>
        <ul class="brand-contact">
          <li><a href="mailto:me@eflury.com"><Mail size={15} /> me@eflury.com</a></li>
          <li><a href="tel:+41799107787"><Phone size={15} /> +41 79 910 77 87</a></li>
          <li>
            <a href="https://linkedin.com/in/emanuelflury" target="_blank" rel="noopener" aria-label="LinkedIn">
              <Linkedin size={15} /> LinkedIn
            </a>
          </li>
        </ul>
      </div>

      {columns.map((col) => (
        <nav class="footer-col" aria-label={col.title}>
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <div class="footer-newsletter">
    <div class="newsletter-inner">
      <div class="newsletter-copy">
        <h4>{t.newsletterTitle}</h4>
        <p>{t.newsletterSubtitle}</p>
        <div class="newsletter-chips">
          {t.newsletterChips.map((chip) => (
            <span class="nl-chip">{chip}</span>
          ))}
        </div>
      </div>
      <div class="newsletter-action">
        <form class="newsletter-form" id="newsletterForm" data-sitekey={turnstileSitekey}>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            placeholder={t.newsletterPlaceholder}
            class="newsletter-input"
            autocomplete="email"
            inputmode="email"
            aria-label={t.newsletterTitle}
            required
          />
          <input
            type="text"
            name="website"
            id="newsletter-hp"
            class="nl-hp"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <button type="submit" class="newsletter-button" id="newsletter-submit">
            {t.newsletterButton}
          </button>
        </form>
        <div id="newsletter-turnstile" class="nl-turnstile"></div>
        <p class="newsletter-micro">
          {t.newsletterMicro} <a href={r.privacy}>{t.newsletterPrivacy}</a>
        </p>
        <div id="newsletter-status" class="newsletter-status" role="status" aria-live="polite">
        </div>
        <a href={r.guides} class="newsletter-success-cta" id="newsletterSuccessCta" hidden>
          {t.newsletterSuccessCta} →
        </a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="bottom-inner">
      <p class="copyright">
        &copy; {currentYear} {t.companyLine}. {t.rights}
      </p>
      <nav class="legal-nav" aria-label={de ? 'Rechtliches' : 'Legal'}>
        {legalLinks.map((l, i) => (
          <>
            <a href={l.href}>{l.label}</a>
            {i < legalLinks.length - 1 && <span class="dot" aria-hidden="true">·</span>}
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 5rem;
  }

  .footer-main {
    padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-2xl);
  }

  .footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--spacing-2xl) var(--spacing-xl);
  }

  /* Brand block */
  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--eflury-navy);
    text-decoration: none;
    margin-bottom: var(--spacing-md);
  }

  .brand-mark span {
    color: var(--eflury-teal);
  }

  .brand-icon {
    width: 34px;
    height: 34px;
    border-radius: 7px;
  }

  .brand-positioning {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 260px;
    margin: 0 0 var(--spacing-lg);
  }

  .brand-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .brand-contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .brand-contact a:hover {
    color: var(--eflury-teal);
  }

  .brand-contact :global(svg) {
    color: var(--eflury-teal);
    flex-shrink: 0;
  }

  /* Link columns */
  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 var(--spacing-md);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-col a {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--eflury-teal);
  }

  /* Newsletter band (navy, matching the site's CTA bands) */
  .footer-newsletter {
    background: var(--surface-navy);
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .newsletter-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg) var(--spacing-2xl);
    flex-wrap: wrap;
  }

  .newsletter-copy h4 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--eflury-white);
    margin: 0 0 0.25rem;
  }

  .newsletter-copy p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0 0 0.6rem;
    max-width: 460px;
  }

  .newsletter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .nl-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.85);
  }

  .newsletter-action {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .nl-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }

  .nl-turnstile:not(:empty) {
    margin-top: 0.4rem;
  }

  .newsletter-micro {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .newsletter-micro a {
    display: inline-flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: underline;
  }

  .newsletter-micro a:hover {
    color: var(--eflury-white);
  }

  .newsletter-success-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    align-self: flex-start;
    padding: 0.55rem 1.1rem;
    background: var(--action-teal);
    border-radius: var(--radius-md);
    color: var(--eflury-white);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .newsletter-success-cta:hover {
    background: var(--primary-700);
  }

  .newsletter-success-cta[hidden] {
    display: none;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-form[hidden] {
    display: none;
  }

  .newsletter-input {
    width: 260px;
    padding: 0.6rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    background: var(--eflury-white);
    color: var(--eflury-navy);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--eflury-teal);
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.12);
  }

  .newsletter-button {
    padding: 0.6rem 1.25rem;
    background: var(--action-teal);
    color: var(--eflury-white);
    border: none;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 700;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .newsletter-button:hover:not(:disabled) {
    background: var(--primary-700);
  }

  .newsletter-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-status {
    display: none;
    font-size: 0.85rem;
  }

  .newsletter-status.success {
    display: block;
    color: var(--eflury-white);
    font-weight: 600;
  }

  .newsletter-status.error {
    display: block;
    color: #ffb4ad;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border-color);
    background: var(--bg-primary);
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    /* keep the legal links clear of the floating chat bubble */
    padding-right: 84px;
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .legal-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .legal-nav a {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .legal-nav a:hover {
    color: var(--eflury-teal);
  }

  .legal-nav .dot {
    color: var(--text-tertiary);
    opacity: 0.6;
    font-size: 0.8rem;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .footer {
      margin-top: 3rem;
    }

    .footer-main {
      padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-xl);
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-xl) var(--spacing-lg);
    }

    .brand-positioning {
      max-width: none;
    }

    .footer-newsletter {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .newsletter-inner {
      flex-direction: column;
      align-items: stretch;
      text-align: left;
    }

    .newsletter-form {
      width: 100%;
    }

    .newsletter-input {
      flex: 1;
      width: auto;
      min-width: 0;
    }

    .footer-bottom {
      padding: var(--spacing-md) var(--spacing-md) calc(var(--spacing-md) + 80px + env(safe-area-inset-bottom));
    }

    .bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }
  }
</style>

<script>
  import { submitHubSpotForm, HUBSPOT_FORMS } from '../scripts/hubspot-forms';

  const newsletterForm = document.getElementById('newsletterForm') as HTMLFormElement;
  const newsletterStatus = document.getElementById('newsletter-status') as HTMLDivElement;
  const newsletterSubmit = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const newsletterEmail = document.getElementById('newsletter-email') as HTMLInputElement;
  const lang = document.documentElement.lang || 'en';

  // --- Bot protection: honeypot + lazily rendered Turnstile ---------------
  let nlToken: string | null = null;
  let nlWidgetRendered = false;

  function renderNlTurnstile() {
    const ts = (window as any).turnstile;
    const container = document.getElementById('newsletter-turnstile');
    if (!ts || !container || nlWidgetRendered) return;
    nlWidgetRendered = true;
    ts.render(container, {
      sitekey: newsletterForm?.dataset.sitekey,
      appearance: 'interaction-only',
      callback: (token: string) => { nlToken = token; },
      'expired-callback': () => { nlToken = null; },
    });
  }

  function ensureTurnstileLoaded() {
    if ((window as any).turnstile) {
      renderNlTurnstile();
      return;
    }
    // Contact pages already load the api.js tag; otherwise inject it once.
    if (!document.querySelector('script[src*="challenges.cloudflare.com"]')) {
      const s = document.createElement('script');
      s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
    const poll = setInterval(() => {
      if ((window as any).turnstile) {
        clearInterval(poll);
        renderNlTurnstile();
      }
    }, 250);
    setTimeout(() => clearInterval(poll), 10000);
  }

  newsletterEmail?.addEventListener('focus', ensureTurnstileLoaded, { once: true });

  if (newsletterForm) {
    newsletterForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Honeypot: bots fill hidden fields — pretend success, submit nothing.
      const honeypot = (document.getElementById('newsletter-hp') as HTMLInputElement)?.value;
      if (honeypot) {
        newsletterStatus.className = 'newsletter-status success';
        newsletterStatus.textContent = lang === 'de' ? 'Abonniert!' : 'Subscribed!';
        newsletterForm.reset();
        return;
      }

      const email = newsletterEmail?.value?.trim();

      if (!email || !email.includes('@') || !email.includes('.')) {
        newsletterStatus.className = 'newsletter-status error';
        newsletterStatus.textContent = lang === 'de'
          ? 'Bitte geben Sie eine gültige E-Mail-Adresse ein.'
          : 'Please enter a valid email address.';
        return;
      }

      // Turnstile gate: widget rendered but unsolved -> ask to wait/complete.
      // Script never loaded (blocked) -> fail open; HubSpot filters spam too.
      if (!nlToken && nlWidgetRendered) {
        newsletterStatus.className = 'newsletter-status error';
        newsletterStatus.textContent = lang === 'de'
          ? 'Bitte schliessen Sie kurz die Sicherheitsprüfung unten ab.'
          : 'Please complete the quick security check below.';
        return;
      }

      const originalText = newsletterSubmit?.textContent || (lang === 'de' ? 'Abonnieren' : 'Subscribe');
      newsletterSubmit.disabled = true;
      newsletterSubmit.textContent = '...';

      try {
        await submitHubSpotForm(HUBSPOT_FORMS.newsletter, { email }, 'Newsletter signup (footer)');

        newsletterStatus.className = 'newsletter-status success';
        newsletterStatus.textContent = lang === 'de'
          ? 'Fast geschafft — bitte bestätigen Sie kurz über die soeben gesendete E-Mail. Ihre Playbooks:'
          : 'Almost done — please confirm via the email we just sent. Your playbooks:';
        newsletterForm.reset();
        newsletterForm.hidden = true;
        const micro = document.querySelector('.newsletter-micro') as HTMLElement | null;
        if (micro) micro.hidden = true;
        const successCta = document.getElementById('newsletterSuccessCta');
        if (successCta) successCta.hidden = false;

        if ((window as any).trackEvent) {
          (window as any).trackEvent('Conversion', 'newsletter_subscribe', 'Newsletter');
        }
      } catch (error) {
        console.error('Newsletter subscription error:', error);
        newsletterStatus.className = 'newsletter-status error';
        newsletterStatus.textContent = lang === 'de'
          ? 'Fehler beim Abonnieren. Bitte versuchen Sie es erneut.'
          : 'Failed to subscribe. Please try again.';
      } finally {
        newsletterSubmit.disabled = false;
        newsletterSubmit.textContent = originalText;
      }
    });
  }
</script>
