---
import { type Language, routes } from '../i18n/utils';
import { Linkedin, Mail, Phone } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const de = lang === 'de';
const r = routes[lang];
const currentYear = new Date().getFullYear();

const t = {
  positioning: de
    ? 'KI-Automatisierung für Schweizer KMU — Fixpreise, Human-in-the-Loop, alles dokumentiert.'
    : 'AI automation for Swiss SMEs — fixed prices, human-in-the-loop, everything documented.',
  services: de ? 'Leistungen' : 'Services',
  industries: de ? 'Branchen' : 'Industries',
  company: de ? 'Unternehmen' : 'Company',
  resources: de ? 'Ressourcen' : 'Resources',
  newsletterTitle: de ? 'KI-Tipps für KMU' : 'AI Tips for SMEs',
  newsletterSubtitle: de
    ? 'Ein praxisnaher Impuls pro Monat. Kostenlos, jederzeit abbestellbar.'
    : 'One practical insight per month. Free, unsubscribe anytime.',
  newsletterPlaceholder: de ? 'ihre@email.ch' : 'your@email.com',
  newsletterButton: de ? 'Abonnieren' : 'Subscribe',
  rights: de ? 'Alle Rechte vorbehalten.' : 'All rights reserved.',
  companyLine: de
    ? 'eFlury Consulting · Einzelfirma · Grenchen, Schweiz'
    : 'eFlury Consulting · Sole Proprietorship · Grenchen, Switzerland',
};

const columns = [
  {
    title: t.services,
    links: [
      { label: de ? 'Übersicht' : 'Overview', href: r.services },
      { label: de ? 'KI-Audit' : 'AI Audit', href: r.servicesAiAudit },
      { label: 'Claude Skills', href: r.servicesClaudeSkills },
      { label: 'MCP Integration', href: r.servicesMcpIntegration },
      { label: de ? 'Finanzautomatisierung' : 'Finance Automation', href: r.servicesFinanceAutomation },
      { label: 'Power BI', href: r.servicesPowerBi },
      { label: de ? 'Datenqualität' : 'Data Quality', href: r.servicesDataQuality },
      { label: de ? 'KI-Betrieb' : 'Managed Operations', href: r.servicesManagedOps },
    ],
  },
  {
    title: t.industries,
    links: [
      { label: de ? 'Übersicht' : 'Overview', href: r.industries },
      { label: de ? 'Treuhand & Buchhaltung' : 'Treuhand & Accounting', href: r.industriesTreuhand },
      { label: de ? 'Finanzteams' : 'Finance Teams', href: r.industriesFinanceTeams },
      { label: de ? 'Dienstleister' : 'Professional Services', href: r.industriesProfessionalServices },
    ],
  },
  {
    title: t.company,
    links: [
      { label: de ? 'Über mich' : 'About', href: `/${lang}/about/` },
      { label: de ? 'Unsere Methode' : 'Our Method', href: r.method },
      { label: de ? 'Sicherheit & Vertrauen' : 'Trust & Security', href: r.trust },
      { label: de ? 'Preise' : 'Pricing', href: `/${lang}/pricing/` },
      { label: de ? 'Karriere' : 'Careers', href: r.careers },
    ],
  },
  {
    title: t.resources,
    links: [
      { label: de ? 'Referenzen' : 'Case Studies', href: `/${lang}/case-studies/` },
      { label: 'Insights', href: `/${lang}/blog/` },
      { label: de ? 'Leitfäden' : 'Guides', href: r.guides },
      { label: 'SkopaAI', href: `/${lang}/skopaai/` },
      { label: de ? 'Kontakt' : 'Contact', href: r.contact },
    ],
  },
];

const legalLinks = [
  { label: de ? 'Datenschutz' : 'Privacy', href: r.privacy },
  { label: de ? 'AGB' : 'Terms', href: r.terms },
  { label: 'Cookies', href: r.cookies },
  { label: de ? 'Haftung' : 'Disclaimer', href: r.disclaimer },
  { label: de ? 'Verhaltenskodex' : 'Code of Conduct', href: r.codeOfConduct },
  { label: de ? 'Impressum' : 'Imprint', href: r.imprint },
];
---

<footer class="footer">
  <div class="footer-main">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={r.home} class="brand-mark">eFlury <span>Consulting</span></a>
        <p class="brand-positioning">{t.positioning}</p>
        <ul class="brand-contact">
          <li><a href="mailto:me@eflury.com"><Mail size={15} /> me@eflury.com</a></li>
          <li><a href="tel:+41799107787"><Phone size={15} /> +41 79 910 77 87</a></li>
          <li>
            <a href="https://linkedin.com/in/emanuelflury" target="_blank" rel="noopener" aria-label="LinkedIn">
              <Linkedin size={15} /> LinkedIn
            </a>
          </li>
        </ul>
      </div>

      {columns.map((col) => (
        <nav class="footer-col" aria-label={col.title}>
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((l) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </nav>
      ))}
    </div>
  </div>

  <div class="footer-newsletter">
    <div class="newsletter-inner">
      <div class="newsletter-copy">
        <h4>{t.newsletterTitle}</h4>
        <p>{t.newsletterSubtitle}</p>
      </div>
      <form class="newsletter-form" id="newsletterForm">
        <input
          type="email"
          id="newsletter-email"
          name="email"
          placeholder={t.newsletterPlaceholder}
          class="newsletter-input"
          autocomplete="email"
          inputmode="email"
          aria-label={t.newsletterTitle}
          required
        />
        <button type="submit" class="newsletter-button" id="newsletter-submit">
          {t.newsletterButton}
        </button>
      </form>
      <div id="newsletter-status" class="newsletter-status" role="status" aria-live="polite"></div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="bottom-inner">
      <p class="copyright">
        &copy; {currentYear} {t.companyLine}. {t.rights}
      </p>
      <nav class="legal-nav" aria-label={de ? 'Rechtliches' : 'Legal'}>
        {legalLinks.map((l, i) => (
          <>
            <a href={l.href}>{l.label}</a>
            {i < legalLinks.length - 1 && <span class="dot" aria-hidden="true">·</span>}
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    margin-top: 5rem;
  }

  .footer-main {
    padding: var(--spacing-3xl) var(--spacing-lg) var(--spacing-2xl);
  }

  .footer-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: var(--spacing-2xl) var(--spacing-xl);
  }

  /* Brand block */
  .brand-mark {
    display: inline-block;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--eflury-navy);
    text-decoration: none;
    margin-bottom: var(--spacing-md);
  }

  .brand-mark span {
    color: var(--eflury-teal);
  }

  .brand-positioning {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 260px;
    margin: 0 0 var(--spacing-lg);
  }

  .brand-contact {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .brand-contact a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .brand-contact a:hover {
    color: var(--eflury-teal);
  }

  .brand-contact :global(svg) {
    color: var(--eflury-teal);
    flex-shrink: 0;
  }

  /* Link columns */
  .footer-col h4 {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 var(--spacing-md);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer-col a {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-col a:hover {
    color: var(--eflury-teal);
  }

  /* Newsletter band */
  .footer-newsletter {
    border-top: 1px solid var(--border-color);
    padding: var(--spacing-lg) var(--spacing-lg);
  }

  .newsletter-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
  }

  .newsletter-copy h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.15rem;
  }

  .newsletter-copy p {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .newsletter-input {
    width: 240px;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    background: var(--bg-primary);
    color: var(--text-primary);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .newsletter-input:focus {
    outline: none;
    border-color: var(--eflury-teal);
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.12);
  }

  .newsletter-button {
    padding: 0.6rem 1.25rem;
    background: var(--eflury-navy);
    color: var(--eflury-white);
    border: none;
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .newsletter-button:hover:not(:disabled) {
    background: var(--eflury-teal);
  }

  .newsletter-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-status {
    flex-basis: 100%;
    display: none;
    font-size: 0.8rem;
    text-align: right;
  }

  .newsletter-status.success {
    display: block;
    color: var(--eflury-teal);
  }

  .newsletter-status.error {
    display: block;
    color: var(--accent-red);
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid var(--border-color);
    background: var(--bg-primary);
    padding: var(--spacing-md) var(--spacing-lg);
  }

  .bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    flex-wrap: wrap;
    /* keep the legal links clear of the floating chat bubble */
    padding-right: 84px;
  }

  .copyright {
    font-size: 0.8rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .legal-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .legal-nav a {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .legal-nav a:hover {
    color: var(--eflury-teal);
  }

  .legal-nav .dot {
    color: var(--text-tertiary);
    opacity: 0.6;
    font-size: 0.8rem;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile */
  @media (max-width: 768px) {
    .footer {
      margin-top: 3rem;
    }

    .footer-main {
      padding: var(--spacing-2xl) var(--spacing-md) var(--spacing-xl);
    }

    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-xl) var(--spacing-lg);
    }

    .brand-positioning {
      max-width: none;
    }

    .footer-newsletter {
      padding: var(--spacing-lg) var(--spacing-md);
    }

    .newsletter-inner {
      flex-direction: column;
      align-items: stretch;
      text-align: left;
    }

    .newsletter-form {
      width: 100%;
    }

    .newsletter-input {
      flex: 1;
      width: auto;
      min-width: 0;
    }

    .newsletter-status {
      text-align: left;
    }

    .footer-bottom {
      padding: var(--spacing-md) var(--spacing-md) calc(var(--spacing-md) + 80px + env(safe-area-inset-bottom));
    }

    .bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }
  }
</style>

<script>
  import { submitHubSpotForm, HUBSPOT_FORMS } from '../scripts/hubspot-forms';

  const newsletterForm = document.getElementById('newsletterForm') as HTMLFormElement;
  const newsletterStatus = document.getElementById('newsletter-status') as HTMLDivElement;
  const newsletterSubmit = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const newsletterEmail = document.getElementById('newsletter-email') as HTMLInputElement;
  const lang = document.documentElement.lang || 'en';

  if (newsletterForm) {
    newsletterForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const email = newsletterEmail?.value?.trim();

      if (!email || !email.includes('@') || !email.includes('.')) {
        newsletterStatus.className = 'newsletter-status error';
        newsletterStatus.textContent = lang === 'de'
          ? 'Bitte geben Sie eine gültige E-Mail-Adresse ein.'
          : 'Please enter a valid email address.';
        return;
      }

      const originalText = newsletterSubmit?.textContent || (lang === 'de' ? 'Abonnieren' : 'Subscribe');
      newsletterSubmit.disabled = true;
      newsletterSubmit.textContent = '...';

      try {
        await submitHubSpotForm(HUBSPOT_FORMS.newsletter, { email }, 'Newsletter signup (footer)');

        newsletterStatus.className = 'newsletter-status success';
        newsletterStatus.textContent = lang === 'de'
          ? 'Erfolgreich abonniert! Vielen Dank.'
          : 'Successfully subscribed! Thank you.';
        newsletterForm.reset();

        if ((window as any).trackEvent) {
          (window as any).trackEvent('Conversion', 'newsletter_subscribe', 'Newsletter');
        }
      } catch (error) {
        console.error('Newsletter subscription error:', error);
        newsletterStatus.className = 'newsletter-status error';
        newsletterStatus.textContent = lang === 'de'
          ? 'Fehler beim Abonnieren. Bitte versuchen Sie es erneut.'
          : 'Failed to subscribe. Please try again.';
      } finally {
        newsletterSubmit.disabled = false;
        newsletterSubmit.textContent = originalText;
      }
    });
  }
</script>
