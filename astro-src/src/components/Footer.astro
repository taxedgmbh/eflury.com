---
import { type Language, useTranslations, routes } from '../i18n/utils';
import { Linkedin, Github, Mail, Phone } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentRoutes = routes[lang];
const currentYear = new Date().getFullYear();

// Legal section title
const legalTitle = lang === 'en' ? 'Legal' : 'Rechtliches';
---

<footer class="footer">
  <div class="footer-container">
    <!-- Column 1: Brand & Description -->
    <div class="footer-section footer-brand">
      <h3 class="footer-logo">Emanuel Flury</h3>
      <p class="footer-tagline">{t('footer.tagline')}</p>
      <p class="footer-description">{t('footer.description')}</p>

      <!-- Social Media Links -->
      <div class="social-links">
        <a href="https://linkedin.com/in/emanuelflury" target="_blank" rel="noopener" title="LinkedIn" aria-label="Visit LinkedIn profile">
          <Linkedin size={20} />
        </a>
        <a href="https://github.com/taxedgmbh" target="_blank" rel="noopener" title="GitHub" aria-label="Visit GitHub profile">
          <Github size={20} />
        </a>
        <a href="mailto:me@eflury.com" title="Email" aria-label="Send email">
          <Mail size={20} />
        </a>
        <a href="tel:+41799107787" title="Phone" aria-label="Call phone number">
          <Phone size={20} />
        </a>
      </div>
    </div>

    <!-- Column 2: Services -->
    <div class="footer-section">
      <h4>{t('footer.sections.services')}</h4>
      <ul class="footer-links">
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.automation')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.tax')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.analytics')}</a></li>
        <li><a href={`${currentRoutes.services}`}>{t('footer.services_list.consulting')}</a></li>
      </ul>
    </div>

    <!-- Column 3: Contact -->
    <div class="footer-section">
      <h4>{lang === 'en' ? 'Contact' : 'Kontakt'}</h4>
      <ul class="footer-links">
        <li><a href="mailto:me@eflury.com">me@eflury.com</a></li>
        <li><a href="tel:+41799107787">+41 79 910 77 87</a></li>
        <li><span>Grenchen, Switzerland</span></li>
      </ul>
    </div>

    <!-- Column 4: Legal (Simplified Apple/Google Style) -->
    <div class="footer-section footer-legal">
      <h4>{legalTitle}</h4>
      <div class="legal-links-compact">
        <a href={currentRoutes.privacy}>{lang === 'en' ? 'Privacy' : 'Datenschutz'}</a>
        <span class="separator">·</span>
        <a href={currentRoutes.terms}>{lang === 'en' ? 'Terms' : 'AGB'}</a>
        <span class="separator">·</span>
        <a href={currentRoutes.cookies}>Cookies</a>
      </div>
      <div class="legal-links-compact">
        <a href={currentRoutes.disclaimer}>{lang === 'en' ? 'Disclaimer' : 'Haftung'}</a>
        <span class="separator">·</span>
        <a href={currentRoutes.codeOfConduct}>{lang === 'en' ? 'Code of Conduct' : 'Verhaltenskodex'}</a>
      </div>
      <a href={lang === 'en' ? 'https://www.edoeb.admin.ch/edoeb/en/home.html' : 'https://www.edoeb.admin.ch/edoeb/de/home.html'}
         target="_blank" rel="noopener" class="external-legal-link">
        {lang === 'en' ? 'Swiss Data Protection' : 'CH Datenschutz'} ↗
      </a>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-container">
      <p class="copyright">&copy; {currentYear} Emanuel Flury. {lang === 'en' ? 'All rights reserved.' : 'Alle Rechte vorbehalten.'}</p>
      <p class="made-with">{t('footer.made_with')}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    padding: 4rem 0 0;
    margin-top: 5rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
  }

  .footer-section h3,
  .footer-section h4 {
    color: var(--primary-green);
    margin-bottom: 1rem;
  }

  .footer-logo {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .footer-description {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-primary);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .social-links a:hover {
    background: var(--primary);
    color: var(--apple-white);
    border-color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }

  .social-links a svg {
    transition: transform var(--transition-fast);
  }

  .social-links a:hover svg {
    transform: scale(1.1);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.75rem;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition-smooth);
    display: inline-block;
  }

  .footer-links a:hover {
    color: var(--primary-green);
    transform: translateX(5px);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border-color);
    background: var(--bg-primary);
  }

  .footer-bottom-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright,
  .made-with {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin: 0;
  }

  /* Legal Links - Compact Style (Apple/Google inspired) */
  .footer-legal h4 {
    margin-bottom: 1rem;
  }

  .legal-links-compact {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.5rem;
  }

  .legal-links-compact a {
    color: var(--text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .legal-links-compact a:hover {
    color: var(--primary);
  }

  .separator {
    color: var(--text-muted);
    font-size: 0.875rem;
    opacity: 0.5;
  }

  .external-legal-link {
    color: var(--text-secondary);
    font-size: 0.875rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: 0.5rem;
    transition: color var(--transition-fast);
  }

  .external-legal-link:hover {
    color: var(--primary);
  }

  @media (max-width: 1024px) {
    .footer-bottom-container {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .footer {
      padding-bottom: calc(80px + env(safe-area-inset-bottom));
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 max(var(--spacing-lg), env(safe-area-inset-left)) 0 max(var(--spacing-lg), env(safe-area-inset-right));
    }

    .footer-bottom-container {
      padding: 0 max(var(--spacing-lg), env(safe-area-inset-left)) 0 max(var(--spacing-lg), env(safe-area-inset-right));
    }

    .footer-legal {
      margin-top: 1rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border-color);
    }

    .legal-links-compact {
      gap: 0.5rem;
    }
  }
</style>
