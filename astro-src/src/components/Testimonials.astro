---
import { type Language, useTranslations } from '../i18n/utils';
import { Briefcase, Wrench, BadgeSwissFranc, Eye, ArrowRight } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const de = lang === 'de';

// Every claim links to the page where it can be verified.
const valueProps = [
  {
    icon: Briefcase,
    title: t('testimonials.value_prop1.title'),
    description: t('testimonials.value_prop1.description'),
    link: t('testimonials.value_prop1.link'),
    href: `/${lang}/about/`,
  },
  {
    icon: Wrench,
    title: t('testimonials.value_prop2.title'),
    description: t('testimonials.value_prop2.description'),
    link: t('testimonials.value_prop2.link'),
    href: `/${lang}/case-studies/`,
  },
  {
    icon: BadgeSwissFranc,
    title: t('testimonials.value_prop3.title'),
    description: t('testimonials.value_prop3.description'),
    link: t('testimonials.value_prop3.link'),
    href: `/${lang}/pricing/`,
  },
  {
    icon: Eye,
    title: t('testimonials.value_prop4.title'),
    description: t('testimonials.value_prop4.description'),
    link: t('testimonials.value_prop4.link'),
    href: de ? '/de/sicherheit/' : '/en/trust/',
  },
];
---

<section class="testimonials section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('testimonials.title')}</h2>
      <p class="section-subtitle">{t('testimonials.subtitle')}</p>
    </div>

    <div class="testimonials-grid">
      {valueProps.map(({ icon: Icon, title, description, link, href }) => (
        <div class="testimonial-card">
          <div class="value-icon">
            <Icon size={28} />
          </div>
          <h3 class="value-title">{title}</h3>
          <p class="value-description">{description}</p>
          <a href={href} class="value-link">{link} <ArrowRight size={14} /></a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .testimonial-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    border: 0.5px solid var(--separator);
    transition: all var(--transition-base);
    position: relative;
    box-shadow: var(--shadow-xs);
    text-align: center;
  }

  .testimonial-card .value-description {
    flex-grow: 1;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary);
  }

  .value-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 1.5rem;
    background: var(--gradient-primary);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .value-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .value-description {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .value-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
  }

  .value-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
