---
import { type Language, useTranslations } from '../i18n/utils';
import { Star, Play } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Helper to safely get optional translation values
const getOptional = (key: string): string | undefined => {
  try {
    const value = t(key as any);
    return value && value !== key ? value : undefined;
  } catch {
    return undefined;
  }
};

const testimonials = [
  {
    name: t('testimonials.testimonial1.name'),
    role: t('testimonials.testimonial1.role'),
    company: t('testimonials.testimonial1.company'),
    text: t('testimonials.testimonial1.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial1.videoUrl')
  },
  {
    name: t('testimonials.testimonial2.name'),
    role: t('testimonials.testimonial2.role'),
    company: t('testimonials.testimonial2.company'),
    text: t('testimonials.testimonial2.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial2.videoUrl')
  },
  {
    name: t('testimonials.testimonial3.name'),
    role: t('testimonials.testimonial3.role'),
    company: t('testimonials.testimonial3.company'),
    text: t('testimonials.testimonial3.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial3.videoUrl')
  },
  {
    name: t('testimonials.testimonial4.name'),
    role: t('testimonials.testimonial4.role'),
    company: t('testimonials.testimonial4.company'),
    text: t('testimonials.testimonial4.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial4.videoUrl')
  },
  {
    name: t('testimonials.testimonial5.name'),
    role: t('testimonials.testimonial5.role'),
    company: t('testimonials.testimonial5.company'),
    text: t('testimonials.testimonial5.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial5.videoUrl')
  },
  {
    name: t('testimonials.testimonial6.name'),
    role: t('testimonials.testimonial6.role'),
    company: t('testimonials.testimonial6.company'),
    text: t('testimonials.testimonial6.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial6.videoUrl')
  },
  {
    name: t('testimonials.testimonial7.name'),
    role: t('testimonials.testimonial7.role'),
    company: t('testimonials.testimonial7.company'),
    text: t('testimonials.testimonial7.text'),
    rating: 5,
    videoUrl: getOptional('testimonials.testimonial7.videoUrl')
  }
];
---

<section class="testimonials section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('testimonials.title')}</h2>
      <p class="section-subtitle">{t('testimonials.subtitle')}</p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((testimonial) => (
        <div class={`testimonial-card ${testimonial.videoUrl ? 'has-video' : ''}`}>
          {testimonial.videoUrl && (
            <div class="testimonial-video">
              <iframe
                src={testimonial.videoUrl}
                title={`Video testimonial from ${testimonial.name}`}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
              <div class="video-badge">
                <Play size={12} fill="currentColor" />
                <span>Video</span>
              </div>
            </div>
          )}
          <div class="testimonial-rating">
            {[...Array(testimonial.rating)].map(() => (
              <Star size={18} fill="currentColor" />
            ))}
          </div>
          <p class="testimonial-text">"{testimonial.text}"</p>
          <div class="testimonial-author">
            <div class="author-avatar">
              {testimonial.name.charAt(0)}
            </div>
            <div class="author-info">
              <h4>{testimonial.name}</h4>
              <p>{testimonial.role}</p>
              <p class="author-company">{testimonial.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--bg-primary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    border: 0.5px solid var(--separator);
    transition: all var(--transition-base);
    position: relative;
    box-shadow: var(--shadow-xs);
    -webkit-tap-highlight-color: transparent;
  }

  .testimonial-card:active {
    transform: scale(0.98);
    opacity: 0.9;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary);
  }

  .testimonial-rating {
    display: flex;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
    color: var(--accent-orange);
  }
  
  .testimonial-rating svg {
    width: 18px;
    height: 18px;
  }

  .testimonial-text {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .author-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.5rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .author-info h4 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .author-info p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0;
  }

  .author-company {
    font-weight: 600;
    color: var(--primary-green);
  }

  /* Video Testimonial Styles */
  .testimonial-card.has-video {
    padding-top: 0;
    overflow: hidden;
  }

  .testimonial-video {
    position: relative;
    width: calc(100% + 2 * var(--spacing-xl));
    margin-left: calc(-1 * var(--spacing-xl));
    margin-bottom: var(--spacing-lg);
    aspect-ratio: 16 / 9;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--separator);
  }

  .testimonial-video iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-badge {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    border-radius: var(--radius-sm);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .video-badge svg {
    width: 10px;
    height: 10px;
  }

  .testimonial-card.has-video .testimonial-rating {
    margin-top: var(--spacing-lg);
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .testimonial-video {
      width: calc(100% + 2 * var(--spacing-lg));
      margin-left: calc(-1 * var(--spacing-lg));
    }
  }
</style>
