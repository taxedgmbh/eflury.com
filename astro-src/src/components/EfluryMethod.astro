---
import { type Language, useTranslations } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Access phases array from translations
const phasesData = [
  {
    title: t('method.phases.0.title'),
    description: t('method.phases.0.description'),
    duration: t('method.phases.0.duration'),
  },
  {
    title: t('method.phases.1.title'),
    description: t('method.phases.1.description'),
    duration: t('method.phases.1.duration'),
  },
  {
    title: t('method.phases.2.title'),
    description: t('method.phases.2.description'),
    duration: t('method.phases.2.duration'),
  },
  {
    title: t('method.phases.3.title'),
    description: t('method.phases.3.description'),
    duration: t('method.phases.3.duration'),
  },
  {
    title: t('method.phases.4.title'),
    description: t('method.phases.4.description'),
    duration: t('method.phases.4.duration'),
  },
];
---

<section class="eflury-method" id="method">
  <div class="method-container">
    <div class="section-header">
      <h2 class="section-title">{t('method.section_title')}</h2>
      <p class="section-subtitle">{t('method.section_subtitle')}</p>
    </div>

    <div class="timeline">
      <div class="timeline-track"></div>
      {phasesData.map((phase, index) => (
        <div class="phase" style={`--phase-index: ${index}`}>
          <div class="phase-marker">
            <div class="phase-number">{index + 1}</div>
            {index < phasesData.length - 1 && <div class="phase-connector"></div>}
          </div>
          <div class="phase-content">
            <h3 class="phase-title">{phase.title}</h3>
            <p class="phase-description">{phase.description}</p>
            <span class="phase-duration">{phase.duration}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .eflury-method {
    --eflury-navy: #022554;
    --eflury-teal: #0d9488;

    background: linear-gradient(135deg, rgba(2, 37, 84, 0.03) 0%, rgba(13, 148, 136, 0.05) 100%);
    padding: 7rem 2rem;
    position: relative;
    overflow: hidden;
  }

  /* Subtle decorative elements */
  .eflury-method::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(13, 148, 136, 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .eflury-method::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(2, 37, 84, 0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  .method-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--eflury-navy);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  :global([data-theme="dark"]) .section-title {
    color: var(--text-primary);
  }

  .section-subtitle {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Desktop: Horizontal Timeline */
  .timeline {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    padding-top: 2rem;
  }

  .timeline-track {
    position: absolute;
    top: calc(2rem + 28px);
    left: 56px;
    right: 56px;
    height: 3px;
    background: linear-gradient(90deg, var(--eflury-navy) 0%, var(--eflury-teal) 50%, var(--eflury-navy) 100%);
    border-radius: 2px;
    opacity: 0.3;
  }

  .phase {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.6s ease forwards;
    animation-delay: calc(var(--phase-index) * 0.15s);
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .phase-marker {
    position: relative;
    z-index: 2;
    margin-bottom: 1.5rem;
  }

  .phase-number {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--eflury-navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    box-shadow:
      0 4px 16px rgba(2, 37, 84, 0.25),
      0 0 0 4px rgba(255, 255, 255, 0.9),
      0 0 0 6px rgba(13, 148, 136, 0.3);
    transition: all 0.3s ease;
    position: relative;
  }

  :global([data-theme="dark"]) .phase-number {
    box-shadow:
      0 4px 16px rgba(2, 37, 84, 0.4),
      0 0 0 4px rgba(30, 41, 59, 0.9),
      0 0 0 6px rgba(13, 148, 136, 0.4);
  }

  .phase:hover .phase-number {
    background: var(--eflury-teal);
    transform: scale(1.1);
    box-shadow:
      0 8px 24px rgba(13, 148, 136, 0.35),
      0 0 0 4px rgba(255, 255, 255, 0.9),
      0 0 0 6px rgba(13, 148, 136, 0.5);
  }

  .phase-connector {
    display: none; /* Hidden on desktop, shown on mobile */
  }

  .phase-content {
    background: var(--bg-primary);
    border-radius: 20px;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--border-color);
    max-width: 200px;
    transition: all 0.3s ease;
    position: relative;
  }

  .phase-content::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    background: var(--bg-primary);
    border-left: 1px solid var(--border-color);
    border-top: 1px solid var(--border-color);
    transform: translateX(-50%) rotate(45deg);
  }

  .phase:hover .phase-content {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.1);
    border-color: var(--eflury-teal);
  }

  :global([data-theme="dark"]) .phase:hover .phase-content {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);
  }

  .phase-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--eflury-navy);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  :global([data-theme="dark"]) .phase-title {
    color: var(--text-primary);
  }

  .phase-description {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .phase-duration {
    display: inline-block;
    padding: 0.375rem 0.875rem;
    background: transparent;
    border: 1.5px solid var(--eflury-teal);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--eflury-teal);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Tablet: Adjusted spacing */
  @media (max-width: 1100px) {
    .phase-content {
      max-width: 180px;
      padding: 1.5rem 1.25rem;
    }

    .phase-title {
      font-size: 1rem;
    }

    .phase-description {
      font-size: 0.85rem;
    }
  }

  /* Mobile: Vertical Timeline */
  @media (max-width: 800px) {
    .eflury-method {
      padding: 5rem 1.5rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .timeline {
      flex-direction: column;
      align-items: flex-start;
      padding-top: 0;
      gap: 0;
    }

    .timeline-track {
      display: none;
    }

    .phase {
      flex-direction: row;
      align-items: flex-start;
      text-align: left;
      width: 100%;
      gap: 1.25rem;
    }

    .phase-marker {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-shrink: 0;
      margin-bottom: 0;
    }

    .phase-number {
      width: 48px;
      height: 48px;
      font-size: 1.25rem;
      box-shadow:
        0 4px 12px rgba(2, 37, 84, 0.2),
        0 0 0 3px rgba(255, 255, 255, 0.9),
        0 0 0 5px rgba(13, 148, 136, 0.25);
    }

    .phase:hover .phase-number {
      transform: none;
    }

    .phase-connector {
      display: block;
      width: 2px;
      flex-grow: 1;
      min-height: 40px;
      background: linear-gradient(
        to bottom,
        var(--eflury-teal) 0%,
        var(--border-color) 100%
      );
      margin-top: 0.5rem;
    }

    .phase:last-child .phase-connector {
      display: none;
    }

    .phase-content {
      max-width: none;
      flex-grow: 1;
      margin-bottom: 1.5rem;
      border-radius: 16px;
      padding: 1.5rem;
    }

    .phase-content::before {
      top: 16px;
      left: -8px;
      transform: rotate(-45deg);
    }

    .phase:hover .phase-content {
      transform: translateX(8px);
    }

    .phase-title {
      font-size: 1.1rem;
    }

    .phase-description {
      font-size: 0.9rem;
    }
  }

  /* Small mobile */
  @media (max-width: 480px) {
    .eflury-method {
      padding: 4rem 1rem;
    }

    .phase {
      gap: 1rem;
    }

    .phase-number {
      width: 44px;
      height: 44px;
      font-size: 1.125rem;
    }

    .phase-content {
      padding: 1.25rem;
    }

    .phase-title {
      font-size: 1rem;
    }

    .phase-description {
      font-size: 0.85rem;
    }

    .phase-duration {
      font-size: 0.7rem;
      padding: 0.3rem 0.75rem;
    }
  }
</style>
