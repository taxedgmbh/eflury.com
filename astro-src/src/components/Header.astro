---
import { type Language, useTranslations, routes } from '../i18n/utils';
import DarkModeToggle from './DarkModeToggle.astro';
import {
  ChevronDown,
  ClipboardCheck,
  FileText,
  Cpu,
  Server,
  Calculator,
  BarChart3,
  Database,
  Activity,
  Briefcase,
  User,
  Route,
  FolderCheck,
  Shield,
  BadgeSwissFranc,
  Users,
} from 'lucide-astro';

interface Props {
  lang: Language;
  languageSwitchUrl?: string;
}

const { lang, languageSwitchUrl } = Astro.props;
const t = useTranslations(lang);
const currentRoutes = routes[lang];
const de = lang === 'de';

// Generate language switch URLs that preserve the current page
const currentPath = Astro.url.pathname;
const getLanguageSwitchUrl = (targetLang: Language) => {
  // If a custom languageSwitchUrl is provided (e.g., for blog posts), use it
  if (languageSwitchUrl && targetLang !== lang) {
    return languageSwitchUrl;
  }
  // If on root, go to language home
  if (currentPath === '/' || currentPath === '') {
    return `/${targetLang}/`;
  }
  // Pages with localized slugs (legal pages, finanzen-automatisierung) can't
  // use prefix replacement — look the path up in the routes table first.
  const normalized = currentPath.endsWith('/') ? currentPath : `${currentPath}/`;
  for (const [key, path] of Object.entries(routes[lang])) {
    if (path === normalized) {
      return routes[targetLang][key as keyof (typeof routes)['en']];
    }
  }
  // Replace /en/ or /de/ prefix with target language
  return currentPath.replace(/^\/(en|de)\//, `/${targetLang}/`);
};

// ---- mega menu content (approved design: lifecycle stages + proof rail) ----
const servicesMenu = {
  stages: [
    {
      pill: 'Advise',
      cls: 'navy',
      line: de ? 'Verstehen & priorisieren' : 'Understand & prioritize',
      items: [
        {
          icon: ClipboardCheck,
          title: de ? 'KI-Audit' : 'AI Audit',
          sub: de ? "Roadmap in 1 Woche · CHF 4'900, voll angerechnet" : "Roadmap in 1 week · CHF 4'900, fully credited",
          href: de ? '/de/services/ki-audit/' : '/en/services/ai-audit/',
        },
        {
          icon: FileText,
          title: de ? 'Musterbericht (PDF)' : 'Sample report (PDF)',
          sub: de ? 'So sieht das Audit-Ergebnis aus' : 'What the audit result looks like',
          href: de ? '/downloads/eflury-sample-audit-report-de.pdf' : '/downloads/eflury-sample-audit-report-en.pdf',
        },
      ],
    },
    {
      pill: 'Build',
      cls: 'teal',
      line: de ? 'Bauen & einführen' : 'Build & roll out',
      items: [
        {
          icon: Cpu,
          title: 'Claude Skills',
          sub: de ? 'Kernbaustein jedes Pakets' : 'Core building block of every package',
          href: `/${lang}/services/claude-skills/`,
        },
        {
          icon: Server,
          title: 'MCP Integration',
          sub: de ? 'bexio · Datenbanken · Microsoft 365' : 'bexio · databases · Microsoft 365',
          href: `/${lang}/services/mcp-integration/`,
        },
        {
          icon: Calculator,
          title: de ? 'Finanz-Automatisierung' : 'Finance Automation',
          sub: de ? 'Monatsabschluss · Kreditoren · Reporting' : 'Month-end close · payables · reporting',
          href: de ? '/de/services/finanzen-automatisierung/' : '/en/services/finance-automation/',
        },
        {
          icon: BarChart3,
          title: 'Power BI',
          sub: de ? 'Dashboards · Excel-Migration' : 'Dashboards · Excel migration',
          href: `/${lang}/services/power-bi/`,
        },
        {
          icon: Database,
          title: de ? 'Datenqualität' : 'Data Quality',
          badge: de ? 'Neu' : 'New',
          sub: de ? 'KI-Agenten mit Live-Demo' : 'AI agents with live demo',
          href: de ? '/de/services/datenqualitaet/' : '/en/services/data-quality/',
        },
      ],
    },
    {
      pill: 'Run',
      cls: 'blue',
      line: de ? 'Betreiben & verbessern' : 'Run & improve',
      items: [
        {
          icon: Activity,
          title: 'Managed AI Operations',
          sub: de ? "Monitoring & Betrieb · ab CHF 1'200/Monat" : "Monitoring & operations · from CHF 1'200/month",
          href: de ? '/de/services/ki-betrieb/' : '/en/services/managed-ai-operations/',
        },
      ],
    },
  ],
  rail: {
    title: de ? 'Ein Lebenszyklus, Fixpreise' : 'One lifecycle, fixed prices',
    sub: de
      ? 'Wir beraten, bevor wir bauen — und betreiben, was wir gebaut haben.'
      : "We advise before we build — and run what we've built.",
    links: [
      { label: de ? 'Preise & Pakete' : 'Pricing & packages', small: de ? "ab CHF 5'900" : "from CHF 5'900", href: `/${lang}/pricing/` },
      { label: de ? 'Demo ansehen' : 'Watch the demo', small: de ? '30-Sek.-Beispiel' : '30-sec example', href: `/${lang}/services/#demo` },
      { label: de ? 'Referenzen' : 'Case studies', small: '', href: `/${lang}/case-studies/` },
    ],
  },
  bottomLink: { label: de ? 'Alle Leistungen im Überblick' : 'All services at a glance', href: `/${lang}/services/` },
  bottomNote: de
    ? 'Nicht sicher? Kostenloses 30-Min-Gespräch — wir sagen ehrlich, ob es passt.'
    : "Not sure? Free 30-min call — we'll tell you honestly if it fits.",
};

const industriesMenu = {
  items: [
    {
      icon: Calculator,
      title: de ? 'Finanzen & Back Office' : 'Finance & Back Office',
      sub: de
        ? 'Kreditoren · Monatsabschluss · Mahnwesen — 2 dokumentierte Projekte'
        : 'Payables · month-end close · dunning — 2 documented projects',
      href: de ? '/de/branchen/finanzteams/' : '/en/industries/finance-teams/',
    },
    {
      icon: Briefcase,
      title: de ? 'Kundenkommunikation & Annahme' : 'Customer Communication & Intake',
      sub: de
        ? 'E-Mail-Triage · Telefon · WhatsApp · Offertanfragen — 1 Projekt'
        : 'Email triage · phone · WhatsApp · quote requests — 1 project',
      href: de ? '/de/branchen/dienstleister/' : '/en/industries/professional-services/',
    },
    {
      icon: BarChart3,
      title: de ? 'Reporting & Daten' : 'Reporting & Data',
      sub: de
        ? 'Power-BI-Dashboards · Excel-Migration · Datenqualität — 1 Projekt'
        : 'Power BI dashboards · Excel migration · data quality — 1 project',
      href: de ? '/de/branchen/reporting-daten/' : '/en/industries/reporting-data/',
    },
  ],
  rail: {
    title: de ? 'Verankert in Projekten' : 'Grounded in projects',
    links: [
      { label: de ? '~40 Std./Monat' : '~40 h/month', small: de ? 'Finanzprozesse' : 'finance processes', href: `/${lang}/case-studies/finance-automation/` },
      { label: de ? '~15 Std./Woche' : '~15 h/week', small: 'Reporting', href: `/${lang}/case-studies/power-bi-reporting/` },
      { label: de ? '~27.5 Std./Woche' : '~27.5 h/week', small: de ? 'eigene Firma' : 'our own firm', href: `/${lang}/case-studies/taxed-gmbh/` },
    ],
    sub: de ? 'Publizierte Schätzungen — jede Zahl führt zur Fallstudie.' : 'Published estimates — every number links to its case study.',
  },
  bottomLink: { label: de ? 'Alle Einsatzbereiche' : 'All business areas', href: currentRoutes.industries },
  bottomNote: de ? 'Ihre Branche fehlt? Ihr Prozess vermutlich nicht.' : "Your industry missing? Your process probably isn't.",
};

const companyMenu = [
  { icon: User, title: de ? 'Über uns' : 'About us', href: `/${lang}/about/` },
  { icon: Route, title: de ? 'Unsere Methode' : 'Our method', href: de ? '/de/methode/' : '/en/method/' },
  { icon: FolderCheck, title: de ? 'Referenzen' : 'Case studies', href: `/${lang}/case-studies/` },
  { icon: Shield, title: de ? 'Sicherheit & Vertrauen' : 'Trust & Security', href: de ? '/de/sicherheit/' : '/en/trust/' },
  { icon: BadgeSwissFranc, title: de ? 'Preise' : 'Pricing', href: `/${lang}/pricing/` },
  { icon: Users, title: de ? 'Karriere' : 'Careers', href: de ? '/de/karriere/' : '/en/careers/' },
];

const englishLabelEN = de ? 'Englisch' : 'English';
const germanLabelEN = de ? 'Deutsch' : 'German';

// mini lifecycle orbit for the services rail (computed arcs, logo at center)
const ocx = 120, ocy = 74, orr = 50;
const orad = (d: number) => (d * Math.PI) / 180;
const opt = (d: number) => [ocx + orr * Math.cos(orad(d)), ocy + orr * Math.sin(orad(d))];
const oarc = (a: number, b: number) => {
  const [x1, y1] = opt(a);
  const [x2, y2] = opt(b);
  return `M ${x1.toFixed(1)} ${y1.toFixed(1)} A ${orr} ${orr} 0 0 1 ${x2.toFixed(1)} ${y2.toFixed(1)}`;
};
---

<!-- Skip to Content Link for Accessibility -->
<a href="#main-content" class="skip-to-content">
  {lang === 'en' ? 'Skip to main content' : 'Zum Hauptinhalt springen'}
</a>

<nav class="navbar" id="navbar">
  <div class="nav-container">
    <a href={currentRoutes.home} class="logo">
      <img src="/images/favicon-tab.png" alt="eFlury Consulting" class="logo-icon" width="32" height="32" />
      <span class="logo-text">eFlury <span class="logo-sub">Consulting</span></span>
    </a>

    <div class="nav-content">
      <ul class="nav-links" id="navLinks">
        <li><a href={`/${lang}/#home`}>{t('nav.home')}</a></li>

        <!-- Leistungen: mega panel -->
        <li class="nav-mega" data-mega>
          <button class="nav-mega-trigger" aria-expanded="false" aria-haspopup="true">
            {t('nav.services')}
            <ChevronDown size={14} class="dropdown-chevron" />
          </button>
          <div class="mega-panel">
            <div class="mega-inner">
              <div class="mega-cols">
                {servicesMenu.stages.map((stage) => (
                  <div class="mega-stage">
                    <div class="mega-stage-head">
                      <span class:list={['mega-pill', stage.cls]}>{stage.pill}</span>
                      <span class="mega-stage-line">{stage.line}</span>
                    </div>
                    <div class="mega-items">
                      {stage.items.map((item) => (
                        <a href={item.href} class="mega-item">
                          <span class="mega-tile"><item.icon size={19} /></span>
                          <span class="mega-item-body">
                            <span class="mega-item-title">{item.title}{item.badge && <span class="mega-new">{item.badge}</span>}</span>
                            <span class="mega-item-sub">{item.sub}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <div class="mega-rail">
                <div class="mega-rail-art">
                  <svg viewBox="0 0 240 148" fill="none" aria-hidden="true">
                    <circle cx={ocx} cy={ocy} r={orr} stroke="var(--border-color)" stroke-width="1.5" stroke-dasharray="2 7" fill="none" />
                    <path d={oarc(-80, 20)} stroke="var(--surface-navy)" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.9" />
                    <path d={oarc(40, 140)} stroke="var(--eflury-teal)" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.9" />
                    <path d={oarc(160, 260)} stroke="var(--eflury-blue)" stroke-width="5" fill="none" stroke-linecap="round" opacity="0.9" />
                    <rect x={ocx - 21} y={ocy - 21} width="42" height="42" rx="10" fill="#fff" stroke="var(--eflury-teal)" stroke-width="2" />
                    <image href="/images/favicon-tab.png" x={ocx - 17} y={ocy - 17} width="34" height="34" />
                    <text x={ocx} y="142" text-anchor="middle" font-size="9.5" font-weight="800" letter-spacing="0.08em" fill="var(--text-secondary)" font-family="inherit">ADVISE · BUILD · RUN</text>
                  </svg>
                </div>
                <div class="mega-rail-title">{servicesMenu.rail.title}</div>
                <div class="mega-rail-sub">{servicesMenu.rail.sub}</div>
                <div class="mega-rail-links">
                  {servicesMenu.rail.links.map((l) => (
                    <a href={l.href} class="mega-rail-link">{l.label} → {l.small && <small>{l.small}</small>}</a>
                  ))}
                </div>
              </div>
            </div>
            <div class="mega-bottom">
              <a href={servicesMenu.bottomLink.href} class="mega-bottom-link">{servicesMenu.bottomLink.label} →</a>
              <span class="mega-bottom-note">{servicesMenu.bottomNote}</span>
            </div>
          </div>
        </li>

        <!-- Einsatzbereiche: mega panel -->
        <li class="nav-mega" data-mega>
          <button class="nav-mega-trigger" aria-expanded="false" aria-haspopup="true">
            {t('nav.industries')}
            <ChevronDown size={14} class="dropdown-chevron" />
          </button>
          <div class="mega-panel mega-panel-mid">
            <div class="mega-inner mega-inner-mid">
              <div class="mega-cols">
                <div class="mega-items mega-items-1col">
                  {industriesMenu.items.map((item) => (
                    <a href={item.href} class="mega-item">
                      <span class="mega-tile"><item.icon size={19} /></span>
                      <span class="mega-item-body">
                        <span class="mega-item-title">{item.title}</span>
                        <span class="mega-item-sub">{item.sub}</span>
                      </span>
                    </a>
                  ))}
                </div>
              </div>
              <div class="mega-rail">
                <div class="mega-rail-title">{industriesMenu.rail.title}</div>
                <div class="mega-rail-links">
                  {industriesMenu.rail.links.map((l) => (
                    <a href={l.href} class="mega-rail-link">{l.label} <small>{l.small}</small></a>
                  ))}
                </div>
                <div class="mega-rail-sub">{industriesMenu.rail.sub}</div>
              </div>
            </div>
            <div class="mega-bottom">
              <a href={industriesMenu.bottomLink.href} class="mega-bottom-link">{industriesMenu.bottomLink.label} →</a>
              <span class="mega-bottom-note">{industriesMenu.bottomNote}</span>
            </div>
          </div>
        </li>

        <!-- Unternehmen: compact dropdown -->
        <li class="nav-mega nav-mega-small" data-mega>
          <button class="nav-mega-trigger" aria-expanded="false" aria-haspopup="true">
            {de ? 'Unternehmen' : 'Company'}
            <ChevronDown size={14} class="dropdown-chevron" />
          </button>
          <div class="mega-panel mega-panel-small">
            <div class="mega-items mega-items-1col mega-items-compact">
              {companyMenu.map((item) => (
                <a href={item.href} class="mega-item">
                  <span class="mega-tile"><item.icon size={17} /></span>
                  <span class="mega-item-body">
                    <span class="mega-item-title">{item.title}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        </li>

        <li><a href={`/${lang}/blog`}>{t('nav.blog')}</a></li>
        <li class="mobile-contact"><a href={de ? '/de/kontakt/' : '/en/contact/'}>{t('nav.contact')}</a></li>

        <!-- Mobile-only: Dark Mode Toggle -->
        <li class="mobile-dark-toggle">
          <span>{lang === 'en' ? 'Dark Mode' : 'Dunkelmodus'}</span>
          <button class="mobile-dark-toggle-btn" id="mobileDarkToggle" aria-label="Toggle dark mode"></button>
        </li>

        <!-- Mobile-only: Language Section -->
        <li class="mobile-menu-section">{t('nav.language')}</li>
        <li class="mobile-language-options">
          <a href={getLanguageSwitchUrl('en')}>
            <img src="/images/icons/en.png" alt="English" class="flag-icon" />
            <span class="lang-label">English</span>
            {lang === 'en' && <span class="lang-check">✓</span>}
          </a>
          <a href={getLanguageSwitchUrl('de')}>
            <img src="/images/icons/de.png" alt="Deutsch" class="flag-icon" />
            <span class="lang-label">Deutsch</span>
            {lang === 'de' && <span class="lang-check">✓</span>}
          </a>
        </li>
      </ul>

      <div class="nav-actions">
        <a href={de ? '/de/kontakt/' : '/en/contact/'} class="nav-cta">{de ? 'Strategiegespräch' : 'Strategy call'}</a>

        <DarkModeToggle />

        <!-- Share Button (Modern Web API) -->
        <button
          class="share-button-nav"
          onclick="window.sharePage?.()"
          aria-label="Share this page"
          title="Share"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="18" cy="5" r="3"></circle>
            <circle cx="6" cy="12" r="3"></circle>
            <circle cx="18" cy="19" r="3"></circle>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
          </svg>
        </button>

        <!-- Language Selector -->
        <div class="language-selector">
          <button class="language-current" id="langToggle" aria-label="Language Selector">
            <img src={`/images/icons/${lang}.png`} alt={lang === 'en' ? 'English' : 'Deutsch'} class="flag-icon" />
            <span>{lang.toUpperCase()}</span>
            <ChevronDown size={16} class="chevron-icon" />
          </button>
          <div class="language-dropdown" id="langDropdown">
            <a href={getLanguageSwitchUrl('en')} class="language-option">
              <img src="/images/icons/en.png" alt="English" class="flag-icon" />
              <span>English</span>
            </a>
            <a href={getLanguageSwitchUrl('de')} class="language-option">
              <img src="/images/icons/de.png" alt="Deutsch" class="flag-icon" />
              <span>Deutsch</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Toggle -->
      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</nav>

<style>
  /* Skip to Content Link for Accessibility */
  .skip-to-content {
    position: absolute;
    top: -100px;
    left: 0;
    background: var(--action-teal);
    color: white;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
    font-weight: 600;
    z-index: 10000;
    border-radius: 0 0 8px 0;
    transition: top 0.3s ease;
  }

  .skip-to-content:focus {
    top: 0;
    outline: 3px solid var(--primary-red);
    outline-offset: 2px;
  }

  /* Apple Navbar Styles - iOS Native */
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background: var(--nav-bg);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 0.5px solid var(--separator);
    z-index: 1001;
    padding: var(--spacing-md) 0;
    transition: all var(--transition-base);
    box-shadow: 0 1px 0 var(--separator), 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .navbar.scrolled {
    background: var(--nav-bg);
    backdrop-filter: var(--blur-medium);
    box-shadow: var(--shadow-sm);
    border-bottom-color: var(--border-color);
  }

  [data-theme="dark"] .navbar {
    background: var(--nav-bg);
    border-bottom-color: var(--border-color);
  }

  .nav-container {
    max-width: 1260px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: opacity var(--transition-base);
  }

  .logo-sub {
    color: var(--teal-text);
  }

  /* App-icon treatment: same white plate in both themes */
  .logo-icon {
    border-radius: 7px;
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .logo:hover {
    opacity: 0.8;
  }

  .logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text-primary);
    white-space: nowrap;
  }

  .nav-content {
    display: flex;
    align-items: center;
    gap: 1.15rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 1.35rem;
    margin: 0;
    padding: 0;
  }

  .nav-links > li {
    display: flex;
    align-items: center;
  }

  .nav-links a {
    display: flex;
    align-items: center;
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 400;
    font-size: 16px;
    letter-spacing: -0.011em;
    line-height: 1;
    transition: color var(--transition-base);
    position: relative;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .nav-links a:active {
    color: var(--primary);
  }

  /* ---- mega menu ------------------------------------------------------- */
  .nav-mega {
    position: static;
  }

  .nav-mega-small {
    position: relative;
  }

  .nav-mega-trigger {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    color: var(--text-secondary);
    font-family: inherit;
    font-weight: 400;
    font-size: 16px;
    line-height: 1;
    letter-spacing: -0.011em;
    cursor: pointer;
    padding: 0;
    margin: 0;
    transition: color var(--transition-base);
  }

  .nav-mega-trigger:hover,
  .nav-mega.open .nav-mega-trigger {
    color: var(--text-primary);
  }

  .dropdown-chevron {
    transition: transform var(--transition-fast);
  }

  .nav-mega.open .dropdown-chevron {
    transform: rotate(180deg);
  }

  .mega-panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    width: min(1060px, calc(100vw - 32px));
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 18px;
    box-shadow: 0 30px 70px rgba(15, 42, 70, 0.18);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 200;
    overflow: hidden;
  }

  .nav-mega.open .mega-panel {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .mega-panel {
      transition: none;
    }
  }

  .mega-panel-mid {
    width: min(880px, calc(100vw - 32px));
  }

  .mega-panel-small {
    width: 280px;
    top: calc(100% + 12px);
    padding: 0.5rem;
  }

  .mega-inner {
    display: grid;
    grid-template-columns: 1fr 290px;
  }

  .mega-inner-mid {
    grid-template-columns: 1fr 265px;
  }

  .mega-cols {
    padding: 1.5rem 1.75rem 1.25rem;
  }

  .mega-stage + .mega-stage {
    margin-top: 1.05rem;
  }

  .mega-stage-head {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.55rem;
  }

  .mega-pill {
