---
// Deployment test: 2026-01-28
import { type Language, useTranslations } from '../i18n/utils';
import { ArrowRight, Sparkles, ChevronDown } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" id="home">
  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <Sparkles size={14} />
        <span>{t('hero.badge')}</span>
      </div>
      <h1 class="hero-title">{t('hero.title')}</h1>
      <p class="hero-subtitle">{t('hero.subtitle')}</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary" onclick="window.trackEvent?.('Conversion', 'cta_click', 'Hero - Contact')">
          {t('hero.cta_primary')}
          <ArrowRight size={18} />
        </a>
        <p class="risk-reducer">{t('hero.risk_reducer')}</p>
        <a href={lang === 'de' ? '/de/methode/' : '/en/method/'} class="secondary-cta" onclick="window.trackEvent?.('Engagement', 'cta_click', 'Hero - Method')">
          {t('hero.cta_secondary')}
          <ArrowRight size={16} />
        </a>
      </div>
      <div class="trust-badges">
        <span class="trust-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
          UiPath Certified
        </span>
        <span class="trust-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h10"/><path d="M7 12h10"/><path d="M7 17h10"/></svg>
          Fortune 500 Experience
        </span>
        <span class="trust-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/></svg>
          13+ Years Enterprise AI
        </span>
      </div>
      <div class="trust-bar">
        <span>{t('hero.trust_bar')}</span>
      </div>
    </div>
    <div class="hero-visual">
      <div class="visual-wrapper">
        <picture>
          <source srcset="/images/hero-ai.webp" type="image/webp" />
          <img
            src="/images/hero-ai.jpg"
            alt="AI Technology Visualization"
            class="hero-image"
            width="600"
            height="400"
            loading="eager"
          />
        </picture>
        <div class="visual-glow"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    background: var(--bg-primary);
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(0, 122, 255, 0.08), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(99, 102, 241, 0.05), transparent);
    pointer-events: none;
  }

  :global([data-theme="dark"]) .hero::before {
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(0, 122, 255, 0.15), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(99, 102, 241, 0.1), transparent);
  }

  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 560px;
    background: linear-gradient(135deg, rgba(255,255,255,0.85) 0%, rgba(255,255,255,0.4) 100%);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
  }

  :global([data-theme="dark"]) .hero-content {
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.4) 100%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1.5px solid var(--eflury-teal);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--teal-text);
    margin-bottom: 1.5rem;
    animation: subtle-pulse 3s ease-in-out infinite;
    box-shadow: 0 2px 8px rgba(13, 148, 136, 0.15);
  }

  :global([data-theme="dark"]) .hero-badge {
    background: transparent;
    border-color: var(--teal-text);
    color: var(--teal-text);
    box-shadow: 0 2px 12px rgba(13, 148, 136, 0.25);
  }

  @keyframes subtle-pulse {
    0%, 100% {
      box-shadow: 0 2px 8px rgba(13, 148, 136, 0.15), 0 0 0 0 rgba(13, 148, 136, 0.4);
    }
    50% {
      box-shadow: 0 2px 8px rgba(13, 148, 136, 0.15), 0 0 0 8px rgba(13, 148, 136, 0);
    }
  }

  :global([data-theme="dark"]) .hero-badge {
    animation: subtle-pulse-dark 3s ease-in-out infinite;
  }

  @keyframes subtle-pulse-dark {
    0%, 100% {
      box-shadow: 0 2px 12px rgba(13, 148, 136, 0.25), 0 0 0 0 rgba(13, 148, 136, 0.5);
    }
    50% {
      box-shadow: 0 2px 12px rgba(13, 148, 136, 0.25), 0 0 0 8px rgba(13, 148, 136, 0);
    }
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 1.5vw, 1.25rem);
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    margin-bottom: 2.5rem;
  }

  .risk-reducer {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
    letter-spacing: 0.01em;
  }

  .secondary-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 1rem;
    color: var(--teal-text);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .secondary-cta:hover {
    color: var(--eflury-navy);
    transform: translateY(2px);
  }

  :global([data-theme="dark"]) .secondary-cta:hover {
    color: var(--text-primary);
  }

  .secondary-cta :global(svg) {
    transition: transform 0.2s ease;
  }

  .secondary-cta:hover :global(svg) {
    transform: translateY(2px);
  }

  .trust-bar {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 1rem;
    margin-top: 2rem;
    font-size: 0.8rem;
    color: var(--text-tertiary);
    opacity: 0.7;
    letter-spacing: 0.02em;
  }

  .trust-bar span {
    filter: grayscale(100%);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--surface-navy);
    color: white;
    box-shadow: 0 4px 14px rgba(2, 37, 84, 0.25);
  }

  .btn-primary:hover {
    background: var(--eflury-teal);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13, 148, 136, 0.35);
  }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .visual-wrapper {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(0, 0, 0, 0.05);
  }

  :global([data-theme="dark"]) .visual-wrapper {
    box-shadow:
      0 25px 50px -12px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.1);
  }

  .hero-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: 24px;
  }

  .visual-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(0, 122, 255, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: -1;
  }

  @media (max-width: 968px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }

    .hero-content {
      max-width: 100%;
      order: 1;
    }

    .hero-visual {
      order: 2;
    }

    .hero-cta {
      align-items: center;
    }

    .trust-bar {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 8rem 1.5rem 3rem;
    }

    .hero-content {
      background: rgba(255,255,255,0.95);
    }

    :global([data-theme="dark"]) .hero-content {
      background: rgba(0,0,0,0.85);
    }

    .hero-title {
      font-size: clamp(2rem, 8vw, 2.5rem);
    }

    .hero-subtitle {
      font-size: clamp(1rem, 4vw, 1.15rem);
      line-height: 1.8;
    }

    .hero-badge {
      font-size: 0.75rem;
      padding: 0.4rem 0.8rem;
      margin-bottom: 1rem;
    }

    .trust-bar {
      font-size: 0.7rem;
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
    }

    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .hero {
      padding: calc(100px + env(safe-area-inset-top)) 1.5rem 3rem;
      min-height: auto;
    }

    .hero-title {
      font-size: clamp(1.75rem, 7vw, 2.25rem);
      margin-bottom: 1rem;
    }

    .hero-subtitle {
      font-size: clamp(0.95rem, 3.5vw, 1.05rem);
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }

    .hero-badge {
      font-size: 0.7rem;
      padding: 0.35rem 0.7rem;
      margin-bottom: 0.75rem;
    }

    .hero-badge :global(svg) {
      width: 12px;
      height: 12px;
    }

    .hero-cta {
      width: 100%;
      align-items: stretch;
    }

    .btn {
      width: 100%;
      justify-content: center;
      min-height: 50px;
      padding: 0.85rem 1rem;
      font-size: 0.95rem;
    }

    .risk-reducer {
      font-size: 0.8rem;
      text-align: center;
    }

    .secondary-cta {
      display: inline-flex;
      justify-content: center;
      font-size: 0.85rem;
    }

    .trust-bar {
      font-size: 0.65rem;
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
      gap: 0.5rem;
    }

    .visual-wrapper {
      border-radius: 16px;
      display: none;
    }

    .hero-image {
      border-radius: 16px;
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: calc(80px + env(safe-area-inset-top)) 1rem 2.5rem;
    }

    .hero-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
      margin-bottom: 0.75rem;
      line-height: 1.2;
    }

    .hero-subtitle {
      font-size: clamp(0.9rem, 3vw, 1rem);
      line-height: 1.7;
      margin-bottom: 1.25rem;
    }

    .hero-badge {
      font-size: 0.65rem;
      padding: 0.3rem 0.6rem;
      margin-bottom: 0.6rem;
    }

    .hero-cta {
      gap: 0;
      margin-bottom: 1.5rem;
    }

    .btn {
      width: 100%;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      min-height: 48px;
    }

    .btn :global(svg) {
      width: 16px;
      height: 16px;
    }

    .risk-reducer {
      font-size: 0.75rem;
      margin-top: 0.5rem;
    }

    .secondary-cta {
      margin-top: 0.75rem;
      font-size: 0.8rem;
    }

    .secondary-cta :global(svg) {
      width: 14px;
      height: 14px;
    }

    .trust-bar {
      font-size: 0.7rem;
      margin-top: 1.5rem;
      gap: 0.5rem;
      opacity: 0.8;
      padding: 0.5rem 1rem;
      background: rgba(2, 37, 84, 0.05);
      border-radius: 8px;
    }
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-lg);
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 6px 12px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-color);
    letter-spacing: -0.01em;
  }

  .trust-badge svg {
    color: var(--teal-text);
    flex-shrink: 0;
  }

  @media (max-width: 600px) {
    .trust-badges {
      justify-content: center;
    }
    .trust-badge {
      font-size: 0.75rem;
      padding: 4px 10px;
    }
  }
</style>
