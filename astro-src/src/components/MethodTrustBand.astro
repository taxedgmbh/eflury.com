---
import { type Language } from '../i18n/utils';
import { Route, ShieldCheck, ArrowRight } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const de = lang === 'de';

const cards = [
  {
    icon: Route,
    title: de ? 'Die eflury Method™' : 'The eflury Method™',
    text: de
      ? 'Fünf Phasen, jede mit Zielen, benannten Deliverables, einem Entscheidungs-Gate und Ihrem Beitrag — vollständig publiziert.'
      : 'Five phases, each with goals, named deliverables, a decision gate, and your contribution — published in full.',
    linkLabel: de ? 'Methode lesen' : 'Read the method',
    href: de ? '/de/methode/' : '/en/method/',
  },
  {
    icon: ShieldCheck,
    title: de ? 'Sicherheit & Vertrauen' : 'Trust & Security',
    text: de
      ? 'Wie wir mit Ihren Daten arbeiten: Lesezugriff via MCP, menschliche Freigaben, jeder eingesetzte Dienst offengelegt — inklusive dem, was wir bewusst nicht behaupten.'
      : 'How we work with your data: read-only MCP access, human approvals, every service disclosed — including what we deliberately do not claim.',
    linkLabel: de ? 'Offenlegung lesen' : 'Read the disclosure',
    href: de ? '/de/sicherheit/' : '/en/trust/',
  },
];

const title = de ? 'So arbeiten wir' : 'How we work';
---

<section class="method-trust section-padding" id="method">
  <div class="container">
    <h2 class="section-title">{title}</h2>
    <div class="band-grid">
      {cards.map(({ icon: Icon, title: cardTitle, text, linkLabel, href }) => (
        <a href={href} class="band-card">
          <div class="band-icon"><Icon size={24} /></div>
          <div class="band-body">
            <h3>{cardTitle}</h3>
            <p>{text}</p>
            <span class="band-link">{linkLabel} <ArrowRight size={14} /></span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .method-trust {
    background: var(--bg-primary);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .section-title {
    text-align: center;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin-bottom: var(--spacing-2xl);
  }

  .band-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
  }

  .band-card {
    display: flex;
    gap: var(--spacing-lg);
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .band-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .band-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--eflury-teal);
  }

  .band-body h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .band-body p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 var(--spacing-md);
  }

  .band-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--primary-light);
    font-weight: 600;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .band-grid {
      grid-template-columns: 1fr;
    }

    .band-card {
      flex-direction: column;
      gap: var(--spacing-md);
    }
  }
</style>
