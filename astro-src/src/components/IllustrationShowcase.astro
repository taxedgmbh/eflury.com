---
/**
 * Card wrapper for decorative illustrations placed inside pages
 * (ServiceLayout "showcase" slot or custom page sections).
 */
---

<div class="ill-showcase">
  <div class="ill-frame">
    <slot />
  </div>
</div>

<style>
  .ill-showcase {
    max-width: 640px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }

  .ill-frame {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }
</style>
