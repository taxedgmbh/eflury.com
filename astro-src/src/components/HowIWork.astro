---
import { type Language, useTranslations } from '../i18n/utils';
import { ArrowRight } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { number: '1', title: t('process.steps.0.title'), description: t('process.steps.0.description') },
  { number: '2', title: t('process.steps.1.title'), description: t('process.steps.1.description') },
  { number: '3', title: t('process.steps.2.title'), description: t('process.steps.2.description') },
  { number: '4', title: t('process.steps.3.title'), description: t('process.steps.3.description') },
  { number: '5', title: t('process.steps.4.title'), description: t('process.steps.4.description') },
];
---

<section class="how-i-work section-padding" id="process">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('process.section_title')}</h2>
      <p class="section-subtitle">{t('process.section_subtitle')}</p>
    </div>

    <div class="timeline">
      {steps.map((step, index) => (
        <div class="timeline-item">
          <div class="timeline-marker">
            <div class="step-number">{step.number}</div>
            {index < steps.length - 1 && <div class="timeline-line"></div>}
          </div>
          <div class="timeline-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-description">{step.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="cta-container">
      <a href="#contact" class="btn btn-primary" onclick="window.trackEvent?.('Conversion', 'cta_click', 'Process - Contact')">
        {t('process.cta')}
        <ArrowRight size={18} />
      </a>
    </div>
  </div>
</section>

<style>
  .how-i-work {
    background: var(--bg-primary);
    padding: 6rem 2rem;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .timeline {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .timeline-item {
    display: flex;
    gap: 1.5rem;
    position: relative;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
  }

  .step-number {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--eflury-teal);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(13, 148, 136, 0.3);
    position: relative;
    z-index: 2;
  }

  .timeline-line {
    width: 2px;
    flex-grow: 1;
    background: linear-gradient(
      to bottom,
      var(--eflury-teal) 0%,
      var(--border-color) 100%
    );
    margin-top: 0.5rem;
    min-height: 40px;
  }

  .timeline-content {
    background: var(--bg-secondary);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-color);
    flex-grow: 1;
    transition: all 0.3s ease;
  }

  .timeline-content:hover {
    transform: translateX(8px);
    border-color: var(--eflury-teal);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="dark"]) .timeline-content:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--eflury-navy);
    margin-bottom: 0.5rem;
  }

  :global([data-theme="dark"]) .step-title {
    color: var(--text-primary);
  }

  .step-description {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  .cta-container {
    text-align: center;
    margin-top: 3rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--eflury-navy);
    color: white;
    box-shadow: 0 4px 14px rgba(2, 37, 84, 0.25);
  }

  .btn-primary:hover {
    background: var(--eflury-teal);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13, 148, 136, 0.35);
  }

  /* Mobile Responsive */
  @media (max-width: 600px) {
    .how-i-work {
      padding: 4rem 1.5rem;
    }

    .section-header {
      margin-bottom: 3rem;
    }

    .timeline-item {
      gap: 1rem;
    }

    .step-number {
      width: 40px;
      height: 40px;
      font-size: 1rem;
    }

    .timeline-content {
      padding: 1.25rem;
      margin-bottom: 1rem;
    }

    .timeline-content:hover {
      transform: none;
    }

    .step-title {
      font-size: 1rem;
    }

    .step-description {
      font-size: 0.9rem;
    }

    .timeline-line {
      min-height: 30px;
    }

    .cta-container {
      margin-top: 2rem;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
