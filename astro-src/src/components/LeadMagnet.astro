---
import { type Language, useTranslations } from '../i18n/utils';
import { Download, FileText, CheckCircle, ArrowRight, Mail, Loader2, Check } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const benefits = [
  'benefit1',
  'benefit2',
  'benefit3',
  'benefit4'
];

const downloadUrl = `/downloads/eflury-ai-implementation-guide-${lang}.pdf`;
---

<section class="lead-magnet" id="free-guide">
  <div class="container">
    <div class="magnet-content">
      <div class="magnet-info">
        <span class="magnet-badge">
          <FileText size={16} />
          {t('lead_magnet.badge')}
        </span>
        <h2 class="magnet-title">{t('lead_magnet.title')}</h2>
        <p class="magnet-subtitle">{t('lead_magnet.subtitle')}</p>

        <ul class="benefits-list">
          {benefits.map((key) => (
            <li class="benefit-item">
              <CheckCircle size={18} class="benefit-icon" />
              <span>{t(`lead_magnet.benefits.${key}`)}</span>
            </li>
          ))}
        </ul>

        <!-- Email Capture Form -->
        <form id="lead-magnet-form" class="lead-form" data-download-url={downloadUrl}>
          <div class="form-group">
            <div class="input-wrapper">
              <Mail size={18} class="input-icon" />
              <input
                type="email"
                id="lead-email"
                name="email"
                placeholder={t('lead_magnet.email_placeholder')}
                required
                autocomplete="email"
              />
          <input type="text" name="website" id="lead-hp" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" tabindex="-1" autocomplete="off" aria-hidden="true" />
            </div>
            <button type="submit" class="download-btn">
              <span class="btn-text">
                <Download size={18} />
                {t('lead_magnet.cta')}
                <ArrowRight size={16} class="arrow-icon" />
              </span>
              <span class="btn-loading" style="display: none;">
                <Loader2 size={18} class="spinner" />
                {lang === 'de' ? 'Wird gesendet...' : 'Sending...'}
              </span>
            </button>
          </div>
          <p class="form-error" style="display: none;"></p>
        </form>

        <!-- Success State (hidden by default) -->
        <div id="lead-success" class="success-state" style="display: none;">
          <div class="success-icon">
            <Check size={24} />
          </div>
          <p class="success-message">{t('lead_magnet.success_message')}</p>
          <a
            href={downloadUrl}
            class="download-btn download-now"
            download
            onclick="window.trackEvent?.('Conversion', 'lead_magnet_download', 'AI Implementation Guide')"
          >
            <Download size={18} />
            {t('lead_magnet.download_now')}
          </a>
        </div>

        <p class="privacy-note">{t('lead_magnet.privacy_note')}</p>
      </div>

      <div class="magnet-visual">
        <div class="guide-preview">
          <div class="preview-header">
            <div class="preview-dots">
              <span></span><span></span><span></span>
            </div>
          </div>
          <div class="preview-content">
            <FileText size={48} class="preview-icon" />
            <span class="preview-title">{t('lead_magnet.preview_title')}</span>
            <span class="preview-pages">PDF · 12 {lang === 'de' ? 'Seiten' : 'Pages'}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .lead-magnet {
    background: linear-gradient(135deg, var(--eflury-navy) 0%, #0a1628 100%);
    padding: 5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .lead-magnet::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(13, 148, 136, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(20, 144, 208, 0.1) 0%, transparent 40%);
    pointer-events: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .magnet-content {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
  }

  .magnet-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.2);
    border: 1px solid rgba(13, 148, 136, 0.3);
    border-radius: var(--radius-full);
    color: var(--eflury-teal);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .magnet-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: white;
    margin-bottom: 1rem;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .magnet-subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .benefits-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
  }

  .benefit-icon {
    color: var(--eflury-teal);
    flex-shrink: 0;
  }

  .download-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--eflury-teal);
    color: white;
    font-weight: 600;
    font-size: 1rem;
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .download-btn:hover {
    background: #0f766e;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(13, 148, 136, 0.3);
  }

  .arrow-icon {
    transition: transform 0.2s ease;
  }

  .download-btn:hover .arrow-icon {
    transform: translateX(4px);
  }

  /* Email Form Styles */
  .lead-form {
    width: 100%;
    max-width: 480px;
  }

  .form-group {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .input-wrapper {
    flex: 1;
    min-width: 200px;
    position: relative;
  }

  .input-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    pointer-events: none;
  }

  .lead-form input {
    width: 100%;
    padding: 1rem 1rem 1rem 2.75rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-lg);
    color: white;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .lead-form input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .lead-form input:focus {
    outline: none;
    border-color: var(--eflury-teal);
    background: rgba(255, 255, 255, 0.15);
  }

  .lead-form input:invalid:not(:placeholder-shown) {
    border-color: #f87171;
  }

  .form-error {
    color: #fca5a5;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }

  .btn-loading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Success State */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background: rgba(13, 148, 136, 0.15);
    border: 1px solid rgba(13, 148, 136, 0.3);
    border-radius: var(--radius-lg);
  }

  .success-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--eflury-teal);
    border-radius: 50%;
    color: white;
  }

  .success-message {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    margin: 0;
  }

  .download-now {
    margin-top: 0.5rem;
  }

  .privacy-note {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
  }

  .magnet-visual {
    display: flex;
    justify-content: center;
  }

  .guide-preview {
    background: white;
    border-radius: var(--radius-lg);
    width: 280px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    transform: rotate(3deg);
    transition: transform 0.3s ease;
  }

  .guide-preview:hover {
    transform: rotate(0deg) scale(1.02);
  }

  .preview-header {
    background: #f1f5f9;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #e2e8f0;
  }

  .preview-dots {
    display: flex;
    gap: 0.5rem;
  }

  .preview-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #cbd5e1;
  }

  .preview-dots span:first-child { background: #f87171; }
  .preview-dots span:nth-child(2) { background: #fbbf24; }
  .preview-dots span:last-child { background: #4ade80; }

  .preview-content {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .preview-icon {
    color: var(--eflury-teal);
  }

  .preview-title {
    font-weight: 600;
    color: var(--eflury-navy);
    font-size: 0.95rem;
  }

  .preview-pages {
    font-size: 0.8rem;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .magnet-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .magnet-visual {
      order: -1;
    }

    .guide-preview {
      width: 240px;
      transform: rotate(0deg);
    }

    .form-group {
      flex-direction: column;
    }

    .input-wrapper {
      min-width: 100%;
    }

    .download-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  import { submitHubSpotForm, HUBSPOT_FORMS } from '../scripts/hubspot-forms';

  const form = document.getElementById('lead-magnet-form') as HTMLFormElement;
  const successState = document.getElementById('lead-success');
  const errorMsg = form?.querySelector('.form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const emailInput = form.querySelector('#lead-email') as HTMLInputElement;
    const email = emailInput?.value?.trim();
    const hp = (form.querySelector('#lead-hp') as HTMLInputElement)?.value;
    if (hp) return; // honeypot: silently drop bot submissions
    const downloadUrl = form.dataset.downloadUrl;

    if (!email) {
      showError('Please enter your email address');
      return;
    }

    // Show loading state
    const btnText = form.querySelector('.btn-text') as HTMLElement;
    const btnLoading = form.querySelector('.btn-loading') as HTMLElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (btnText) btnText.style.display = 'none';
    if (btnLoading) btnLoading.style.display = 'flex';
    if (submitBtn) submitBtn.disabled = true;
    hideError();

    try {
      // Capture the lead in HubSpot (newsletter list)
      await submitHubSpotForm(
        HUBSPOT_FORMS.newsletter,
        { email },
        'AI Implementation Playbook download'
      );

      // Track conversion
      window.trackEvent?.('Conversion', 'lead_magnet_email_captured', email);

      // Show success state and hide form
      form.style.display = 'none';
      if (successState) {
        successState.style.display = 'flex';
      }

      // Auto-trigger download after short delay
      setTimeout(() => {
        if (downloadUrl) {
          const link = document.createElement('a');
          link.href = downloadUrl;
          link.download = '';
          link.click();
          window.trackEvent?.('Conversion', 'lead_magnet_download', 'AI Implementation Guide');
        }
      }, 500);

    } catch (error) {
      console.error('Lead magnet form error:', error);
      // Still allow download even if email fails (graceful degradation)
      // Show success state with download button - don't use window.open (blocked by popup blockers)
      form.style.display = 'none';
      if (successState) {
        successState.style.display = 'flex';
      }
      window.trackEvent?.('Conversion', 'lead_magnet_download_fallback', 'AI Implementation Guide');
    } finally {
      // Reset button state
      if (btnText) btnText.style.display = 'flex';
      if (btnLoading) btnLoading.style.display = 'none';
      if (submitBtn) submitBtn.disabled = false;
    }
  });

  function showError(message: string) {
    if (errorMsg) {
      errorMsg.textContent = message;
      errorMsg.style.display = 'block';
    }
  }

  function hideError() {
    if (errorMsg) {
      errorMsg.style.display = 'none';
    }
  }

  // Declare trackEvent on window
  declare global {
    interface Window {
      trackEvent?: (category: string, action: string, label?: string) => void;
    }
  }
</script>
