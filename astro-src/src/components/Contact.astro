---
import { type Language, useTranslations } from '../i18n/utils';
import { Mail, Phone, MapPin, Send } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="contact section-padding" id="contact">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('contact.title')}</h2>
      <p class="section-subtitle">{t('contact.subtitle')}</p>
    </div>

    <div class="contact-wrapper">
      <div class="contact-info">
        <h3>{t('contact.info_title')}</h3>
        <p>{t('contact.info_description')}</p>

        <div class="contact-methods">
          <div class="contact-method">
            <div class="method-icon">
              <Mail size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.email')}</h4>
              <a href="mailto:me@eflury.com">me@eflury.com</a>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <Phone size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.phone')}</h4>
              <a href="tel:+41799107787">+41 79 910 77 87</a>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <MapPin size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.location')}</h4>
              <p>Grenchen, Switzerland</p>
            </div>
          </div>
        </div>
      </div>

      <form class="contact-form" id="contactForm" novalidate>
        <div class="form-group">
          <label for="name">{t('contact.form.name')}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={t('contact.form.name_placeholder')}
            autocomplete="name"
            aria-required="true"
            aria-describedby="name-error"
            required
          />
          <span class="field-hint">{t('contact.form.name_hint')}</span>
          <div id="name-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <div class="form-group">
          <label for="email">{t('contact.form.email')}</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={t('contact.form.email_placeholder')}
            autocomplete="email"
            inputmode="email"
            aria-required="true"
            aria-describedby="email-error"
            required
          />
          <span class="field-hint">{t('contact.form.email_hint')}</span>
          <div id="email-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <div class="form-group">
          <label for="subject">{t('contact.form.subject')}</label>
          <input
            type="text"
            id="subject"
            name="subject"
            placeholder={t('contact.form.subject_placeholder')}
            autocomplete="off"
            aria-required="true"
            aria-describedby="subject-error"
            required
          />
          <span class="field-hint">{t('contact.form.subject_hint')}</span>
          <div id="subject-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <div class="form-group">
          <label for="message">{t('contact.form.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder={t('contact.form.message_placeholder')}
            aria-required="true"
            aria-describedby="message-error"
            required
          ></textarea>
          <span class="field-hint">{t('contact.form.message_hint')}</span>
          <div id="message-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <!-- Cloudflare Turnstile Anti-Bot Protection -->
        <div class="turnstile-wrapper">
          <div
            id="turnstile-widget"
            class="cf-turnstile"
            data-sitekey="0x4AAAAAACNCvv3pA4hrcbKM"
            data-theme="auto"
            data-language={lang}
            data-callback="onTurnstileSuccess"
            data-expired-callback="onTurnstileExpired"
          ></div>
          <div id="turnstile-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <button type="submit" class="btn btn-primary" id="submitBtn" disabled aria-label={t('contact.form.submit')}>
          <span class="btn-text">{t('contact.form.submit')}</span>
          <Send size={18} class="btn-icon" />
          <span class="btn-loader" aria-hidden="true"></span>
        </button>

        <div id="formStatus" class="form-status" role="status" aria-live="polite"></div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--bg-secondary);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-info h3 {
    font-size: 1.8rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .contact-info p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-method {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .method-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .method-content h4 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .method-content a {
    color: var(--primary-green);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .method-content a:hover {
    text-decoration: underline;
  }

  .method-content p {
    margin: 0;
    color: var(--text-secondary);
  }

  .contact-form {
    background: var(--card-bg);
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--border-color);
  }

  .form-group {
    margin-bottom: 1.5rem;
    position: relative;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 17px;
    letter-spacing: -0.011em;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 0.5px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 17px;
    line-height: 1.47059;
    letter-spacing: -0.011em;
    transition: all var(--transition-base);
    -webkit-appearance: none;
    appearance: none;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(0, 122, 255, 0.1);
    transform: translateY(-1px);
  }

  .form-group input.success,
  .form-group textarea.success {
    border-color: var(--accent-green);
    background: rgba(52, 199, 89, 0.05);
  }

  .form-group input.error,
  .form-group textarea.error {
    border-color: var(--accent-red);
    background: rgba(255, 59, 48, 0.05);
    animation: shake 0.4s ease-in-out;
  }

  .field-hint {
    display: block;
    margin-top: 6px;
    color: var(--text-tertiary);
    font-size: 13px;
    line-height: 1.38462;
    transition: opacity var(--transition-base);
  }

  .form-group input:focus ~ .field-hint,
  .form-group textarea:focus ~ .field-hint {
    color: var(--text-secondary);
  }

  .form-group input.error ~ .field-hint,
  .form-group textarea.error ~ .field-hint {
    display: none;
  }

  .field-error {
    display: block;
    margin-top: 6px;
    color: var(--accent-red);
    font-size: 13px;
    line-height: 1.38462;
    opacity: 0;
    transform: translateY(-5px);
    transition: all var(--transition-base);
  }

  .form-group input.error ~ .field-error,
  .form-group textarea.error ~ .field-error {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.011em;
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
    border: none;
    width: 100%;
    min-height: 44px;
    position: relative;
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-primary {
    background: var(--primary);
    color: var(--apple-white);
    box-shadow: var(--shadow-sm);
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-primary:active {
    transform: scale(0.98);
    opacity: 0.9;
  }

  .btn.loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .btn.loading .btn-text,
  .btn.loading .btn-icon {
    opacity: 0;
  }

  .btn.loading .btn-loader {
    opacity: 1;
  }

  .btn-loader {
    position: absolute;
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .form-status {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 8px;
    display: none;
    text-align: center;
    font-weight: 500;
  }

  .form-status.success {
    display: block;
    background: rgba(0, 199, 126, 0.1);
    color: var(--primary-green);
    border: 1px solid var(--primary-green);
  }

  .form-status.error {
    display: block;
    background: rgba(224, 60, 49, 0.1);
    color: var(--primary-red);
    border: 1px solid var(--primary-red);
  }

  /* Turnstile Anti-Bot Widget */
  .turnstile-wrapper {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .turnstile-wrapper .field-error {
    text-align: center;
  }

  .cf-turnstile {
    margin: 0 auto;
  }

  /* Disabled submit button state */
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .btn-primary:disabled:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 768px) {
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-form {
      padding: 1.5rem;
    }
  }
</style>

<!-- Cloudflare Turnstile Script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  import emailjs from '@emailjs/browser';

  // Initialize EmailJS with your public key
  emailjs.init('t1Qe1Zg5U3m8sqLGE');

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const formStatus = document.getElementById('formStatus') as HTMLDivElement;
  const submitButton = document.getElementById('submitBtn') as HTMLButtonElement;
  const turnstileError = document.getElementById('turnstile-error') as HTMLDivElement;
  const lang = document.documentElement.lang || 'en';

  // Turnstile token storage
  let turnstileToken: string | null = null;

  // Global callbacks for Turnstile
  (window as any).onTurnstileSuccess = (token: string) => {
    turnstileToken = token;
    if (submitButton) {
      submitButton.disabled = false;
    }
    if (turnstileError) {
      turnstileError.textContent = '';
      turnstileError.style.opacity = '0';
    }
  };

  (window as any).onTurnstileExpired = () => {
    turnstileToken = null;
    if (submitButton) {
      submitButton.disabled = true;
    }
    if (turnstileError) {
      turnstileError.textContent = lang === 'de'
        ? 'Verifizierung abgelaufen. Bitte erneut bestätigen.'
        : 'Verification expired. Please verify again.';
      turnstileError.style.opacity = '1';
    }
  };

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Check Turnstile verification
      if (!turnstileToken) {
        if (turnstileError) {
          turnstileError.textContent = lang === 'de'
            ? 'Bitte bestätigen Sie, dass Sie kein Roboter sind.'
            : 'Please verify that you are not a robot.';
          turnstileError.style.opacity = '1';
        }
        return;
      }

      const btnText = submitButton?.querySelector('.btn-text') as HTMLSpanElement;
      const originalText = btnText?.textContent || (lang === 'de' ? 'Nachricht senden' : 'Send Message');

      submitButton.disabled = true;
      submitButton.classList.add('loading');
      if (btnText) btnText.textContent = lang === 'de' ? 'Wird gesendet...' : 'Sending...';

      try {
        const result = await emailjs.sendForm(
          'service_7o5qkdh',  // Service ID
          'template_yw4ehjl', // Template ID
          form
        );

        console.log('EmailJS Success:', result);

        formStatus.className = 'form-status success';
        formStatus.textContent = lang === 'de'
          ? 'Nachricht erfolgreich gesendet! Ich melde mich bald bei Ihnen.'
          : 'Message sent successfully! I\'ll get back to you soon.';
        form.reset();

        // Reset Turnstile after successful submission
        if ((window as any).turnstile) {
          (window as any).turnstile.reset();
        }
        turnstileToken = null;

        // Track conversion
        if ((window as any).trackEvent) {
          (window as any).trackEvent('Conversion', 'contact_form_submit', 'Contact Form');
        }
      } catch (error: any) {
        console.error('EmailJS Error:', error);

        let errorMessage = lang === 'de'
          ? 'Nachricht konnte nicht gesendet werden. Bitte versuchen Sie es erneut oder schreiben Sie mir direkt an me@eflury.com'
          : 'Failed to send message. Please try again or email me directly at me@eflury.com';

        if (error?.text) {
          console.error('EmailJS Error Details:', error.text);
        }

        formStatus.className = 'form-status error';
        formStatus.textContent = errorMessage;
      } finally {
        submitButton.disabled = !turnstileToken;
        submitButton.classList.remove('loading');
        if (btnText) btnText.textContent = originalText;
      }
    });
  }
</script>
