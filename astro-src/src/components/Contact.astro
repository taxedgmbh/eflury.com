---
import { type Language, useTranslations } from '../i18n/utils';
import { Mail, Phone, MapPin, Send, MessageCircle, CheckCircle2 } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Environment variables for third-party services
const turnstileSitekey = import.meta.env.PUBLIC_TURNSTILE_SITEKEY || '0x4AAAAAACNCvv3pA4hrcbKM';
---

<section class="contact section-padding" id="contact">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('contact.title')}</h2>
      <p class="section-subtitle">{t('contact.subtitle')}</p>
    </div>

    <div class="contact-wrapper">
      <div class="contact-info">
        <h3>{t('contact.info_title')}</h3>
        <p>{t('contact.info_description')}</p>

        <div class="contact-methods">
          <div class="contact-method">
            <div class="method-icon">
              <Mail size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.email')}</h4>
              <a href="mailto:me@eflury.com">me@eflury.com</a>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <Phone size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.phone')}</h4>
              <a href="tel:+41799107787">+41 79 910 77 87</a>
            </div>
          </div>

          <div class="contact-method">
            <div class="method-icon">
              <MapPin size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.location')}</h4>
              <p>Grenchen, Switzerland</p>
            </div>
          </div>

          <div class="contact-method whatsapp-method">
            <div class="method-icon">
              <MessageCircle size={24} />
            </div>
            <div class="method-content">
              <h4>{t('contact.whatsapp') || 'WhatsApp'}</h4>
              <a href="https://wa.me/41799107787">{t('contact.whatsapp_number') || '+41 79 910 77 87'}</a>
            </div>
          </div>
        </div>
      </div>

      <form class="contact-form" id="contactForm" novalidate>
        <div class="form-header">
          <img src="/images/portraits/emanuel-aaron-flury-portrait.webp" alt="Emanuel Flury" class="form-avatar" />
          <div>
            <h3>{t('contact.form_title') || 'Book Your Strategy Call'}</h3>
            <p class="response-guarantee">{t('contact.response_guarantee') || 'Response within 24 hours'}</p>
          </div>
        </div>

        <ul class="contact-benefits">
          <li>{t('contact.benefits.ai_fit') || 'If AI automation fits your business'}</li>
          <li>{t('contact.benefits.process') || 'Which process to automate first'}</li>
          <li>{t('contact.benefits.timeline') || 'Realistic timeline and budget'}</li>
        </ul>

        <div class="form-group">
          <label for="name">{t('contact.form.name')}</label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder={t('contact.form.name_placeholder')}
            autocomplete="name"
            aria-required="true"
            aria-describedby="name-error"
            required
          />
          <span class="field-hint">{t('contact.form.name_hint')}</span>
          <div id="name-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <div class="form-group">
          <label for="email">{t('contact.form.email')}</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder={t('contact.form.email_placeholder')}
            autocomplete="email"
            inputmode="email"
            aria-required="true"
            aria-describedby="email-error"
            required
          />
          <span class="field-hint">{t('contact.form.email_hint')}</span>
          <div id="email-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <div class="form-group">
          <label for="message">{t('contact.form.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            placeholder={t('contact.form.message_placeholder')}
            aria-required="true"
            aria-describedby="message-error"
            required
          ></textarea>
          <span class="field-hint">{t('contact.form.message_hint')}</span>
          <div id="message-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <!-- Cloudflare Turnstile Anti-Bot Protection -->
        <div class="turnstile-wrapper">
          <div
            id="turnstile-widget"
            class="cf-turnstile"
            data-sitekey={turnstileSitekey}
            data-theme="auto"
            data-language={lang}
            data-callback="onTurnstileSuccess"
            data-expired-callback="onTurnstileExpired"
          ></div>
          <div id="turnstile-error" class="field-error" role="alert" aria-live="polite"></div>
        </div>

        <button type="submit" class="btn btn-primary" id="submitBtn" aria-label={t('contact.form.submit')}>
          <span class="btn-text">{t('contact.form.submit')}</span>
          <Send size={18} class="btn-icon" />
          <span class="btn-loader" aria-hidden="true"></span>
        </button>

        <div id="formStatus" class="form-status" role="status" aria-live="polite"></div>
      </form>

      <div class="contact-form success-panel" id="formSuccess" hidden>
        <div class="success-icon"><CheckCircle2 size={42} /></div>
        <h3>{lang === 'de' ? 'Nachricht erhalten!' : 'Message received!'}</h3>
        <p class="success-text">
          {lang === 'de'
            ? 'Vielen Dank. Sie erhalten innerhalb von 24 Stunden eine Antwort — direkt von Emanuel Flury.'
            : 'Thank you. You will get a reply within 24 hours — directly from Emanuel Flury.'}
        </p>
        <p class="success-hint">
          {lang === 'de'
            ? 'Dringend? Rufen Sie an: +41 79 910 77 87'
            : 'Urgent? Call +41 79 910 77 87'}
        </p>
        <div class="success-newsletter" id="successNewsletter">
          <p>
            {lang === 'de'
              ? 'Bis dahin: ein praxisnaher KI-Impuls pro Monat?'
              : 'In the meantime: one practical AI insight per month?'}
          </p>
          <button type="button" class="subscribe-after" id="subscribeAfter">
            {lang === 'de' ? 'Newsletter abonnieren' : 'Subscribe to the newsletter'}
          </button>
        </div>
        <button type="button" class="send-another" id="sendAnother">
          {lang === 'de' ? 'Weitere Nachricht senden' : 'Send another message'}
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: linear-gradient(
      135deg,
      var(--bg-secondary) 0%,
      rgba(13, 148, 136, 0.03) 50%,
      var(--bg-secondary) 100%
    );
    padding: 6rem 2rem;
    position: relative;
  }

  .contact::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(
      ellipse at 70% 20%,
      rgba(13, 148, 136, 0.05) 0%,
      transparent 50%
    );
    pointer-events: none;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  .contact-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 3rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-info h3 {
    font-size: 1.8rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .contact-info p {
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-method {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .method-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: var(--action-teal);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .method-content {
    min-width: 0;
  }

  .method-content h4 {
    font-size: 1rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .method-content a {
    color: var(--teal-text);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .method-content a:hover {
    text-decoration: underline;
  }

  .method-content p {
    margin: 0;
    color: var(--text-secondary);
  }

  .contact-form {
    background: linear-gradient(
      145deg,
      var(--card-bg) 0%,
      rgba(13, 148, 136, 0.02) 100%
    );
    padding: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  /* Form header with avatar */
  .form-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .form-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 3px solid var(--eflury-teal);
    box-shadow: 0 4px 12px rgba(13, 148, 136, 0.2);
  }

  .form-header h3 {
    font-size: 1.25rem;
    color: var(--text-primary);
    margin: 0 0 0.25rem 0;
    font-weight: 700;
  }

  .response-guarantee {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    padding: 0.35rem 0.75rem;
    background: linear-gradient(135deg, rgba(13, 148, 136, 0.1), rgba(13, 148, 136, 0.05));
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    color: var(--teal-text);
    border: 1px solid rgba(13, 148, 136, 0.2);
  }

  .response-guarantee::before {
    content: '\2713';
    font-size: 11px;
    font-weight: 700;
  }

  .form-group {
    margin-bottom: 1.5rem;
    position: relative;
  }

  .form-group label {
    display: block;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    font-size: 17px;
    letter-spacing: -0.011em;
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 0.5px solid var(--border-color);
    border-radius: var(--radius-md);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 17px;
    line-height: 1.47059;
    letter-spacing: -0.011em;
    transition: all var(--transition-base);
    -webkit-appearance: none;
    appearance: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-secondary);
    opacity: 0.8;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--teal-text);
    box-shadow: 0 0 0 3px rgba(13, 148, 136, 0.15);
    transform: translateY(-1px);
  }

  .form-group input.success,
  .form-group textarea.success {
    border-color: var(--accent-green);
    background: rgba(52, 199, 89, 0.05);
  }

  .form-group input.error,
  .form-group textarea.error {
    border-color: var(--accent-red);
    background: rgba(255, 59, 48, 0.05);
    animation: shake 0.4s ease-in-out;
  }

  .field-hint {
    display: block;
    margin-top: 6px;
    color: var(--text-tertiary);
    font-size: 13px;
    line-height: 1.38462;
    transition: opacity var(--transition-base);
  }

  .form-group input:focus ~ .field-hint,
  .form-group textarea:focus ~ .field-hint {
    color: var(--text-secondary);
  }

  .form-group input.error ~ .field-hint,
  .form-group textarea.error ~ .field-hint {
    display: none;
  }

  .field-error {
    display: block;
    margin-top: 6px;
    color: var(--accent-red);
    font-size: 13px;
    line-height: 1.38462;
    opacity: 0;
    transform: translateY(-5px);
    transition: all var(--transition-base);
  }

  .form-group input.error ~ .field-error,
  .form-group textarea.error ~ .field-error {
    opacity: 1;
    transform: translateY(0);
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
    20%, 40%, 60%, 80% { transform: translateX(5px); }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.011em;
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
    border: none;
    width: 100%;
    min-height: 44px;
    position: relative;
    overflow: hidden;
    -webkit-tap-highlight-color: transparent;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--eflury-navy) 0%, #1a365d 100%);
    color: white;
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.25);
    position: relative;
    overflow: hidden;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.1),
      transparent
    );
    transition: left 0.5s ease;
  }

  .btn-primary:hover {
    background: linear-gradient(135deg, var(--eflury-teal) 0%, #0d7377 100%);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(13, 148, 136, 0.35);
  }

  .btn-primary:hover::before {
    left: 100%;
  }

  .btn-primary:active {
    transform: scale(0.98) translateY(0);
    box-shadow: 0 2px 8px rgba(13, 148, 136, 0.25);
  }

  .btn.loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .btn.loading .btn-text,
  .btn.loading .btn-icon {
    opacity: 0;
  }

  .btn.loading .btn-loader {
    opacity: 1;
  }

  .btn-loader {
    position: absolute;
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .form-status {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 8px;
    display: none;
    text-align: center;
    font-weight: 500;
  }

  .form-status.success {
    display: block;
    background: rgba(0, 199, 126, 0.1);
    color: var(--primary-green);
    border: 1px solid var(--primary-green);
  }

  .form-status.error {
    display: block;
    background: rgba(224, 60, 49, 0.1);
    color: var(--primary-red);
    border: 1px solid var(--primary-red);
  }

  /* Turnstile Anti-Bot Widget */
  .turnstile-wrapper {
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .turnstile-wrapper .field-error {
    text-align: center;
  }

  .cf-turnstile {
    margin: 0 auto;
  }

  /* Disabled submit button state */
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .btn-primary:disabled:hover {
    transform: none;
    box-shadow: var(--shadow-sm);
  }

  /* WhatsApp method styling */
  .whatsapp-method .method-icon {
    background: #25D366;
  }

  .whatsapp-method .method-content a {
    color: #25D366;
  }

  .whatsapp-method .method-content a:hover {
    color: #128C7E;
  }

  /* Success panel (replaces the form after submission) */
  .contact-form[hidden],
  .success-panel[hidden] {
    display: none !important;
  }

  .success-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 0.75rem;
    min-height: 320px;
  }

  .success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: var(--radius-full);
    background: rgba(13, 148, 136, 0.12);
    color: var(--teal-text);
    margin-bottom: 0.5rem;
  }

  .success-panel h3 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .success-text {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 380px;
    margin: 0;
  }

  .success-hint {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .success-newsletter {
    margin-top: 0.5rem;
    padding: 1rem 1.25rem;
    background: rgba(13, 148, 136, 0.06);
    border: 1px solid rgba(13, 148, 136, 0.2);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .success-newsletter p {
    font-size: 0.9rem;
    color: var(--text-primary);
    margin: 0;
  }

  .subscribe-after {
    padding: 0.55rem 1.25rem;
    background: var(--action-teal);
    border: none;
    border-radius: var(--radius-md);
    color: var(--eflury-white);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast);
  }

  .subscribe-after:hover:not(:disabled) {
    background: var(--eflury-navy);
  }

  .subscribe-after:disabled {
    opacity: 0.7;
    cursor: default;
  }

  .send-another {
    margin-top: 0.75rem;
    padding: 0.55rem 1.1rem;
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .send-another:hover {
    border-color: var(--teal-text);
    color: var(--teal-text);
  }

  /* Contact benefits list */
  .contact-benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem 0;
    background: rgba(13, 148, 136, 0.08);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    border: 1px solid rgba(13, 148, 136, 0.15);
  }

  .contact-benefits li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-primary);
    font-size: 15px;
    line-height: 1.5;
    padding: 0.4rem 0;
  }

  .contact-benefits li::before {
    content: '\2713';
    color: var(--teal-text);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    /* Section padding */
    .contact {
      padding: 4rem 1.5rem;
    }

    /* Stack layout vertically */
    .contact-wrapper {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    /* Contact info section */
    .contact-info {
      order: -1;
    }

    .contact-info h3 {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .contact-info p {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    /* Center contact methods on mobile */
    .contact-methods {
      gap: 1.25rem;
    }

    .contact-method {
      align-items: center;
      justify-content: center;
      text-align: center;
      flex-direction: column;
    }

    .method-icon {
      width: 44px;
      height: 44px;
    }

    .method-content h4 {
      font-size: 0.95rem;
    }

    .method-content a {
      font-size: 0.95rem;
    }

    /* Form styling for mobile */
    .contact-form {
      padding: 1.5rem;
      border-radius: 12px;
    }

    /* Form header adjustments */
    .form-header {
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      padding-bottom: 1.25rem;
      align-items: center;
      text-align: center;
    }

    .form-avatar {
      width: 44px;
      height: 44px;
      flex-shrink: 0;
    }

    .form-header h3 {
      font-size: 1.05rem;
      margin: 0;
    }

    .response-guarantee {
      font-size: 11px;
      padding: 0.25rem 0.5rem;
    }

    /* Contact benefits list */
    .contact-benefits {
      padding: 0.875rem 1rem;
      margin: 0 0 1.25rem 0;
      border-radius: 10px;
    }

    .contact-benefits li {
      font-size: 13px;
      line-height: 1.4;
      padding: 0.35rem 0;
    }

    /* Form groups */
    .form-group {
      margin-bottom: 1.25rem;
    }

    .form-group label {
      font-size: 15px;
      margin-bottom: 0.4rem;
    }

    .form-group input,
    .form-group textarea {
      padding: 12px 14px;
      font-size: 16px;
      min-height: 48px;
      border-radius: var(--radius-md);
    }

    .form-group textarea {
      min-height: 120px;
      resize: vertical;
    }

    /* Submit button */
    .btn {
      min-height: 48px;
      padding: 12px 20px;
      font-size: 15px;
      width: 100%;
    }

    .btn-icon {
      display: none;
    }

    /* Turnstile widget */
    .turnstile-wrapper {
      margin-bottom: 1.25rem;
    }

    /* Section header */
    .section-header {
      margin-bottom: 2rem;
    }

    .section-title {
      font-size: clamp(1.5rem, 3.5vw, 2rem);
      margin-bottom: 0.5rem;
    }

    .section-subtitle {
      font-size: 1rem;
    }
  }
</style>

<!-- Cloudflare Turnstile Script -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  import { submitHubSpotForm, HUBSPOT_FORMS } from '../scripts/hubspot-forms';

  const form = document.getElementById('contactForm') as HTMLFormElement;
  const formStatus = document.getElementById('formStatus') as HTMLDivElement;
  const submitButton = document.getElementById('submitBtn') as HTMLButtonElement;
  const turnstileError = document.getElementById('turnstile-error') as HTMLDivElement;
  const lang = document.documentElement.lang || 'en';

  // Turnstile token storage
  let turnstileToken: string | null = null;
  let lastSubmittedEmail = '';

  // Global callbacks for Turnstile
  (window as any).onTurnstileSuccess = (token: string) => {
    turnstileToken = token;
    if (turnstileError) {
      turnstileError.textContent = '';
      turnstileError.style.opacity = '0';
    }
  };

  (window as any).onTurnstileExpired = () => {
    turnstileToken = null;
    if (turnstileError) {
      turnstileError.textContent = lang === 'de'
        ? 'Verifizierung abgelaufen. Bitte erneut bestätigen.'
        : 'Verification expired. Please verify again.';
      turnstileError.style.opacity = '1';
    }
  };

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Turnstile gate: if the widget loaded but has no token yet, ask the
      // user to complete it. If the script never loaded at all (ad-blocker,
      // network), fail open — the token is client-side only and HubSpot
      // applies its own spam filtering.
      if (!turnstileToken && (window as any).turnstile) {
        if (turnstileError) {
          turnstileError.textContent = lang === 'de'
            ? 'Bitte bestätigen Sie unten, dass Sie kein Roboter sind.'
            : 'Please complete the verification below.';
          turnstileError.style.opacity = '1';
        }
        return;
      }

      const btnText = submitButton?.querySelector('.btn-text') as HTMLSpanElement;
      const originalText = btnText?.textContent || (lang === 'de' ? 'Nachricht senden' : 'Send Message');

      submitButton.disabled = true;
      submitButton.classList.add('loading');
      if (btnText) btnText.textContent = lang === 'de' ? 'Wird gesendet...' : 'Sending...';

      try {
        const name = (form.querySelector('#name') as HTMLInputElement)?.value?.trim() || '';
        const email = (form.querySelector('#email') as HTMLInputElement)?.value?.trim() || '';
        const message = (form.querySelector('#message') as HTMLTextAreaElement)?.value?.trim() || '';
        lastSubmittedEmail = email;

        await submitHubSpotForm(
          HUBSPOT_FORMS.contact,
          { firstname: name, email, message },
          'Contact form'
        );

        form.reset();
        formStatus.className = 'form-status';
        formStatus.textContent = '';
        form.hidden = true;
        const successPanel = document.getElementById('formSuccess');
        if (successPanel) {
          successPanel.hidden = false;
          successPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Reset Turnstile after successful submission
        if ((window as any).turnstile) {
          (window as any).turnstile.reset();
        }
        turnstileToken = null;

        // Track conversion
        if ((window as any).trackEvent) {
          (window as any).trackEvent('Conversion', 'contact_form_submit', 'Contact Form');
        }
      } catch (error: any) {
        console.error('Contact form submission error:', error);

        formStatus.className = 'form-status error';
        formStatus.textContent = lang === 'de'
          ? 'Nachricht konnte nicht gesendet werden. Bitte versuchen Sie es erneut oder schreiben Sie uns direkt an me@eflury.com'
          : 'Failed to send message. Please try again or email us directly at me@eflury.com';
      } finally {
        submitButton.disabled = false;
        submitButton.classList.remove('loading');
        if (btnText) btnText.textContent = originalText;
      }
    });

    const subscribeAfter = document.getElementById('subscribeAfter') as HTMLButtonElement | null;
    subscribeAfter?.addEventListener('click', async () => {
      if (!lastSubmittedEmail) return;
      subscribeAfter.disabled = true;
      const original = subscribeAfter.textContent || '';
      subscribeAfter.textContent = '...';
      try {
        await submitHubSpotForm(
          HUBSPOT_FORMS.newsletter,
          { email: lastSubmittedEmail },
          'Newsletter opt-in after contact'
        );
        subscribeAfter.textContent = lang === 'de' ? 'Bestätigungs-E-Mail gesendet ✓' : 'Confirmation email sent ✓';
        if ((window as any).trackEvent) {
          (window as any).trackEvent('Conversion', 'newsletter_subscribe', 'After contact');
        }
      } catch (error) {
        console.error('Newsletter opt-in error:', error);
        subscribeAfter.disabled = false;
        subscribeAfter.textContent = original;
      }
    });

    const sendAnother = document.getElementById('sendAnother');
    sendAnother?.addEventListener('click', () => {
      const successPanel = document.getElementById('formSuccess');
      if (successPanel) successPanel.hidden = true;
      form.hidden = false;
      turnstileToken = null;
      if ((window as any).turnstile) {
        (window as any).turnstile.reset();
      }
      (form.querySelector('#name') as HTMLInputElement)?.focus();
    });
  }
</script>
