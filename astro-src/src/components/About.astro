---
import { type Language, useTranslations } from '../i18n/utils';
import { MapPin, Building2, CheckCircle2, Award, Shield } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="about" id="about">
  <div class="about-container">
    <div class="about-image">
      <div class="image-wrapper">
        <img src="/images/portraits/emanuel-aaron-flury-portrait.png"
             alt="Emanuel Flury - AI Consultant"
             class="profile-photo"
             width="400"
             height="500"
             loading="lazy" />
      </div>
    </div>

    <div class="about-content">
      <h2 class="about-title">{t('about.title')}</h2>

      <div class="credentials">
        <span class="credential-pill">
          <Award size={16} />
          {t('about.credential1')}
        </span>
        <span class="credential-pill">
          <Building2 size={16} />
          {t('about.credential2')}
        </span>
        <span class="credential-pill">
          <Shield size={16} />
          {t('about.credential3')}
        </span>
      </div>

      <p class="about-bio">{t('about.bio1')}</p>
      <p class="about-bio">{t('about.bio2')}</p>
      <p class="about-bio">{t('about.bio3')}</p>

      <div class="achievement-stat">
        <span class="stat-number">200+</span>
        <span class="stat-label">{t('about.achievement')}</span>
      </div>

      <div class="about-highlights">
        <div class="highlight">
          <CheckCircle2 size={18} />
          <span>{t('about.highlight1')}</span>
        </div>
        <div class="highlight">
          <CheckCircle2 size={18} />
          <span>{t('about.highlight2')}</span>
        </div>
        <div class="highlight">
          <CheckCircle2 size={18} />
          <span>{t('about.highlight3')}</span>
        </div>
        <div class="highlight">
          <CheckCircle2 size={18} />
          <span>{t('about.highlight4')}</span>
        </div>
      </div>

      <div class="about-badges">
        <div class="badge badge-outline">
          <MapPin size={16} />
          <span>{t('about.badge1')}</span>
        </div>
        <div class="badge badge-filled">
          <Building2 size={16} />
          <span>{t('about.badge2')}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: var(--eflury-bg-light);
    padding: 6rem 2rem;
  }

  .about-container {
    max-width: 1000px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-image {
    position: relative;
  }

  .image-wrapper {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    border: 3px solid var(--eflury-navy);
    outline: 3px solid var(--eflury-teal);
    outline-offset: 3px;
  }

  :global([data-theme="dark"]) .about {
    background: var(--bg-secondary);
  }

  :global([data-theme="dark"]) .image-wrapper {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    border-color: var(--eflury-blue);
    outline-color: var(--eflury-teal);
  }

  .image-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.1) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .profile-photo {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top center;
    aspect-ratio: 4/5;
  }

  .about-content {
    padding: 1rem 0;
  }

  .about-title {
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  /* Credential Pills */
  .credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .credential-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(2, 37, 84, 0.05);
    border: 1px solid rgba(2, 37, 84, 0.15);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--eflury-navy);
    transition: all 0.2s ease;
  }

  .credential-pill:hover {
    background: rgba(2, 37, 84, 0.1);
    transform: translateY(-2px);
  }

  .credential-pill svg {
    color: var(--eflury-teal);
    flex-shrink: 0;
  }

  :global([data-theme="dark"]) .credential-pill {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.15);
    color: var(--text-primary);
  }

  :global([data-theme="dark"]) .credential-pill:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* Achievement Stat */
  .achievement-stat {
    text-align: center;
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(13, 148, 136, 0.1) 0%, rgba(2, 37, 84, 0.05) 100%);
    border-radius: 16px;
    margin: 1.5rem 0;
  }

  .stat-number {
    display: block;
    font-size: 3rem;
    font-weight: 700;
    color: var(--eflury-teal);
    line-height: 1.1;
  }

  .stat-label {
    display: block;
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  :global([data-theme="dark"]) .achievement-stat {
    background: linear-gradient(135deg, rgba(13, 148, 136, 0.15) 0%, rgba(96, 165, 250, 0.1) 100%);
  }

  .about-bio {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
    font-size: 1.05rem;
  }

  .about-highlights {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .highlight {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .highlight svg {
    color: var(--primary);
    flex-shrink: 0;
  }

  .about-badges {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 500;
  }

  /* Swiss-based badge - Teal outline style */
  .badge-outline {
    background: transparent;
    border: 2px solid var(--eflury-teal);
    color: var(--eflury-teal);
  }

  .badge-outline svg {
    color: var(--eflury-teal);
  }

  /* Fortune 100 badge - Navy filled style */
  .badge-filled {
    background: var(--eflury-navy);
    border: 2px solid var(--eflury-navy);
    color: var(--eflury-white);
  }

  .badge-filled svg {
    color: var(--eflury-white);
  }

  :global([data-theme="dark"]) .badge-outline {
    border-color: var(--eflury-teal);
    color: var(--eflury-teal);
  }

  :global([data-theme="dark"]) .badge-outline svg {
    color: var(--eflury-teal);
  }

  :global([data-theme="dark"]) .badge-filled {
    background: var(--eflury-blue);
    border-color: var(--eflury-blue);
    color: #0f172a;
  }

  :global([data-theme="dark"]) .badge-filled svg {
    color: #0f172a;
  }

  @media (max-width: 768px) {
    .about {
      padding: 4rem 1.5rem;
    }

    .about-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .about-image {
      order: -1;
      max-width: 100%;
      margin: 0 auto;
    }

    .image-wrapper {
      max-width: 320px;
      margin: 0 auto;
    }

    .profile-photo {
      width: 100%;
      height: auto;
    }

    .about-title {
      font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    }

    .credentials {
      justify-content: center;
      gap: 0.5rem;
    }

    .credential-pill {
      font-size: 0.75rem;
      padding: 0.375rem 0.625rem;
      gap: 0.375rem;
    }

    .credential-pill svg {
      width: 14px;
      height: 14px;
    }

    .about-bio {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 0.875rem;
    }

    .achievement-stat {
      max-width: 280px;
      margin: 1.5rem auto;
      padding: 1.25rem;
    }

    .stat-number {
      font-size: 2.5rem;
    }

    .stat-label {
      font-size: 0.875rem;
    }

    .about-highlights {
      grid-template-columns: 2fr;
      text-align: left;
      gap: 0.625rem;
      margin: 1.5rem auto;
      max-width: 100%;
    }

    .highlight {
      font-size: 0.875rem;
      gap: 0.375rem;
    }

    .highlight svg {
      width: 16px;
      height: 16px;
    }

    .about-badges {
      justify-content: center;
      gap: 0.75rem;
    }

    .badge {
      padding: 0.5rem 0.875rem;
      font-size: 0.8125rem;
      gap: 0.375rem;
    }

    .badge svg {
      width: 14px;
      height: 14px;
    }
  }

  @media (max-width: 480px) {
    .about {
      padding: 3rem 1rem;
    }

    .about-title {
      font-size: 1.375rem;
      margin-bottom: 1rem;
    }

    .credentials {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .credential-pill {
      width: 100%;
      justify-content: center;
    }

    .about-bio {
      font-size: 0.875rem;
      margin-bottom: 0.75rem;
    }

    .achievement-stat {
      max-width: 100%;
      padding: 1rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .about-highlights {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    .highlight {
      font-size: 0.8125rem;
    }

    .about-badges {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .badge {
      width: auto;
      max-width: 280px;
      justify-content: center;
      padding: 0.625rem 1.25rem;
    }

    .achievement-stat {
      border-radius: 12px;
    }

    .credential-pill {
      width: auto;
      max-width: 280px;
    }
  }
</style>
