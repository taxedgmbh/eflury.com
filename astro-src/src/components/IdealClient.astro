---
import { type Language, useTranslations } from '../i18n/utils';
import { CheckCircle2, XCircle, Building2, Repeat, Brain, Rocket, Shield, HelpCircle, User, Wallet, ArrowRight } from 'lucide-astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// Icons for suitable items
const suitableIcons = [Building2, Repeat, Brain, Rocket, Shield];
// Icons for not suitable items
const notSuitableIcons = [HelpCircle, User, Wallet];

// Get the new structured data
const suitable = [
  { title: t('ideal_client.suitable.0.title'), description: t('ideal_client.suitable.0.description') },
  { title: t('ideal_client.suitable.1.title'), description: t('ideal_client.suitable.1.description') },
  { title: t('ideal_client.suitable.2.title'), description: t('ideal_client.suitable.2.description') },
  { title: t('ideal_client.suitable.3.title'), description: t('ideal_client.suitable.3.description') },
  { title: t('ideal_client.suitable.4.title'), description: t('ideal_client.suitable.4.description') }
].filter(item => !item.title.includes('ideal_client.'));

const notSuitable = [
  { title: t('ideal_client.not_suitable.0.title'), description: t('ideal_client.not_suitable.0.description') },
  { title: t('ideal_client.not_suitable.1.title'), description: t('ideal_client.not_suitable.1.description') },
  { title: t('ideal_client.not_suitable.2.title'), description: t('ideal_client.not_suitable.2.description') }
].filter(item => !item.title.includes('ideal_client.'));

const suitableTitle = t('ideal_client.suitable_title');
const notSuitableTitle = t('ideal_client.not_suitable_title');
const sectionSubtitle = t('ideal_client.section_subtitle');
const ctaText = t('ideal_client.cta_text');
const ctaButton = t('ideal_client.cta_button');
---

<section class="ideal-client" id="ideal-client">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{t('ideal_client.section_title')}</h2>
      <p class="section-subtitle">{sectionSubtitle}</p>
    </div>

    <div class="client-grid">
      <!-- Suitable Card -->
      <div class="suitable-card">
        <div class="card-header">
          <span class="card-badge suitable-badge">
            <CheckCircle2 size={16} />
            <span>{lang === 'en' ? 'Perfect Match' : 'Perfekte Übereinstimmung'}</span>
          </span>
          <h3 class="card-title suitable-title">{suitableTitle}</h3>
        </div>
        <ul class="client-list">
          {suitable.map((item, index) => {
            const IconComponent = suitableIcons[index];
            return (
              <li class="client-item suitable-item">
                <span class="icon-wrapper suitable-icon">
                  <IconComponent size={22} />
                </span>
                <div class="item-content">
                  <span class="item-title">{item.title}</span>
                  <span class="item-description">{item.description}</span>
                </div>
              </li>
            );
          })}
        </ul>
      </div>

      <!-- Not Suitable Card -->
      <div class="not-suitable-card">
        <div class="card-header">
          <span class="card-badge not-suitable-badge">
            <XCircle size={16} />
            <span>{lang === 'en' ? 'Honest Assessment' : 'Ehrliche Einschätzung'}</span>
          </span>
          <h3 class="card-title not-suitable-title">{notSuitableTitle}</h3>
        </div>
        <ul class="client-list">
          {notSuitable.map((item, index) => {
            const IconComponent = notSuitableIcons[index];
            return (
              <li class="client-item not-suitable-item">
                <span class="icon-wrapper not-suitable-icon">
                  <IconComponent size={22} />
                </span>
                <div class="item-content">
                  <span class="item-title">{item.title}</span>
                  <span class="item-description">{item.description}</span>
                </div>
              </li>
            );
          })}
        </ul>

        <!-- CTA inside not-suitable card -->
        <div class="card-cta">
          <p class="cta-text">{ctaText}</p>
          <a href="#contact" class="cta-button">
            {ctaButton}
            <ArrowRight size={16} />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ideal-client {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    padding: 6rem 2rem;
    position: relative;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .client-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    align-items: start;
  }

  .suitable-card,
  .not-suitable-card {
    background: var(--card-bg, var(--bg-primary));
    border-radius: 24px;
    padding: 2rem;
    border: 1px solid var(--border-color);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
    transition: all 0.3s ease;
  }

  .suitable-card:hover,
  .not-suitable-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }

  :global([data-theme="dark"]) .suitable-card,
  :global([data-theme="dark"]) .not-suitable-card {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  :global([data-theme="dark"]) .suitable-card:hover,
  :global([data-theme="dark"]) .not-suitable-card:hover {
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.3);
  }

  .suitable-card {
    border-top: 4px solid var(--eflury-teal);
    background: linear-gradient(180deg, rgba(13, 148, 136, 0.03) 0%, var(--card-bg, var(--bg-primary)) 100%);
  }

  .not-suitable-card {
    border-top: 4px solid #94a3b8;
    background: var(--card-bg, var(--bg-primary));
  }

  .card-header {
    margin-bottom: 1.75rem;
  }

  .card-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.375rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .suitable-badge {
    background: rgba(13, 148, 136, 0.12);
    color: var(--eflury-teal);
  }

  .not-suitable-badge {
    background: rgba(148, 163, 184, 0.15);
    color: #64748b;
  }

  :global([data-theme="dark"]) .not-suitable-badge {
    background: rgba(148, 163, 184, 0.1);
    color: #94a3b8;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    letter-spacing: -0.01em;
  }

  .suitable-title {
    color: var(--text-primary);
  }

  .not-suitable-title {
    color: var(--text-primary);
  }

  .client-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .client-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border-color);
    transition: all 0.2s ease;
  }

  .client-item:last-child {
    border-bottom: none;
  }

  .client-item:hover {
    padding-left: 0.5rem;
  }

  .icon-wrapper {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .suitable-icon {
    background: rgba(13, 148, 136, 0.1);
    color: var(--eflury-teal);
  }

  .not-suitable-icon {
    background: rgba(148, 163, 184, 0.1);
    color: #64748b;
  }

  :global([data-theme="dark"]) .not-suitable-icon {
    background: rgba(148, 163, 184, 0.08);
    color: #94a3b8;
  }

  .item-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .item-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .item-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* CTA in card */
  .card-cta {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-color);
    text-align: center;
  }

  .cta-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--eflury-teal);
    color: white;
    border-radius: 100px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-button:hover {
    background: var(--eflury-navy);
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .client-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .ideal-client {
      padding: 4rem 1.5rem;
    }

    .section-header {
      margin-bottom: 2.5rem;
    }

    .section-subtitle {
      font-size: 1rem;
    }

    .suitable-card,
    .not-suitable-card {
      padding: 1.5rem;
      border-radius: 20px;
    }

    .card-title {
      font-size: 1.25rem;
    }

    .icon-wrapper {
      width: 40px;
      height: 40px;
    }

    .client-item {
      gap: 0.875rem;
    }

    .client-item:hover {
      padding-left: 0;
    }
  }
</style>
