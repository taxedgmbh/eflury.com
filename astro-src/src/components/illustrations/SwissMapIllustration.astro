---

<svg viewBox="0 0 560 380" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true" class="ill-swissmap">
  <defs>
    <clipPath id="ch-border">
      <path d={borderPath} />
    </clipPath>
  </defs>

  <text x="30" y="30" font-size="11" font-weight="700" letter-spacing="0.12em" fill="var(--text-tertiary)" font-family="inherit">{t.title}</text>

  <!-- country silhouette -->
  <path d={borderPath} fill="var(--primary-50)" stroke="var(--eflury-navy)" stroke-width="1.8" stroke-linejoin="round" opacity="0.95" />

  <!-- lakes, clipped to the border -->
  <g clip-path="url(#ch-border)">
    {lakes.map((d) => (
      <path d={d} fill="var(--eflury-blue)" opacity="0.35" />
    ))}
  </g>

  <!-- dashed reach lines from Grenchen to every city -->
  <g stroke="var(--eflury-teal)" stroke-width="1.5" stroke-dasharray="2 6" stroke-linecap="round" opacity="0.65">
    {cities.map((c) => (
      <path d={`M ${home.x} ${home.y} L ${c.x} ${c.y}`} />
    ))}
  </g>

  <!-- city dots + labels -->
  <g>
    {cities.map((c) => (
      <g>
        <circle cx={c.x} cy={c.y} r="4.5" fill="var(--eflury-blue)" opacity="0.9" />
        <circle cx={c.x} cy={c.y} r="4.5" stroke="var(--card-bg)" stroke-width="1.2" fill="none" />
        <text x={c.lx} y={c.ly} text-anchor={c.anchor} font-size="11.5" font-weight="600" fill="var(--text-secondary)" font-family="inherit">{c.label}</text>
      </g>
    ))}
  </g>

  <!-- home base: brand callout in the empty north-west corner, leader to the pin -->
  <g>
    <path d={`M 122 90 Q 148 100 ${home.x - 6} ${home.y - 6}`} stroke="var(--eflury-teal)" stroke-width="1.8" fill="none" opacity="0.65" />
    <rect x="74" y="46" width="48" height="48" rx="11" fill="#fff" stroke="var(--eflury-teal)" stroke-width="2.5" />
    <image href="/images/favicon-tab.png" x="78" y="50" width="40" height="40" />
    <text x="98" y="110" text-anchor="middle" font-size="12.5" font-weight="800" fill="var(--eflury-navy)" font-family="inherit">{t.base}</text>
  </g>
  <g>
    <circle cx={home.x} cy={home.y} r="9" stroke="var(--eflury-teal)" stroke-width="2" fill="none" opacity="0.5" />
    <circle cx={home.x} cy={home.y} r="5" fill="var(--eflury-teal)" />
  </g>

  <!-- response stamp in the empty north-east corner -->
  <g transform="rotate(-7 472 56)">
    <rect x="417" y="36" width="110" height="40" rx="9" fill="var(--card-bg)" stroke="var(--teal-text)" stroke-width="2.5" />
    <text x="472" y="61" text-anchor="middle" font-size="14" font-weight="800" letter-spacing="0.03em" fill="var(--teal-text)" font-family="inherit">{t.stamp}</text>
  </g>

  <!-- legend + wordmark -->
  <text x="30" y="364" font-size="12" font-weight="600" fill="var(--text-secondary)" font-family="inherit">{t.legend}</text>
  <text x="530" y="364" text-anchor="end" font-size="13" font-weight="700" fill="var(--eflury-navy)" font-family="inherit">eFlury <tspan fill="var(--eflury-teal)">Consulting</tspan></text>
</svg>

<style>
  .ill-swissmap {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
