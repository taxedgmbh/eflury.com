---
/**
 * Decorative on-brand illustration: supplier invoice → agent draft →
 * human approval → ledger entry. Inline SVG on CSS variables.
 */
import IllustrationBrand from './IllustrationBrand.astro';
---

<svg viewBox="0 0 560 344" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true" class="ill-invoice">
  <!-- flow arrows -->
  <g stroke="var(--eflury-teal)" stroke-width="2" stroke-linecap="round" opacity="0.85">
    <path d="M172 140 L 218 140" />
    <path d="M212 134 L 220 140 L 212 146" fill="none" />
    <path d="M342 140 L 388 140" />
    <path d="M382 134 L 390 140 L 382 146" fill="none" />
  </g>

  <!-- incoming invoice (paper) -->
  <g>
    <rect x="52" y="64" width="116" height="152" rx="10" fill="var(--card-bg)" stroke="var(--border-color)" stroke-width="1.5" />
    <path d="M138 64 L 168 94 L 138 94 Z" fill="var(--primary-50)" stroke="var(--border-color)" />
    <rect x="68" y="104" width="64" height="9" rx="4.5" fill="var(--eflury-navy)" opacity="0.6" />
    <rect x="68" y="126" width="84" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.45" />
    <rect x="68" y="141" width="84" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.45" />
    <rect x="68" y="156" width="60" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.45" />
    <rect x="68" y="182" width="84" height="10" rx="5" fill="var(--eflury-teal)" opacity="0.6" />
    <text x="70" y="88" font-size="11" font-weight="700" fill="var(--text-secondary)" font-family="inherit">PDF</text>
  </g>

  <!-- the agent (brand mark) -->
  <g>
    <rect x="230" y="92" width="100" height="96" rx="18" fill="var(--primary-50)" stroke="var(--eflury-teal)" stroke-width="2" />
    <rect x="255" y="106" width="50" height="50" rx="11" fill="#fff" stroke="var(--border-color)" />
    <image href="/images/favicon-tab.png" x="258" y="109" width="44" height="44" />
    <rect x="250" y="166" width="60" height="8" rx="4" fill="var(--eflury-navy)" opacity="0.35" />
  </g>
  <!-- draft badge -->
  <g>
    <rect x="238" y="196" width="84" height="22" rx="11" fill="var(--card-bg)" stroke="var(--eflury-blue)" stroke-width="1.5" />
    <circle cx="252" cy="207" r="4" fill="var(--eflury-blue)" opacity="0.8" />
    <rect x="262" y="203" width="48" height="8" rx="4" fill="var(--text-tertiary)" opacity="0.5" />
  </g>

  <!-- ledger / accounting system -->
  <g>
    <rect x="392" y="64" width="120" height="152" rx="12" fill="var(--card-bg)" stroke="var(--border-color)" stroke-width="1.5" />
    <rect x="392" y="64" width="120" height="30" rx="12" fill="var(--surface-navy)" />
    <rect x="392" y="82" width="120" height="12" fill="var(--surface-navy)" />
    <rect x="404" y="74" width="54" height="9" rx="4.5" fill="#fff" opacity="0.85" />
    <g>
      <rect x="404" y="106" width="66" height="8" rx="4" fill="var(--text-tertiary)" opacity="0.5" />
      <rect x="478" y="106" width="24" height="8" rx="4" fill="var(--eflury-teal)" opacity="0.7" />
      <rect x="404" y="126" width="58" height="8" rx="4" fill="var(--text-tertiary)" opacity="0.5" />
      <rect x="478" y="126" width="24" height="8" rx="4" fill="var(--eflury-navy)" opacity="0.6" />
      <rect x="404" y="146" width="70" height="8" rx="4" fill="var(--text-tertiary)" opacity="0.5" />
      <rect x="478" y="146" width="24" height="8" rx="4" fill="var(--eflury-blue)" opacity="0.65" />
      <line x1="404" y1="168" x2="502" y2="168" stroke="var(--border-color)" stroke-width="1.5" />
      <rect x="404" y="180" width="44" height="10" rx="5" fill="var(--eflury-navy)" opacity="0.8" />
      <rect x="470" y="180" width="32" height="10" rx="5" fill="var(--eflury-teal)" opacity="0.85" />
    </g>
  </g>

  <!-- human approval gate under the agent -->
  <path d="M280 224 L 280 254" stroke="var(--eflury-navy)" stroke-width="2" stroke-linecap="round" opacity="0.7" />
  <g>
    <circle cx="280" cy="280" r="24" fill="var(--success-50)" stroke="var(--eflury-teal)" stroke-width="2" />
    <path d="M269 280 L 277 288 L 292 272" stroke="var(--teal-text)" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </g>

  <IllustrationBrand x={412} y={330} />
</svg>

<style>
  .ill-invoice {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
