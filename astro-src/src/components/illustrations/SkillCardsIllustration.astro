---
/**
 * Decorative on-brand illustration: a library of custom Claude Skills,
 * one running. Inline SVG on CSS variables.
 */
import IllustrationBrand from './IllustrationBrand.astro';
---

<svg viewBox="0 0 560 344" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-hidden="true" class="ill-skills">
  <!-- stacked skill cards -->
  <g>
    <rect x="60" y="180" width="220" height="76" rx="12" fill="var(--card-bg)" stroke="var(--border-color)" stroke-width="1.5" />
    <rect x="78" y="196" width="34" height="34" rx="9" fill="var(--primary-50)" stroke="var(--primary-100)" />
    <rect x="86" y="204" width="18" height="18" rx="4" fill="var(--eflury-blue)" opacity="0.7" />
    <rect x="126" y="200" width="92" height="9" rx="4.5" fill="var(--eflury-navy)" opacity="0.65" />
    <rect x="126" y="218" width="130" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.45" />
  </g>
  <g>
    <rect x="48" y="76" width="220" height="76" rx="12" fill="var(--card-bg)" stroke="var(--border-color)" stroke-width="1.5" />
    <rect x="66" y="92" width="34" height="34" rx="9" fill="var(--primary-50)" stroke="var(--primary-100)" />
    <circle cx="83" cy="109" r="9" fill="var(--eflury-navy)" opacity="0.6" />
    <rect x="114" y="96" width="80" height="9" rx="4.5" fill="var(--eflury-navy)" opacity="0.65" />
    <rect x="114" y="114" width="130" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.45" />
  </g>

  <!-- active skill card (highlighted, running) -->
  <g>
    <rect x="256" y="118" width="256" height="110" rx="14" fill="var(--primary-50)" stroke="var(--eflury-teal)" stroke-width="2" />
    <rect x="276" y="136" width="42" height="42" rx="10" fill="#fff" stroke="var(--border-color)" />
    <image href="/images/favicon-tab.png" x="279" y="139" width="36" height="36" />
    <rect x="330" y="140" width="110" height="10" rx="5" fill="var(--eflury-navy)" opacity="0.8" />
    <rect x="330" y="160" width="150" height="7" rx="3.5" fill="var(--text-tertiary)" opacity="0.5" />
    <!-- progress -->
    <rect x="276" y="196" width="216" height="10" rx="5" fill="var(--bg-secondary)" />
    <rect x="276" y="196" width="146" height="10" rx="5" fill="var(--eflury-teal)" opacity="0.85" />
    <!-- play chevron -->
    <circle cx="470" cy="157" r="15" fill="var(--eflury-teal)" opacity="0.14" />
    <path d="M465 149 L 478 157 L 465 165 Z" fill="var(--teal-text)" />
  </g>

  <!-- output line to approved doc -->
  <g stroke="var(--eflury-teal)" stroke-width="2" stroke-dasharray="1 7" stroke-linecap="round" opacity="0.8">
    <path d="M384 228 C 384 252, 384 258, 384 268" />
  </g>
  <g>
    <rect x="332" y="270" width="104" height="30" rx="9" fill="var(--card-bg)" stroke="var(--border-color)" stroke-width="1.5" />
    <rect x="346" y="281" width="52" height="8" rx="4" fill="var(--text-tertiary)" opacity="0.5" />
    <circle cx="418" cy="285" r="9" fill="var(--success-50)" stroke="var(--eflury-teal)" stroke-width="1.5" />
    <path d="M414 285 L 417 288 L 423 281" stroke="var(--teal-text)" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
  </g>

  <IllustrationBrand x={48} y={330} />
</svg>

<style>
  .ill-skills {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
