---
import MainLayout from '../../layouts/MainLayout.astro';
import SwissMapIllustration from '../../components/illustrations/SwissMapIllustration.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { MapPin, Check, ExternalLink, MessageCircle } from 'lucide-astro';

const lang = "en";

const steps = [
  {
    title: "You reach out",
    text: "Use the form below, email, phone, or WhatsApp — whichever suits you.",
  },
  {
    title: "Reply within 24 hours",
    text: "Directly from Emanuel Flury — the person who builds the systems, not a gatekeeper.",
  },
  {
    title: "Free 30-minute call",
    text: "We walk through your case. If automation does not fit, we say so — a clear no is a clean outcome too.",
  },
];

const reachItems = [
  "On-site: Solothurn · Biel · Bern · Basel · Zurich area",
  "Remote: all of Switzerland & EU",
  "Reply within 24 hours, most calls scheduled within 3 days",
];

const mapsUrl = "https://www.google.com/maps/search/?api=1&query=Keltenweg+4%2C+2540+Grenchen%2C+Schweiz";
---

<MainLayout
  title="Contact - eFlury Consulting"
  description="Contact eFlury Consulting in Grenchen: form, email, phone, or WhatsApp. Reply within 24 hours, then a free 30-minute call about your case — on-site or remote across Switzerland."
  keywords="contact eFlury Consulting, AI automation consulting, free strategy call, Grenchen Switzerland"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Contact" }]} />

  <main class="contact-page">
    <section class="contact-hero">
      <div class="container">
        <span class="hero-badge">Contact · Reply < 24 h · Free</span>
        <h1>Let's talk.</h1>
        <p class="lead">Whether you have a specific process in mind or are just exploring — you will hear back within 24 hours, from the person who builds the systems.</p>
      </div>
    </section>

    <section class="next-steps">
      <div class="container">
        <h2>What happens next</h2>
        <ol class="steps-grid">
          {steps.map((step, i) => (
            <li class="step-card">
              <span class="step-number">{i + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <Contact lang={lang} showHeader={false} />

    <section class="location">
      <div class="container">
        <h2 class="section-title">Location & reach</h2>
        <p class="section-sub">Based in the Swiss Mittelland, working across the country — on-site or remote.</p>
        <div class="location-grid">
          <div class="map-panel">
            <SwissMapIllustration lang={lang} />
          </div>
          <div class="addr-panel">
            <div class="addr-head">
              <span class="addr-icon"><MapPin size={20} /></span>
              <span class="addr-label">Address</span>
            </div>
            <address>
              <strong>eFlury Consulting</strong><br />
              Keltenweg 4<br />
              2540 Grenchen, Switzerland
            </address>
            <p class="addr-note">Meetings by arrangement — at your company, in Grenchen, or remote.</p>
            <ul class="reach-list">
              {reachItems.map((item) => (
                <li><Check size={15} /><span>{item}</span></li>
              ))}
            </ul>
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="directions-btn">
              Get directions (Google Maps)
              <ExternalLink size={15} />
            </a>
            <p class="effi-hint"><MessageCircle size={15} /> Quick question outside office hours? Effi, our chat in the bottom-right corner, answers instantly.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="vcard-section">
      <div class="container">
        <h2 class="section-title">Digital Business Card</h2>
        <p class="section-sub">Scan the QR code and the contact lands straight in your phone — or take the card with you as a file.</p>
        <div class="vcard-grid">
          <img src="/images/card/card-display.webp" alt="Business card of Emanuel Aaron Flury, eFlury Consulting" class="vcard-img" width="972" height="615" loading="lazy" />
          <div class="vcard-side">
            <div class="vcard-qr">
              <img src="/images/card/qr-vcard.svg" alt="QR code with contact details (vCard)" width="172" height="172" loading="lazy" />
            </div>
            <p class="vcard-hint">Scan → contact saved. Works with any camera app, no extra app needed.</p>
            <div class="vcard-actions">
              <a href="/downloads/emanuel-flury.vcf" download class="vcard-btn primary">Save contact (.vcf)</a>
              <a href="/downloads/emanuel-flury-card.png" download class="vcard-btn">Card as image (PNG)</a>
              <a href="/downloads/emanuel-flury-card.pdf" download class="vcard-btn">Card as PDF · 85.6 × 54 mm</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .contact-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .contact-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .contact-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .next-steps {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-primary);
  }

  .next-steps h2 {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xl);
  }

  .steps-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--action-teal);
    color: var(--eflury-white);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
  }

  .step-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .step-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Location & map */
  .location {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-primary);
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .section-sub {
    text-align: center;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto var(--spacing-xl);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: var(--spacing-lg);
    align-items: stretch;
  }

  .map-panel {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    align-items: center;
  }

  .addr-panel {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }

  .addr-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .addr-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
  }

  .addr-label {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  address {
    font-style: normal;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text-primary);
    margin-bottom: 0.9rem;
  }

  .addr-note {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
  }

  .reach-list {
    list-style: none;
    margin: 0 0 1.4rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-grow: 1;
  }

  .reach-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-primary);
  }

  .reach-list li :global(svg) {
    color: var(--teal-text);
    flex-shrink: 0;
    margin-top: 0.18rem;
  }

  .directions-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.8rem 1.4rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .directions-btn:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  .effi-hint {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-tertiary);
    margin: 1.1rem 0 0;
  }

  .effi-hint :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--teal-text);
  }

  @media (max-width: 900px) {
    .location-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Digital business card */
  .vcard-section {
    padding: 0 0 var(--spacing-3xl);
    background: var(--bg-primary);
  }

  .vcard-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2.5rem;
    align-items: center;
    max-width: 920px;
    margin: 0 auto;
  }

  .vcard-img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid var(--border-color);
    box-shadow: 0 18px 40px rgba(15, 42, 70, 0.22);
  }

  .vcard-side {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .vcard-qr {
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 0.9rem;
    box-shadow: var(--shadow-sm);
  }

  .vcard-qr img {
    display: block;
    width: 172px;
    height: 172px;
  }

  .vcard-hint {
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-align: center;
    margin: 0;
    max-width: 240px;
  }

  .vcard-actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    width: 100%;
    max-width: 280px;
  }

  .vcard-btn {
    display: block;
    text-align: center;
    padding: 0.7rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background: var(--card-bg);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .vcard-btn:hover {
    border-color: var(--eflury-teal);
    transform: translateY(-1px);
  }

  .vcard-btn.primary {
    background: var(--action-teal);
    border-color: var(--action-teal);
    color: #fff;
  }

  .vcard-btn.primary:hover {
    background: var(--primary-700);
  }

  @media (max-width: 820px) {
    .vcard-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .contact-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .contact-hero .lead {
      font-size: 1.05rem;
    }

    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .step-card {
      padding: var(--spacing-lg);
    }

    .map-panel {
      padding: 1rem;
    }
  }
</style>
