---
/**
 * Dynamic Blog Post Page (English)
 * Renders individual blog posts
 */

import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import { getTranslatedSlug } from '../../../i18n/blogTranslationMap';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.lang === 'en' && !data.draft;
  });

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get translated slug for language switcher
const translatedSlug = getTranslatedSlug(post.id);
const languageSwitchUrl = translatedSlug ? `/de/blog/${translatedSlug}` : '/de/blog';
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  tags={post.data.tags}
  slug={post.id}
  lang="en"
  languageSwitchUrl={languageSwitchUrl}
>
  <Content />
</BlogLayout>
