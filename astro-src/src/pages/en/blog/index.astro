---
/**
 * Blog / Insights hub (English)
 * Topic-filterable list of all posts; topics come from src/i18n/blog-topics.ts.
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { getCollection } from 'astro:content';
import { ArrowRight, Calendar, Clock } from 'lucide-astro';
import { topicFor, topicLabels, topicOrder, readingMinutes } from '../../../i18n/blog-topics';

const lang = 'en';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.lang === 'en' && !data.draft;
});

const posts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf() || a.id.localeCompare(b.id))
  .map((post) => ({
    ...post,
    topic: topicFor(post.data.translationKey),
    minutes: readingMinutes(post.body),
  }));

const topicCounts = new Map<string, number>();
for (const post of posts) {
  topicCounts.set(post.topic, (topicCounts.get(post.topic) ?? 0) + 1);
}
const topics = topicOrder.filter((key) => topicCounts.has(key));
---

<MainLayout
  title="Blog & Insights - AI Automation for Swiss SMEs | Emanuel Flury"
  description="Practical insights on AI automation, accounting & finance, Power BI, and security for Swiss SMEs — filterable by topic."
  keywords="AI automation blog, Claude AI insights, Power BI guides, Swiss business automation"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Blog' }]} />

  <main class="blog-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <h1>Insights</h1>
        <p class="subtitle">Practical analyses on AI automation, accounting &amp; finance, reporting, and security — written for Swiss SMEs.</p>

        <p class="guides-teaser">
          Prefer the condensed version? <a href="/en/guides/">Three downloadable playbooks →</a>
        </p>

        <div class="topic-filter" role="group" aria-label="Filter articles by topic">
          <button class="chip active" data-topic="all">All <span class="count">{posts.length}</span></button>
          {topics.map((key) => (
            <button class="chip" data-topic={key}>
              {topicLabels[key][lang]} <span class="count">{topicCounts.get(key)}</span>
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Posts Grid -->
    <section class="blog-grid">
      <div class="container">
        <div class="posts-grid">
          {posts.map((post) => (
            <a href={`/en/blog/${post.id}`} class="post-card" data-topic={post.topic}>
              {post.data.image && (
                <div class="post-image">
                  <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
                </div>
              )}
              <div class="post-content">
                <div class="post-meta">
                  <span class="topic-badge">{topicLabels[post.topic][lang]}</span>
                  <span class="date">
                    <Calendar size={14} />
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric'
                    })}
                  </span>
                  <span class="reading-time">
                    <Clock size={14} />
                    ~{post.minutes} min read
                  </span>
                </div>

                <h2>{post.data.title}</h2>
                <p class="description">{post.data.description}</p>

                <div class="read-more">
                  Read Article <ArrowRight size={16} />
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Want to apply this to your business?</h2>
        <p>Free 30-minute call — we walk through your specific case.</p>
        <a href="/en/contact/" class="btn-primary">
          Get in touch
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.topic-filter .chip');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');

  const applyTopic = (chip: HTMLButtonElement) => {
    chips.forEach((c) => c.classList.toggle('active', c === chip));
    const topic = chip.dataset.topic;
    cards.forEach((card) => {
      card.hidden = topic !== 'all' && card.dataset.topic !== topic;
    });
  };

  chips.forEach((chip) => {
    chip.addEventListener('click', () => applyTopic(chip));
  });

  // Deep links: /blog/#treuhand pre-selects that topic (used by industry pages)
  const fromHash = document.querySelector<HTMLButtonElement>(
    `.topic-filter .chip[data-topic="${CSS.escape(location.hash.slice(1))}"]`
  );
  if (fromHash) applyTopic(fromHash);
</script>

<style>
  .blog-page {
    padding-top: 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero {
    padding: 4rem 0 3rem;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
  }

  .hero h1 {
    font-size: clamp(3rem, 7vw, 5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .hero .subtitle {
    font-size: clamp(1.15rem, 2.5vw, 1.45rem);
    color: var(--text-secondary);
    font-weight: 400;
    line-height: 1.6;
    max-width: 700px;
    margin-bottom: 2rem;
  }

  .guides-teaser {
    font-size: 0.95rem;
    color: var(--text-secondary);
    margin: 0 0 1.25rem;
  }

  .guides-teaser a {
    display: inline-flex;
    align-items: center;
    color: var(--link-color);
    font-weight: 600;
    text-decoration: none;
  }

  .guides-teaser a:hover {
    text-decoration: underline;
  }

  /* Topic filter chips */
  .topic-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 1rem;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    background: var(--card-bg);
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .chip:hover {
    border-color: var(--teal-text);
    color: var(--teal-text);
  }

  .chip.active {
    background: var(--surface-navy);
    border-color: var(--eflury-navy);
    color: var(--eflury-white);
  }

  .chip .count {
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0.7;
  }

  /* Blog Grid */
  .blog-grid {
    padding: 4rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 3rem 2.5rem;
  }

  .post-card {
    background: var(--bg-primary);
    border-radius: 0;
    overflow: hidden;
    border: none;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .post-card:hover {
    transform: translateY(-2px);
  }

  /* The hidden attribute must beat the explicit display:flex above */
  .post-card[hidden] {
    display: none;
  }

  .post-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--apple-black);
    position: relative;
  }

  .post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.5s var(--ease-in-out);
    filter: brightness(0.95);
  }

  .post-card:hover .post-image img {
    transform: scale(1.03);
    filter: brightness(1);
  }

  .post-content {
    padding: 1.5rem 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .post-meta span {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .post-meta :global(svg) {
    color: var(--teal-text);
    opacity: 0.6;
  }

  .topic-badge {
    color: var(--teal-text);
    font-weight: 700;
  }

  .post-card h2 {
    font-size: clamp(1.5rem, 3vw, 1.85rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }

  .post-card .description {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
    flex-grow: 1;
    font-weight: 400;
  }

  .read-more {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.85rem;
    margin-top: auto;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all 0.2s ease;
  }

  .post-card:hover .read-more {
    gap: 0.75rem;
    color: var(--teal-text);
  }

  .read-more :global(svg) {
    transition: transform 0.2s ease;
  }

  .post-card:hover .read-more :global(svg) {
    transform: translateX(4px);
  }

  /* CTA Section */
  .cta {
    padding: 4rem 0;
    background: var(--surface-navy);
    text-align: center;
  }

  .cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: var(--eflury-white);
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--action-teal);
    color: var(--eflury-white);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hero {
      padding: 2rem 0 2rem;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
