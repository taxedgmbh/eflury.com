---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Statistics from '../../components/Statistics.astro';
import About from '../../components/About.astro';
import Services from '../../components/Services.astro';
import Portfolio from '../../components/Portfolio.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import MobileBottomNav from '../../components/MobileBottomNav.astro';
import { useTranslations } from '../../i18n/utils';

// SEO Schema Components - LLM Optimized
import FAQSchema from '../../components/FAQSchema.astro';
import PersonSchema from '../../components/PersonSchema.astro';
import OrganizationSchema from '../../components/OrganizationSchema.astro';
import { faqsEN } from '../../data/faqs';

const lang = 'en';
const t = useTranslations(lang);
---

<MainLayout
  title={t('meta.title')}
  description={t('meta.description')}
  keywords={t('meta.keywords')}
  lang={lang}
>
  <!-- SEO Schema Markup - Optimized for LLM visibility -->
  <FAQSchema faqs={faqsEN} lang={lang} slot="head" />
  <PersonSchema slot="head" />
  <OrganizationSchema type="eflury" slot="head" />

  <Header lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />
    <Statistics lang={lang} />
    <About lang={lang} />
    <Services lang={lang} />
    <Portfolio lang={lang} />
    <Testimonials lang={lang} />
    <FAQ lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
  <MobileBottomNav lang={lang} />
  <AIChatbot />
</MainLayout>
