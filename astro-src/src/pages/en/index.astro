---
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import TrustSignals from '../../components/TrustSignals.astro';
import ProofStrip from '../../components/ProofStrip.astro';
import ServiceLifecycle from '../../components/ServiceLifecycle.astro';
import IndustriesRouter from '../../components/IndustriesRouter.astro';
import MethodTrustBand from '../../components/MethodTrustBand.astro';
import TechPartners from '../../components/TechPartners.astro';
import About from '../../components/About.astro';
import Testimonials from '../../components/Testimonials.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<MainLayout
  title={t('meta.title')}
  description={t('meta.description')}
  keywords={t('meta.keywords')}
  lang={lang}
  preloadHero={true}
>
  <Header lang={lang} />
  <main id="main-content">
    <Hero lang={lang} />
    <TrustSignals lang={lang} />
    <ProofStrip lang={lang} />
    <ServiceLifecycle lang={lang} />
    <IndustriesRouter lang={lang} />
    <MethodTrustBand lang={lang} />
    <TechPartners lang={lang} />
    <About lang={lang} />
    <Testimonials lang={lang} />
    <LeadMagnet lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>
