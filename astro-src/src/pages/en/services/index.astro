---
import MainLayout from '../../../layouts/MainLayout.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import LifecycleOrbitIllustration from '../../../components/illustrations/LifecycleOrbitIllustration.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, FileText, Cpu, Server, Calculator, BarChart3, Database, ClipboardCheck, Activity } from 'lucide-astro';

const lang = 'en';

// BUILD-stage services (ADVISE and RUN are rendered as feature rows)
const buildServices = [
  { icon: Cpu, title: "Claude Skills", desc: "Custom Claude Skills for your specific workflows. Automate repetitive tasks with AI that understands your business.", link: "/en/services/claude-skills/", badge: null, metric: "The core of every package" },
  { icon: Server, title: "MCP Server Integration", desc: "Connect Claude to your business systems via Model Context Protocol — databases, APIs, and business software.", link: "/en/services/mcp-integration/", badge: null, metric: "bexio · databases · Microsoft 365" },
  { icon: Calculator, title: "Finance Process Automation", desc: "Automate month-end close, reporting, and reconciliations — AI-assisted, with bexio and ABACUS integration.", link: "/en/services/finance-automation/", badge: null, metric: "Month-end · payables · reporting" },
  { icon: BarChart3, title: "Power BI Consulting", desc: "Custom Power BI dashboards and reports — from data modeling to the executive dashboard.", link: "/en/services/power-bi/", badge: null, metric: "Dashboards · Excel migration" },
  { icon: Database, title: "Data Quality with Agentic AI", desc: "AI agents that profile, clean, and monitor your business data — with human control built in.", link: "/en/services/data-quality/", badge: "New", metric: "Includes a live demo" },
];
---

<MainLayout
  title="Services - AI Automation for Swiss SMEs | eflury.com"
  description="Seven services along the Advise · Build · Run lifecycle: AI Audit, Claude Skills, MCP integration, finance automation, Power BI, data quality, and Managed AI Operations — at fixed prices."
  keywords="Claude Skills, MCP integration, finance automation, Power BI consulting, AI audit, Swiss AI services"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Services" }]} />

  <main class="services-page">
    <section class="page-hero">
      <div class="container">
        <span class="hero-badge">7 services · fixed prices · one lifecycle</span>
        <h1 class="page-title">Services.</h1>
        <p class="page-lead">Every service has its place in the lifecycle: we advise before we build — and we run what we built.</p>
      </div>
    </section>

    <IllustrationShowcase>
      <LifecycleOrbitIllustration />
    </IllustrationShowcase>

    <section class="offer">
      <div class="container">

        <!-- ADVISE -->
        <div class="stage-head">
          <span class="stage-pill navy">Advise</span>
          <span class="stage-line">Understand & prioritize</span>
        </div>
        <a href="/en/services/ai-audit/" class="feature-card">
          <div class="icon-tile"><ClipboardCheck size={26} /></div>
          <div class="feature-body">
            <div class="feature-top">
              <h2>AI Audit</h2>
              <span class="start-badge">Start here</span>
            </div>
            <p>One week, fixed price: process inventory with time-cost scoring, prioritized roadmap, and ROI projection per initiative — ending in an honest go/no-go.</p>
            <div class="feature-meta">
              <span class="metric">CHF 4'900 · fully credited</span>
              <span class="sample-link"><FileText size={14} /> See the sample report (PDF)</span>
            </div>
          </div>
          <span class="go"><ArrowRight size={18} /></span>
        </a>

        <!-- BUILD -->
        <div class="stage-head">
          <span class="stage-pill teal">Build</span>
          <span class="stage-line">Build & deploy</span>
        </div>
        <div class="services-grid">
          {buildServices.map((service) => (
            <a href={service.link} class="service-card">
              <div class="card-top">
                <div class="icon-tile"><service.icon size={24} /></div>
                {service.badge && <span class="new-badge">{service.badge}</span>}
              </div>
              <h2>{service.title}</h2>
              <p>{service.desc}</p>
              <div class="card-bottom">
                <span class="metric">{service.metric}</span>
                <span class="go"><ArrowRight size={16} /></span>
              </div>
            </a>
          ))}
        </div>

        <!-- RUN -->
        <div class="stage-head">
          <span class="stage-pill blue">Run</span>
          <span class="stage-line">Operate & improve</span>
        </div>
        <a href="/en/services/managed-ai-operations/" class="feature-card">
          <div class="icon-tile"><Activity size={26} /></div>
          <div class="feature-body">
            <div class="feature-top">
              <h2>Managed AI Operations</h2>
            </div>
            <p>We run what we build: monitoring, a monthly metrics report, an improvement backlog, and re-validation after platform updates.</p>
            <div class="feature-meta">
              <span class="metric">From CHF 1'200/month</span>
            </div>
          </div>
          <span class="go"><ArrowRight size={18} /></span>
        </a>

        <h2 class="explore-title">Explore more</h2>
        <div class="explore-grid">
          <a href="/en/pricing/" class="explore-card">
            <h3>Pricing & packages</h3>
            <p>Transparent fixed prices — from the Micro project to the Enterprise package.</p>
          </a>
          <a href="/en/skopaai/" class="explore-card">
            <h3>SkopaAI <span class="badge-new">New</span></h3>
            <p>Preconfigured Mac mini with AI assistant. Unpack, plug in, go.</p>
          </a>
          <a href="/en/case-studies/" class="explore-card">
            <h3>Case studies</h3>
            <p>Real projects, measurable results — including the Taxed GmbH case study.</p>
          </a>
        </div>

        <section class="cta-section">
          <h2>Not sure which service fits?</h2>
          <p>Book a free 30-minute strategy call. We analyze your workflows and recommend the right approach.</p>
          <a href="/en/contact/" class="cta-button">
            Book a free strategy call
            <ArrowRight size={18} />
          </a>
        </section>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-hero {
    padding: 3.5rem 0 3rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .page-lead {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .offer {
    padding: 1rem 0 4rem;
  }

  .stage-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 3rem 0 1.25rem;
  }

  .stage-pill {
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
  }

  .stage-pill.navy { background: var(--surface-navy); }
  .stage-pill.teal { background: var(--action-teal); }
  .stage-pill.blue { background: var(--eflury-blue-mid); }

  .stage-line {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* Feature rows (Advise / Run) */
  .feature-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .feature-body {
    flex: 1;
    min-width: 0;
  }

  .feature-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .feature-card h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .start-badge {
    background: var(--action-teal);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.28rem 0.7rem;
    border-radius: var(--radius-full);
  }

  .feature-card p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 0.85rem;
  }

  .feature-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .metric {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--teal-text);
  }

  .sample-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--link-color);
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
    flex-shrink: 0;
  }

  .go {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    color: var(--teal-text);
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .feature-card:hover .go,
  .service-card:hover .go {
    background: var(--action-teal);
    color: #fff;
  }

  /* Build grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .card-top .icon-tile {
    width: 46px;
    height: 46px;
  }

  .new-badge {
    background: var(--surface-navy);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.26rem 0.65rem;
    border-radius: var(--radius-full);
  }

  .service-card h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .service-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
    flex: 1;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--border-color);
    padding-top: 0.9rem;
  }

  .card-bottom .go {
    width: 32px;
    height: 32px;
  }

  /* Explore */
  .explore-title {
    text-align: center;
    font-size: 1.35rem;
    color: var(--text-primary);
    margin: 3.5rem 0 1.25rem;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .explore-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.6rem;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .explore-card:hover {
    border-color: var(--eflury-teal);
    transform: translateY(-2px);
  }

  .explore-card h3 {
    font-size: 1.02rem;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
  }

  .explore-card p {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .badge-new {
    background: var(--action-teal);
    color: #fff;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-full);
    vertical-align: middle;
    margin-left: 0.35rem;
  }

  /* CTA */
  .cta-section {
    margin-top: 3.5rem;
    text-align: center;
    background: var(--surface-navy);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
  }

  .cta-section h2 {
    color: #fff;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    padding: 0.95rem 1.9rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-button:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .feature-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .feature-card .go {
      display: none;
    }
  }
</style>
