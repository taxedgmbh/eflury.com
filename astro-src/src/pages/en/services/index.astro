---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { useTranslations } from '../../../i18n/utils';
import { ArrowRight, Cpu, Server, Calculator, BarChart3, Database, ClipboardCheck, Activity } from 'lucide-astro';

const lang = 'en';
const t = useTranslations(lang);

const services = [
  {
    icon: ClipboardCheck,
    title: 'AI Audit',
    description: 'One week, fixed price: process inventory with time-cost scoring, prioritized roadmap, and an ROI projection per initiative — ending in an honest go/no-go.',
    link: '/en/services/ai-audit',
    badge: 'Start Here',
    metric: 'CHF 4,900 · fully credited'
  },
  {
    icon: Cpu,
    title: 'Claude Skills Development',
    description: 'Custom Claude Skills built for your specific workflows. Automate repetitive tasks with AI that understands your business.',
    link: '/en/services/claude-skills',
    badge: 'Most Popular',
    metric: '15-30 hrs/week saved'
  },
  {
    icon: Server,
    title: 'MCP Server Integration',
    description: 'Connect Claude to your business systems with Model Context Protocol. Seamless integration with databases, APIs, and enterprise software.',
    link: '/en/services/mcp-integration',
    badge: null,
    metric: '5+ systems connected'
  },
  {
    icon: Calculator,
    title: 'Finance Process Automation',
    description: 'Automate month-end close, reporting, and reconciliation. AI-powered finance automation with Bexio and ABACUS integration.',
    link: '/en/services/finance-automation',
    badge: null,
    metric: '40 hrs/month saved'
  },
  {
    icon: Database,
    title: 'Data Quality with Agentic AI',
    description: 'Autonomous AI agents that profile, clean, and monitor your business data. Deduplication, validation, and continuous quality checks — with human review built in.',
    link: '/en/services/data-quality',
    badge: 'New',
    metric: 'Trustworthy data, measurable'
  },
  {
    icon: BarChart3,
    title: 'Power BI Consulting',
    description: 'Custom Power BI dashboards and reports for Swiss businesses. From data modeling to executive dashboards with AI-powered insights.',
    link: '/en/services/power-bi',
    badge: null,
    metric: '15 hrs/week saved'
  },
  {
    icon: Activity,
    title: 'Managed AI Operations',
    description: 'We run what we build: monitoring, monthly metrics reports, improvement backlog, and re-validation after platform updates.',
    link: '/en/services/managed-ai-operations',
    badge: null,
    metric: 'From CHF 1,200/month'
  }
];
---

<MainLayout
  title="Services | eflury.com"
  description={t('services_pages.index.description')}
  keywords="Claude Skills, MCP integration, finance automation, Power BI consulting, Swiss AI services"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Services' }]} />

  <main class="services-page">
    <section class="page-hero">
      <div class="container">
        <h1 class="page-title">{t('services_pages.index.title')}</h1>
        <p class="page-subtitle">{t('services_pages.index.subtitle')}</p>
        <p class="page-description">{t('services_pages.index.description')}</p>
      </div>
    </section>

    <section class="offer">
      <div class="container">
        <div class="services-grid">
          {services.map((service) => (
            <a href={service.link} class="service-card">
              <div class="card-top">
                <div class="icon-tile">
                  <service.icon size={28} />
                </div>
                {service.badge && <span class="popular-badge">{service.badge}</span>}
              </div>
              <h2>{service.title}</h2>
              <p>{service.description}</p>
              <div class="card-bottom">
                <span class="saving">{service.metric}</span>
                <span class="go">
                  <ArrowRight size={18} />
                </span>
              </div>
            </a>
          ))}
        </div>

        <h2 class="explore-title">More to explore</h2>
        <div class="explore-grid">
          <a href="/en/pricing" class="explore-card">
            <h3>Pricing & Packages</h3>
            <p>Transparent fixed prices — from micro projects to enterprise packages.</p>
          </a>
          <a href="/en/skopaai" class="explore-card">
            <h3>SkopaAI <span class="badge-new">New</span></h3>
            <p>Pre-configured Mac mini with an AI assistant. Unbox, plug in, go.</p>
          </a>
          <a href="/en/case-studies" class="explore-card">
            <h3>Case Studies</h3>
            <p>Real projects, measurable results — including the Taxed GmbH case study.</p>
          </a>
        </div>

        <section class="cta-section">
          <h2>Not sure which service fits?</h2>
          <p>Book a free 30-minute strategy call. We'll analyze your workflows and recommend the right approach.</p>
          <a href={`/${lang}/#contact`} class="cta-button">
            Book a free strategy call
            <ArrowRight size={18} />
          </a>
        </section>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Shared verbatim between en/ and de/ services index — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* --- Hero band ------------------------------------------------------ */
  .page-hero {
    position: relative;
    padding: 3.5rem 0 3rem;
    background: linear-gradient(180deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    overflow: hidden;
    text-align: center;
  }

  .page-hero::before {
    content: '';
    position: absolute;
    top: -140px;
    right: -100px;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(13, 148, 136, 0.12), transparent 65%);
    pointer-events: none;
  }

  .breadcrumb {
    position: relative;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin-bottom: 1.5rem;
  }

  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--teal-text);
  }

  .page-title {
    position: relative;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    position: relative;
    font-size: clamp(1.125rem, 2.5vw, 1.3125rem);
    color: var(--teal-text);
    font-weight: 650;
    margin-bottom: 0.75rem;
  }

  .page-description {
    position: relative;
    font-size: 1.0625rem;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* --- Service cards ----------------------------------------------------- */
  .offer {
    padding: 3.5rem 0 4.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 18px;
    text-decoration: none;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--teal-text);
    box-shadow: 0 12px 28px rgba(2, 37, 84, 0.1);
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .icon-tile {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 14px;
    color: var(--teal-text);
  }

  .popular-badge {
    padding: 0.3125rem 0.75rem;
    background: var(--action-teal);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .service-card h2 {
    font-size: 1.3125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.625rem;
  }

  .service-card > p {
    font-size: 0.9625rem;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
    margin: 0 0 1.5rem;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--border-color);
  }

  .saving {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--teal-text);
  }

  .go {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--bg-secondary);
    border-radius: 50%;
    color: var(--text-secondary);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .service-card:hover .go {
    background: var(--action-teal);
    color: #fff;
    transform: translateX(4px);
  }

  /* --- Explore row -------------------------------------------------------- */
  .explore-title {
    text-align: center;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 3.5rem 0 0.5rem;
  }

  .explore-title::after {
    content: '';
    display: block;
    width: 40px;
    height: 3px;
    border-radius: 2px;
    background: var(--eflury-teal);
    margin: 0.75rem auto 0;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .explore-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1.375rem 1.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    text-decoration: none;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .explore-card:hover {
    transform: translateY(-3px);
    border-color: var(--teal-text);
  }

  .explore-card h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 1.0625rem;
    color: var(--text-primary);
  }

  .badge-new {
    padding: 0.125rem 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .explore-card p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  /* --- CTA ------------------------------------------------------------------ */
  .cta-section {
    margin-top: 3.5rem;
    text-align: center;
    padding: 3.5rem 2rem;
    background: linear-gradient(135deg, var(--eflury-navy) 0%, var(--eflury-teal) 130%);
    border-radius: 20px;
  }

  .cta-section h2 {
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.875rem;
  }

  .cta-section p {
    font-size: 1.0625rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 auto 2rem;
    max-width: 520px;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9375rem 1.875rem;
    background: #fff;
    color: var(--eflury-navy);
    font-size: 1rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cta-button:hover {
    background: rgba(255, 255, 255, 0.92);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  }

  /* --- Responsive -------------------------------------------------------------- */
  @media (max-width: 900px) {
    .explore-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.25rem;
    }

    .page-hero {
      padding: 2.75rem 0 2.25rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .offer {
      padding: 2.75rem 0 3.5rem;
    }

    .cta-section {
      padding: 2.75rem 1.5rem;
    }
  }
</style>
