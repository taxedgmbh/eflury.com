---
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import InvoiceFlowIllustration from '../../../components/illustrations/InvoiceFlowIllustration.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const serviceData = {
  title: t('services_pages.finance_automation.meta.title'),
  description: t('services_pages.finance_automation.meta.description'),
  keywords: t('services_pages.finance_automation.meta.keywords'),
  lang,
  serviceType: 'Finance Process Automation',
  heroTitle: t('services_pages.finance_automation.hero.title'),
  heroSubtitle: t('services_pages.finance_automation.hero.badge'),
  heroDescription: t('services_pages.finance_automation.hero.description'),
  problemTitle: t('services_pages.finance_automation.problem.title'),
  problems: [
    'Month-end close takes days of manual data gathering and reconciliation',
    'Report generation requires hours of copying data between systems',
    'Invoice processing is a bottleneck with manual data entry',
    'Compliance documentation is time-consuming and error-prone'
  ],
  solutionTitle: t('services_pages.finance_automation.solution.title'),
  solutionDescription: t('services_pages.finance_automation.solution.description'),
  benefits: [
    {
      title: 'Faster Month-End Close',
      description: 'Reduce close time by 60-80% with automated reconciliation and reporting.'
    },
    {
      title: 'Bexio & ABACUS Integration',
      description: 'Native integration with Swiss accounting software via MCP.'
    },
    {
      title: 'Accurate & Auditable',
      description: 'AI maintains audit trails and catches errors humans miss.'
    },
    {
      title: 'Swiss Compliance Ready',
      description: 'Built with Swiss accounting standards and FADP data protection in mind.'
    }
  ],
  processTitle: t('services_pages.finance_automation.process.title'),
  processSteps: [
    {
      title: 'Process Mapping',
      description: 'We document your current finance workflows and pain points.'
    },
    {
      title: 'Automation Design',
      description: 'We design AI workflows that integrate with your accounting software.'
    },
    {
      title: 'Build & Test',
      description: 'Automation is built and tested with historical data before go-live.'
    },
    {
      title: 'Parallel Run & Training',
      description: 'We run old and new processes together, then train your team.'
    }
  ],
  faqs: [
    {
      question: 'Which accounting software do you integrate with?',
      answer: 'We specialize in Swiss accounting software: Bexio, ABACUS, and Infoniqa. We also work with international tools like Xero, QuickBooks, and SAP. For custom or legacy systems, we can build API integrations.'
    },
    {
      question: 'How much time can we realistically save?',
      answer: 'Most finance teams save 30-50 hours per month after automation. Month-end close typically reduces from 5-7 days to 1-2 days. Invoice processing goes from minutes per invoice to seconds.'
    },
    {
      question: 'Is AI accurate enough for financial data?',
      answer: 'Modern AI achieves 99%+ accuracy on structured data tasks. We always include human review checkpoints for high-stakes decisions. The AI handles data gathering and preparation; humans make final approvals.'
    },
    {
      question: 'What about compliance and audit requirements?',
      answer: 'All automations maintain complete audit trails. Every AI action is logged with timestamps. We design workflows that comply with Swiss accounting standards (OR/HRM) and data protection requirements (FADP/DSG).'
    },
    {
      question: "What's the investment for finance automation?",
      answer: "Starter projects (1-2 processes) begin at CHF 10'000. Comprehensive finance automation packages range CHF 25'000-50,000. Most clients see ROI within 3-6 months through time savings."
    }
  ],
  ctaTitle: t('services_pages.finance_automation.cta.title'),
  ctaDescription: t('services_pages.finance_automation.cta.description'),
  ctaButtonText: t('services_pages.finance_automation.cta.button'),
  relatedCaseStudy: {
    title: 'Finance Automation Case Study',
    link: '/en/case-studies/finance-automation',
    metric: '40 hrs/month saved'
  }
};
---

<ServiceLayout {...serviceData}>
  <IllustrationShowcase slot="showcase">
    <InvoiceFlowIllustration />
  </IllustrationShowcase>
</ServiceLayout>
