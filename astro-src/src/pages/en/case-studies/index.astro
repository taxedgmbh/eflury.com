---
/**
 * Case Studies Index Page
 * Showcases all client success stories
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import ResultsWallVisual from '../../../components/illustrations/ResultsWallVisual.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, Clock, TrendingUp, Building2, Home, ChevronRight } from 'lucide-astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

const caseStudies = [
  {
    slug: 'taxed-gmbh',
    title: 'Taxed GmbH',
    subtitle: 'How I Automated My Own Accounting Firm',
    industry: 'Tax Consulting',
    badge: 'My Own Firm',
    badgeClass: 'own',
    statsList: [
      { value: '27.5h/week', label: 'Time Saved' },
      { value: 'CHF 24K/year', label: 'Annual Savings' },
      { value: '3.2 months', label: 'Payback' },
    ],
    description: 'Complete automation of client onboarding, report generation, email responses, and tax calculations using Claude Skills and MCP integration with bexio.',
  },
  {
    slug: 'finance-automation',
    title: 'Finance Process Automation',
    subtitle: 'Month-End Close Optimization',
    industry: 'Manufacturing',
    badge: 'Client Project',
    badgeClass: 'client',
    statsList: [
      { value: '40h/month', label: 'Time Saved' },
      { value: 'CHF 48K/year', label: 'Annual Savings' },
      { value: '4.1 months', label: 'Payback' },
    ],
    description: 'Automated reconciliation, variance analysis, and reporting for a Swiss manufacturing company, reducing month-end close from 12 days to 5 days.',
  },
  {
    slug: 'power-bi-reporting',
    title: 'Power BI Executive Dashboard',
    subtitle: 'Real-Time Business Intelligence',
    industry: 'Professional Services',
    badge: 'Client Project',
    badgeClass: 'client',
    statsList: [
      { value: '15h/week', label: 'Time Saved' },
      { value: 'CHF 36K/year', label: 'Annual Savings' },
      { value: '2.8 months', label: 'Payback' },
    ],
    description: 'Built a comprehensive Power BI solution connecting 7 data sources, enabling real-time KPI tracking and automated client reporting.',
  },
  {
    slug: 'llm-pipeline-showcase',
    title: 'Three LLMs, One Dunning Run',
    subtitle: 'How a Python script puts AI to work, row by row',
    industry: 'Tech Showcase',
    badge: 'Code Published',
    badgeClass: 'tech',
    statsList: [
      { value: '3 providers', label: 'Claude · GPT · Gemini' },
      { value: '40 invoices', label: 'Processed row by row' },
      { value: '< CHF 1', label: 'API cost per run (projection)' },
    ],
    description: 'Not a client project but a runnable teaching piece: a Python script assesses open invoices with Claude, enforces JSON with GPT-5 mini and drafts reminder emails with Gemini — code, real model outputs and cost projection published in full.',
  },
];
---

<MainLayout
  title="Case Studies - AI Automation Success Stories | Emanuel Flury"
  description="Documented AI automation projects from Swiss businesses: estimated savings of CHF 24K-48K per year and payback in 2.8-4.1 months, with the numbers shown per project."
  keywords="AI automation case studies, Swiss business automation, Claude AI implementation, RPA success stories, Power BI consulting"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: t('nav.case_studies') }]} />

  <main class="case-studies-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">

        <h1>Case Studies</h1>
        <p class="subtitle">Real results from real Swiss businesses</p>

        <div class="hero-stats">
          <div class="stat">
            <Clock size={24} />
            <span class="value">~220 h/month</span>
            <span class="label">Combined estimated time saved</span>
          </div>
          <div class="stat">
            <TrendingUp size={24} />
            <span class="value">~CHF 108K</span>
            <span class="label">Combined estimated annual savings</span>
          </div>
          <div class="stat">
            <Building2 size={24} />
            <span class="value">2.8–4.1 months</span>
            <span class="label">Estimated payback, per project</span>
          </div>
        </div>
        <p class="stats-basis">
          Aggregated from the three automation projects below — every figure is documented, per project, in its case study. The tech showcase (synthetic data) is not included.
        </p>
      </div>
    </section>

    <!-- Case Studies Grid -->
    <section class="case-studies-grid">
      <div class="container">
        {caseStudies.map((study) => (
          <a href={`/en/case-studies/${study.slug}`} class="case-study-card">
            <div class="card-header">
              <span class={`badge ${study.badgeClass}`}>
                {study.badge}
              </span>
              <span class="industry">{study.industry}</span>
            </div>

            <h2>{study.title}</h2>
            <p class="card-subtitle">{study.subtitle}</p>
            <p class="description">{study.description}</p>

            <div class="stats-row">
              {study.statsList.map((s) => (
                <div class="stat-item">
                  <span class="stat-value">{s.value}</span>
                  <span class="stat-label">{s.label}</span>
                </div>
              ))}
            </div>

            <div class="card-cta">
              Read Case Study <ArrowRight size={16} />
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="results-wall-section">
      <div class="container">
        <ResultsWallVisual lang="en" />
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Want Similar Results?</h2>
        <p>Book a free 30-minute assessment to discover your automation potential.</p>
        <a href="/en/contact/" class="btn-primary">
          Get Started
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .case-studies-page {
    /* padding-top handled by breadcrumb */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero {
    padding: 3rem 0 4rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .hero .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .hero-stats .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .stats-basis {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 1.25rem 0 0;
  }

  .hero-stats .stat :global(svg) {
    color: var(--teal-text);
    margin-bottom: 0.75rem;
  }

  .hero-stats .value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--eflury-navy);
  }

  .hero-stats .label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Case Studies Grid */
  .case-studies-grid {
    padding: 4rem 0;
  }

  .case-studies-grid .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .case-study-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid var(--border-color);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .case-study-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    border-color: var(--teal-text);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge.own {
    background: var(--action-teal);
    color: white;
  }

  .badge.client {
    background: var(--surface-navy);
    color: white;
  }

  .badge.tech {
    background: transparent;
    border: 1.5px solid var(--action-teal);
    color: var(--teal-text);
  }

  .industry {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .case-study-card h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .card-subtitle {
    font-size: 1rem;
    color: var(--teal-text);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1.5rem;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--eflury-navy);
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--teal-text);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .case-study-card:hover .card-cta {
    gap: 0.75rem;
  }

  /* CTA Section */
  .cta {
    padding: 4rem 0;
    background: var(--surface-navy);
    text-align: center;
  }

  .cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--action-teal);
    color: white;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    background: #0f766e;
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hero {
      padding: 2rem 0 3rem;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .hero-stats .stat {
      flex-direction: row;
      justify-content: space-between;
      padding: 1rem 1.5rem;
    }

    .hero-stats .stat :global(svg) {
      margin-bottom: 0;
      margin-right: 1rem;
    }

    .case-studies-grid .container {
      grid-template-columns: 1fr;
    }

    .stats-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .stat-item {
      display: flex;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
