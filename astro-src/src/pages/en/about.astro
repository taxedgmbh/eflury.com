<script>
  // GSAP counter animation for impact stats
  if (typeof window !== 'undefined') {
    import('gsap').then(({ gsap }) => {
      import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);

        // Final values are server-rendered; only animate 0 -> target when JS runs.
        const counters = document.querySelectorAll('.stat-item .stat-value[data-target]');

        counters.forEach((counter) => {
          const target = parseFloat(counter.getAttribute('data-target') || '0');
          const suffix = counter.getAttribute('data-suffix') || '';
          const state = { value: 0 };

          gsap.fromTo(state, { value: 0 }, {
            value: target,
            duration: 2,
            ease: 'power2.out',
            scrollTrigger: {
              trigger: counter.closest('.stat-item'),
              start: 'top 85%',
              once: true,
            },
            onUpdate: () => {
              counter.textContent = Math.round(state.value) + suffix;
            },
          });
        });
      });
    });
  }
</script>
