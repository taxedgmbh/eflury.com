---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, BarChart3, FileSpreadsheet, Database, Send } from 'lucide-astro';

const lang = 'en';

const pains = [
  {
    title: 'Reports rebuilt by hand every cycle',
    text: 'The monthly numbers exist — but assembling them from exports and spreadsheets eats days, every single month.',
  },
  {
    title: 'No single source of truth',
    text: 'ERP, CRM, banking, Excel — the same KPI has three values depending on who you ask, and nobody fully trusts any of them.',
  },
  {
    title: 'Decisions wait for data',
    text: 'Management questions take hours to answer because the data has to be hunted down and reconciled first.',
  },
];

const automations = [
  {
    icon: BarChart3,
    title: 'Power BI dashboards',
    text: 'Live dashboards connected to your source systems — the numbers refresh themselves instead of being rebuilt.',
    href: '/en/services/power-bi/',
    linkLabel: 'Power BI service',
  },
  {
    icon: FileSpreadsheet,
    title: 'Excel to Power BI migration',
    text: 'Structured migration of grown Excel reporting — with a checklist for the typical pitfalls.',
    href: '/en/blog/excel-to-power-bi-migration/',
    linkLabel: 'The migration guide',
  },
  {
    icon: Database,
    title: 'Data quality',
    text: 'Duplicates, format drift, and missing identifiers cleaned with human approval gates — so your reports stop arguing with each other.',
    href: '/en/services/data-quality/',
    linkLabel: 'Data quality service',
  },
  {
    icon: Send,
    title: 'Report distribution',
    text: 'Recurring client and management reports drafted and distributed automatically — reviewed by a person before anything leaves the house.',
    href: '/en/services/finance-automation/',
    linkLabel: 'Finance automation service',
  },
];
---

<MainLayout
  title="Reporting & Data Automation - eFlury Consulting"
  description="Automation for reporting and data in Swiss SMEs: Power BI dashboards, Excel migration, data quality, and automated report distribution — documented in a client case study."
  keywords="Power BI Swiss SME, reporting automation, Excel Power BI migration, data quality, dashboard automation"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Where We Help', href: '/en/industries/' }, { label: 'Reporting & Data' }]} />

  <main class="industry-page">
    <section class="industry-hero">
      <div class="container">
        <p class="eyebrow">Where we help · Reporting &amp; Data</p>
        <h1>Reporting &amp; data.</h1>
        <p class="lead">
          Numbers you trust, on screens that update themselves.
          We connect your systems, clean the data underneath, and automate the reports on top.
        </p>
      </div>
    </section>

    <section class="pains">
      <div class="container">
        <h2>Where the hours go</h2>
        <div class="card-grid three">
          {pains.map((pain) => (
            <div class="plain-card">
              <h3>{pain.title}</h3>
              <p>{pain.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="automations">
      <div class="container">
        <h2>What we automate around reporting &amp; data</h2>
        <p class="section-lead">
          Every system follows the same rule: AI proposes, your team approves.
          Your data stays in your systems — agents access it read-only via MCP connectors.
        </p>
        <div class="card-grid two">
          {automations.map((item) => (
            <div class="auto-card">
              <div class="auto-icon"><item.icon size={22} /></div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a href={item.href} class="card-link">{item.linkLabel} <ArrowRight size={14} /></a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="proof">
      <div class="container">
        <h2>Documented in a client project</h2>
        <div class="proof-card">
          <p>
            For a professional services firm we built a Power BI solution connecting seven data
            sources into one executive dashboard — documented with ~15 h/week estimated time saved
            and ~2.8 months estimated payback.
          </p>
          <a href="/en/case-studies/power-bi-reporting/" class="card-link">Power BI case study <ArrowRight size={14} /></a>
        </div>
        <div class="proof-card">
          <p>
            How our data-quality agents reason about duplicates and conflicts is shown live —
            with illustrative data — in the interactive demo on the data quality service page.
          </p>
          <a href="/en/services/data-quality/" class="card-link">See the live demo <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="insights-band">
      <div class="container">
        <p>
          In-depth articles on Power BI and reporting —
          <a href="/en/blog/#powerbi">read them in the Insights hub</a>.
        </p>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>How long does your monthly report take?</h2>
        <p>Free 30-minute call — we look at your reporting chain, not a slide deck.</p>
        <a href="/en/contact/" class="btn-primary">
          Get in touch
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .industry-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: var(--spacing-lg);
  }

  .industry-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 auto var(--spacing-md);
    max-width: 800px;
  }

  .industry-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: var(--spacing-xl);
  }

  .pains {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .automations {
    padding: var(--spacing-3xl) 0;
    background: var(--bg-primary);
  }

  .card-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .card-grid.three {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid.two {
    grid-template-columns: repeat(2, 1fr);
  }

  .plain-card,
  .auto-card,
  .proof-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .plain-card h3,
  .auto-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .plain-card p,
  .auto-card p,
  .proof-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .auto-card p {
    margin-bottom: var(--spacing-md);
  }

  .auto-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--teal-text);
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .proof {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-secondary);
  }

  .proof-card p {
    font-size: 1.02rem;
    margin-bottom: var(--spacing-md);
  }

  .proof-card + .proof-card {
    margin-top: var(--spacing-lg);
  }

  .insights-band {
    padding: var(--spacing-xl) 0;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .insights-band p {
    font-size: 1rem;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  .insights-band a {
    display: inline-flex;
    align-items: center;
    color: var(--link-color);
    font-weight: 600;
    text-decoration: none;
  }

  .insights-band a:hover {
    text-decoration: underline;
  }

  .cta {
    padding: var(--spacing-3xl) 0;
    background: var(--surface-navy);
    text-align: center;
  }

  .cta h2 {
    color: var(--eflury-white);
    margin-bottom: var(--spacing-sm);
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    margin-bottom: var(--spacing-xl);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--action-teal);
    color: var(--eflury-white);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .card-grid.three,
    .card-grid.two {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .industry-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .industry-hero .lead {
      font-size: 1.05rem;
    }

    .pains,
    .automations,
    .proof {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
