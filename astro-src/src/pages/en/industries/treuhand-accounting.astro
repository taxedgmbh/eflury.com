---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, FileInput, Receipt, MailCheck, Database } from 'lucide-astro';

const lang = 'en';

const pains = [
  {
    title: 'Price pressure on standard services',
    text: 'Bookkeeping, payroll, and VAT returns are becoming commodities — clients compare prices, not effort.',
  },
  {
    title: 'Qualified staff is scarce',
    text: 'Open positions stay open. The team you have spends too many hours on routine work that does not need their judgment.',
  },
  {
    title: 'More regulation, higher expectations',
    text: 'Compliance grows while clients expect faster answers and digital service — both pull in opposite directions on your margin.',
  },
];

const automations = [
  {
    icon: FileInput,
    title: 'Client onboarding',
    text: 'Document intake, checklists, and structured client files — assembled by AI, approved by your team.',
    href: '/en/blog/ai-client-onboarding-accounting-firms/',
    linkLabel: 'How AI onboarding works',
  },
  {
    icon: Receipt,
    title: 'Accounts payable & bookkeeping routine',
    text: 'Invoice capture, account assignment proposals, and reconciliation prep — connected to bexio or ABACUS via read-only MCP access.',
    href: '/en/services/finance-automation/',
    linkLabel: 'Finance automation service',
  },
  {
    icon: MailCheck,
    title: 'Email & document triage',
    text: 'Incoming client mail sorted, prioritized, and drafted for response — nothing is sent without human review.',
    href: '/en/blog/ai-email-triage-agent-professionals/',
    linkLabel: 'The email triage pattern',
  },
  {
    icon: Database,
    title: 'Client master data & reporting',
    text: 'Duplicates, missing identifiers, and format drift cleaned up with human approval gates — then reported in Power BI.',
    href: '/en/services/data-quality/',
    linkLabel: 'Data quality service',
  },
];
---

<MainLayout
  title="AI for Treuhand & Accounting Firms - eFlury Consulting"
  description="AI automation for Swiss fiduciary and accounting firms: client onboarding, accounts payable, email triage, and master data — with human review gates, tested in a real practice."
  keywords="AI Treuhand, accounting firm automation, fiduciary AI Switzerland, bexio automation, ABACUS integration, client onboarding AI"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Industries', href: '/en/industries/' }, { label: 'Treuhand & Accounting' }]} />

  <main class="industry-page">
    <section class="industry-hero">
      <div class="container">
        <p class="eyebrow">Industries · Treuhand &amp; Accounting</p>
        <h1>AI for fiduciary and accounting firms.</h1>
        <p class="lead">
          Your margin lives on hours — and too many of them go into routine work.
          We automate the repetitive parts of the mandate so your team's time goes
          where clients actually pay for judgment.
        </p>
      </div>
    </section>

    <section class="pains">
      <div class="container">
        <h2>The pressure is structural</h2>
        <div class="card-grid three">
          {pains.map((pain) => (
            <div class="plain-card">
              <h3>{pain.title}</h3>
              <p>{pain.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="automations">
      <div class="container">
        <h2>What we automate in a Treuhand practice</h2>
        <p class="section-lead">
          Every system follows the same rule: AI proposes, your team approves.
          Client data stays in your systems — agents access it read-only via MCP connectors.
        </p>
        <div class="card-grid two">
          {automations.map((item) => (
            <div class="auto-card">
              <div class="auto-icon"><item.icon size={22} /></div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a href={item.href} class="card-link">{item.linkLabel} <ArrowRight size={14} /></a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="proof">
      <div class="container">
        <h2>Tested where it hurts: in a real practice</h2>
        <div class="proof-card">
          <p>
            These systems were built and run in a real Swiss accounting firm — our own.
            The case study documents the setup, the review gates, and the estimated effects:
            ~27.5 h/week time saved, ~CHF 24K projected annual savings, ~3.2 months payback.
          </p>
          <a href="/en/case-studies/taxed-gmbh/" class="card-link">Read the case study <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="insights-band">
      <div class="container">
        <p>
          Four in-depth articles on AI in Treuhand and accounting —
          <a href="/en/blog/#treuhand">read them in the Insights hub</a>.
        </p>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>Which mandate step costs you the most hours?</h2>
        <p>Free 30-minute call — we walk through your practice, not a slide deck.</p>
        <a href="/en/contact/" class="btn-primary">
          Get in touch
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .industry-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--eflury-teal);
    margin-bottom: var(--spacing-lg);
  }

  .industry-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 auto var(--spacing-md);
    max-width: 800px;
  }

  .industry-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: var(--spacing-xl);
  }

  .pains {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .automations {
    padding: var(--spacing-3xl) 0;
    background: var(--bg-primary);
  }

  .card-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .card-grid.three {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid.two {
    grid-template-columns: repeat(2, 1fr);
  }

  .plain-card,
  .auto-card,
  .proof-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .plain-card h3,
  .auto-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .plain-card p,
  .auto-card p,
  .proof-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .auto-card p {
    margin-bottom: var(--spacing-md);
  }

  .auto-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--eflury-teal);
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--primary-light);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .proof {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-secondary);
  }

  .proof-card p {
    font-size: 1.02rem;
    margin-bottom: var(--spacing-md);
  }

  .insights-band {
    padding: var(--spacing-xl) 0;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .insights-band p {
    font-size: 1rem;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  .insights-band a {
    display: inline-flex;
    align-items: center;
    color: var(--primary-light);
    font-weight: 600;
    text-decoration: none;
  }

  .insights-band a:hover {
    text-decoration: underline;
  }

  .cta {
    padding: var(--spacing-3xl) 0;
    background: var(--eflury-navy);
    text-align: center;
  }

  .cta h2 {
    color: var(--eflury-white);
    margin-bottom: var(--spacing-sm);
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    margin-bottom: var(--spacing-xl);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--eflury-teal);
    color: var(--eflury-white);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .card-grid.three,
    .card-grid.two {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .industry-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .industry-hero .lead {
      font-size: 1.05rem;
    }

    .pains,
    .automations,
    .proof {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
