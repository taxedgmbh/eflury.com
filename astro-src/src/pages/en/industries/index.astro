---
import MainLayout from '../../../layouts/MainLayout.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import FloorPlanIllustration from '../../../components/illustrations/FloorPlanIllustration.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, Check, Calculator, BarChart3, Briefcase } from 'lucide-astro';

const lang = "en";

const areas = [
  {
    icon: Calculator,
    title: "Finance & Back Office",
    tagline: "So the close stops eating half of month-end.",
    proof: "2 documented projects",
    ticks: ["Supplier invoice capture & approval", "Month-end close & reconciliations", "Dunning & payment reminders", "Financial master data & controls"],
    href: "/en/industries/finance-teams/",
  },
  {
    icon: Briefcase,
    title: "Customer Communication & Intake",
    tagline: "So customer work stops leaking into administration.",
    proof: "1 documented project",
    ticks: ["Email triage & drafted replies", "Phone reception & call-backs", "WhatsApp business communication", "Quote requests & order intake"],
    href: "/en/industries/professional-services/",
  },
  {
    icon: BarChart3,
    title: "Reporting & Data",
    tagline: "Numbers you trust — refreshing themselves.",
    proof: "1 documented project",
    ticks: ["Power BI dashboards instead of hand-built reports", "Excel migration & data model", "Data quality with AI agents", "Automated report distribution"],
    href: "/en/industries/reporting-data/",
  },
];

const proofs = [
  {
    value: "~40",
    unit: "h/month",
    area: "Finance",
    label: "Finance processes automated for an SME: reconciliation, variance analysis, reports.",
    href: "/en/case-studies/finance-automation/",
  },
  {
    value: "~15",
    unit: "h/week",
    area: "Reporting",
    label: "Manual reporting replaced with Power BI dashboards — client reports included.",
    href: "/en/case-studies/power-bi-reporting/",
  },
  {
    value: "~27.5",
    unit: "h/week",
    area: "Communication & admin",
    label: "In our own company (Taxed GmbH): email, onboarding, and research automated.",
    href: "/en/case-studies/taxed-gmbh/",
  },
];

const stages = [
  { cls: "navy", name: "Advise", text: "AI Audit with process inventory, roadmap, and ROI projection — with an honest go/no-go." },
  { cls: "teal", name: "Build", text: "Claude Skills, integrations, and dashboards — in weeks, not months." },
  { cls: "blue", name: "Run", text: "Managed AI Operations: monitoring, a monthly metrics report, and continuous improvement." },
];
---

<MainLayout
  title="Where We Help - eFlury Consulting"
  description="The three business areas where we automate for Swiss SMEs: finance & back office, customer communication & intake, reporting & data — grounded in documented projects with published estimates."
  keywords="AI automation industries, finance team automation, professional services AI, Swiss SME"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Where We Help" }]} />

  <main class="industries-page">
    <section class="hub-hero">
      <div class="container">
        <span class="hero-badge">3 business areas · Any industry · Documented</span>
        <h1>Where we help.</h1>
        <p class="lead">The same processes eat time in every industry: invoices arrive, emails pile up, reports get built by hand. That is why we organise our work by business area, not by industry.</p>
      </div>
    </section>

    <IllustrationShowcase>
      <FloorPlanIllustration lang={lang} />
    </IllustrationShowcase>

    <section class="hub-areas">
      <div class="container">
        <h2 class="section-title">Three areas, one goal: time back.</h2>
        <p class="section-sub">Each card leads to a detail page with processes, tools, and the matching projects.</p>
        <div class="area-grid">
          {areas.map((area) => (
            <a href={area.href} class="area-card">
              <div class="card-top">
                <div class="icon-tile"><area.icon size={24} /></div>
                <span class="proof-chip">{area.proof}</span>
              </div>
              <h3>{area.title}</h3>
              <p class="tagline">{area.tagline}</p>
              <ul class="tick-list">
                {area.ticks.map((tick) => (
                  <li><Check size={15} /><span>{tick}</span></li>
                ))}
              </ul>
              <div class="card-bottom">
                <span class="card-link">See what we automate</span>
                <span class="go"><ArrowRight size={16} /></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="hub-proof">
      <div class="container">
        <h2 class="section-title">Grounded in documented projects.</h2>
        <p class="section-sub">What these areas delivered in real projects — every number links to the full case study.</p>
        <div class="proof-grid">
          {proofs.map((proof) => (
            <a href={proof.href} class="proof-card">
              <span class="proof-area">{proof.area}</span>
              <div class="proof-value">{proof.value}<span class="proof-unit"> {proof.unit}</span></div>
              <p>{proof.label}</p>
              <span class="proof-link">Read the case study <ArrowRight size={14} /></span>
            </a>
          ))}
        </div>
        <p class="proof-note">Published estimates — assumptions and details are in each case study.</p>
      </div>
    </section>

    <section class="hub-method">
      <div class="container">
        <h2 class="section-title">The same path in every area.</h2>
        <div class="stage-grid">
          {stages.map((stage) => (
            <div class="stage-col">
              <span class:list={['stage-pill', stage.cls]}>{stage.name}</span>
              <p>{stage.text}</p>
            </div>
          ))}
        </div>
        <div class="method-links">
          <a href="/en/method/">The eFlury Method in detail <ArrowRight size={14} /></a>
          <a href="/en/services/">See all 7 services <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="hub-cta">
      <div class="container">
        <div class="cta-band">
          <h2>Your industry isn't listed? Your process probably is.</h2>
          <p>Most SME processes look alike across industries. Tell us in 30 minutes where your time leaks — and we'll tell you honestly whether automation is worth it.</p>
          <a href="/en/contact/" class="cta-button">
            Book a free strategy call
            <ArrowRight size={18} />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hub-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .hub-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .hub-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.6rem, 3.5vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
  }

  .section-sub {
    text-align: center;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto 2.25rem;
  }

  /* Area cards */
  .hub-areas {
    padding: var(--spacing-2xl) 0 var(--spacing-2xl);
    background: var(--bg-secondary);
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .area-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.7rem;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .area-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
    flex-shrink: 0;
  }

  .proof-chip {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    padding: 0.28rem 0.7rem;
    white-space: nowrap;
  }

  .area-card h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
  }

  .tagline {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
  }

  .tick-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-grow: 1;
  }

  .tick-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--text-primary);
  }

  .tick-list li :global(svg) {
    color: var(--teal-text);
    flex-shrink: 0;
    margin-top: 0.18rem;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  .card-link {
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .go {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    color: var(--teal-text);
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .area-card:hover .go {
    background: var(--action-teal);
    color: #fff;
  }

  /* Proof strip */
  .hub-proof {
    padding: var(--spacing-2xl) 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
  }

  .proof-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.7rem;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .proof-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .proof-area {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-text);
    margin-bottom: 0.6rem;
  }

  .proof-value {
    font-size: 2.1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }

  .proof-unit {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .proof-card p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .proof-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .proof-note {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  /* Method band */
  .hub-method {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .stage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-lg);
  }

  .stage-col {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.6rem;
  }

  .stage-pill {
    display: inline-block;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.75rem;
  }

  .stage-pill.navy { background: var(--surface-navy); }
  .stage-pill.teal { background: var(--action-teal); }
  .stage-pill.blue { background: var(--eflury-blue-mid); }

  .stage-col p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .method-links {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .method-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }

  .method-links a:hover {
    text-decoration: underline;
  }

  /* CTA */
  .hub-cta {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
  }

  .cta-band {
    text-align: center;
    background: var(--surface-navy);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
  }

  .cta-band h2 {
    color: #fff;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .cta-band p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 560px;
    margin: 0 auto 1.75rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    padding: 0.95rem 1.9rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-button:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hub-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .hub-hero .lead {
      font-size: 1.05rem;
    }

    .method-links {
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }
  }
</style>
