---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight } from 'lucide-astro';

const lang = 'en';

const industries = [
  {
    title: 'Treuhand & Accounting',
    text: 'Client onboarding, accounts payable, email triage, and master data — automated with human review gates, tested in a real Swiss practice.',
    href: '/en/industries/treuhand-accounting/',
  },
];
---

<MainLayout
  title="Industries - eFlury Consulting"
  description="Who we build AI automation for: fiduciary and accounting firms, finance teams, and professional services — grounded in documented projects."
  keywords="AI automation industries, Treuhand AI, finance team automation, professional services AI, Swiss SME"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Industries' }]} />

  <main class="industries-page">
    <section class="hub-hero">
      <div class="container">
        <h1>Industries</h1>
        <p class="lead">
          Automation only works when it speaks the language of your daily business.
          These pages show what we build per sector — grounded in the projects and
          articles already documented on this site.
        </p>
      </div>
    </section>

    <section class="hub-grid">
      <div class="container">
        <div class="card-grid">
          {industries.map((item) => (
            <a href={item.href} class="industry-card">
              <h2>{item.title}</h2>
              <p>{item.text}</p>
              <span class="card-link">View industry page <ArrowRight size={14} /></span>
            </a>
          ))}
        </div>
        <p class="more-note">
          Pages for finance teams and professional services are in preparation —
          the underlying services are available today via the <a href="/en/services/">services overview</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hub-hero {
    padding: var(--spacing-4xl) 0 var(--spacing-2xl);
    background: var(--bg-primary);
  }

  .hub-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .hub-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
  }

  .hub-grid {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-secondary);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-lg);
  }

  .industry-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .industry-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .industry-card h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .industry-card p {
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-md);
    flex-grow: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--primary-light);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .more-note {
    margin-top: var(--spacing-xl);
    font-size: 0.9rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  .more-note a {
    display: inline-flex;
    align-items: center;
    color: var(--primary-light);
    text-decoration: none;
  }

  .more-note a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hub-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .hub-hero .lead {
      font-size: 1.05rem;
    }
  }
</style>
