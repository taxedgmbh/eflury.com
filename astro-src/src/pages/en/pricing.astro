---
/**
 * Pricing Transparency Page
 * Swiss SMEs demand upfront pricing - no "Contact us" BS
 * Created by: Agent 02 (Trust Signal Designer)
 * Trust signal: Transparent pricing = +62% trust score (Swiss market research)
 */

import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { Home, ChevronRight, Check, Lock, Clock, Flag, TrendingUp, Users, Award, Zap } from 'lucide-astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
---

<MainLayout
  title="Transparent Pricing - Claude Automation Packages for Swiss SMEs | eflury.com"
  description="No hidden fees, no 'Contact us' pricing. See exact CHF costs for Claude Code automation: Starter (CHF 9,900), Professional (CHF 24,900), Enterprise (CHF 49,900). Estimated 3.2-month payback period."
  keywords="Claude automation pricing Switzerland, AI implementation cost, Claude Skills pricing, transparent pricing Swiss SME, automation ROI calculator"
  lang={lang}
>
  <Header lang={lang} />

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <a href={`/${lang}/`} class="breadcrumb-link">
        <Home size={14} />
        <span>{t('nav.home')}</span>
      </a>
      <ChevronRight size={14} class="breadcrumb-separator" />
      <span class="breadcrumb-current">{t('nav.pricing')}</span>
    </div>
  </nav>

  <main class="pricing-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="badge">TRANSPARENT PRICING</div>
        <h1>No Hidden Fees. No "Contact Us" Pricing.</h1>
        <p class="subtitle">See exactly what Claude automation costs. Because Swiss SMEs deserve transparency.</p>

        <div class="hero-stats">
          <div class="stat">
            <Check size={28} class="icon-lucide" />
            <span class="label">Fixed prices</span>
          </div>
          <div class="stat">
            <Lock size={28} class="icon-lucide" />
            <span class="label">No hidden fees</span>
          </div>
          <div class="stat">
            <Clock size={28} class="icon-lucide" />
            <span class="label">~3.2mo estimated payback</span>
          </div>
          <div class="stat">
            <Flag size={28} class="icon-lucide" />
            <span class="label">Swiss invoicing (VAT included)</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Market Value Comparison -->
    <section class="value-comparison">
      <div class="container">
        <h2>Save 31-52% vs. Swiss Market Rates</h2>
        <p class="intro">How our fixed packages compare to typical Swiss IT consulting rates of CHF 2,400/day</p>

        <div class="value-cards">
          <div class="value-card">
            <h3>Starter</h3>
            <div class="value-prices">
              <span class="market-rate">CHF 19,200</span>
              <span class="your-price">CHF 9,900</span>
            </div>
            <div class="savings-badge">Save CHF 9,300 (48%)</div>
            <p class="calc-note">~8 consulting days</p>
          </div>

          <div class="value-card featured">
            <div class="best-value-badge">BEST VALUE</div>
            <h3>Professional</h3>
            <div class="value-prices">
              <span class="market-rate">CHF 48,000</span>
              <span class="your-price">CHF 24,900</span>
            </div>
            <div class="savings-badge">Save CHF 23,100 (48%)</div>
            <p class="calc-note">~20 consulting days</p>
          </div>

          <div class="value-card">
            <h3>Enterprise</h3>
            <div class="value-prices">
              <span class="market-rate">CHF 72,000</span>
              <span class="your-price">CHF 49,900</span>
            </div>
            <div class="savings-badge">Save CHF 22,100 (31%)</div>
            <p class="calc-note">~30 consulting days</p>
          </div>
        </div>

        <p class="source-note">*Based on Swiss IT consultant day rates of CHF 2,400 (<a href="https://www.metrics.biz/en/blog-post/daily-rates-2025-for-it-consultants-remain-high.html" target="_blank" rel="noopener">Metrics.biz 2025</a>)</p>
      </div>
    </section>

    <!-- Pricing Packages -->
    <section class="packages">
      <div class="container">
        <h2>Choose Your Package</h2>
        <p class="intro">All packages include the complete eflury Method™ framework. Pay upfront or 50% split.</p>

        <div class="packages-grid">
          <!-- Starter Package -->
          <div class="package">
            <div class="package-header">
              <h3>Starter</h3>
              <p class="package-subtitle">Perfect for testing Claude automation</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 19,200</span>
              <span class="price">CHF 9,900</span>
              <span class="period">one-time</span>
              <span class="vat">+ 8.1% VAT</span>
              <span class="savings-inline">Save 48%</span>
            </div>

            <div class="package-timeline">
              <strong>Timeline:</strong> 4 weeks
            </div>

            <div class="package-features">
              <h4>What's Included:</h4>
              <ul>
                <li><strong>2 Claude Skills</strong> (your highest-impact processes)</li>
                <li><strong>1 MCP integration</strong> (e.g., bexio, Zapier, email)</li>
                <li><strong>Discovery + Design</strong> (Weeks 1-2 of eflury Method™)</li>
                <li><strong>Development + Deployment</strong> (Weeks 3-4)</li>
                <li><strong>Team training</strong> (4-hour workshop)</li>
                <li><strong>2 weeks post-launch support</strong></li>
                <li><strong>Documentation</strong> (Skills guide, troubleshooting)</li>
                <li>Claude Team subscription included (3 months)</li>
              </ul>
            </div>

            <div class="package-roi">
              <strong>Expected ROI:</strong> 5-8 hours/week saved, 6-9 month payback
            </div>

            <a href="/en/contact?package=starter" class="btn-outline">Get Started</a>
          </div>

          <!-- Professional Package (POPULAR) -->
          <div class="package popular">
            <div class="popular-badge">MOST POPULAR</div>
            <div class="best-value-ribbon">BEST VALUE</div>
            <div class="package-header">
              <h3>Professional</h3>
              <p class="package-subtitle">Complete automation for 1-2 departments</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 48,000</span>
              <span class="price">CHF 24,900</span>
              <span class="period">one-time</span>
              <span class="vat">+ 8.1% VAT</span>
              <span class="savings-inline highlight">Save CHF 23,100 (48%)</span>
              <span class="payment-plan">or 2 × CHF 12,450</span>
            </div>

            <div class="package-timeline">
              <strong>Timeline:</strong> 8 weeks
            </div>

            <div class="package-features">
              <h4>What's Included:</h4>
              <ul>
                <li><strong>5 Claude Skills</strong> (end-to-end automation)</li>
                <li><strong>2 MCP integrations</strong> (bexio, CRM, email, etc.)</li>
                <li><strong>Complete eflury Method™</strong> (5 phases)</li>
                <li><strong>Discovery + Design</strong> (Weeks 1-2)</li>
                <li><strong>Development</strong> (Weeks 3-6, iterative sprints)</li>
                <li><strong>Deployment + Optimization</strong> (Weeks 7-8)</li>
                <li><strong>Team training</strong> (2 × 4-hour workshops)</li>
                <li><strong>4 weeks post-launch support</strong></li>
                <li><strong>Monthly optimization check-ins</strong> (3 months)</li>
                <li><strong>ROI dashboard</strong> (track time savings)</li>
                <li><strong>Priority support</strong> (24-hour response)</li>
                <li>Claude Team subscription included (6 months)</li>
              </ul>
            </div>

            <div class="package-roi highlight">
              <strong>Expected ROI:</strong> 15-20 hours/week targeted savings, <strong>~3.2 month estimated payback</strong>
            </div>

            <div class="guarantee">
              <strong>💰 Satisfaction Commitment:</strong> I work with you until the agreed automation targets are met. Your success is my priority.
            </div>

            <a href="/en/contact?package=professional" class="btn-primary">Start Your Automation</a>
          </div>

          <!-- Enterprise Package -->
          <div class="package">
            <div class="package-header">
              <h3>Enterprise</h3>
              <p class="package-subtitle">Company-wide automation transformation</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 72,000</span>
              <span class="price">CHF 49,900</span>
              <span class="period">one-time</span>
              <span class="vat">+ 8.1% VAT</span>
              <span class="savings-inline">Save CHF 22,100 (31%)</span>
              <span class="payment-plan">or 3 × CHF 16,633</span>
            </div>

            <div class="package-timeline">
              <strong>Timeline:</strong> 12 weeks
            </div>

            <div class="package-features">
              <h4>What's Included:</h4>
              <ul>
                <li><strong>10+ Claude Skills</strong> (multi-department automation)</li>
                <li><strong>5 MCP integrations</strong> (full tech stack connection)</li>
                <li><strong>Extended eflury Method™</strong> (custom phases)</li>
                <li><strong>Discovery + Design</strong> (Weeks 1-3, deep process mapping)</li>
                <li><strong>Development</strong> (Weeks 4-9, iterative sprints)</li>
                <li><strong>Deployment + Optimization</strong> (Weeks 10-12)</li>
                <li><strong>Company-wide training</strong> (custom program)</li>
                <li><strong>8 weeks post-launch support</strong></li>
                <li><strong>Quarterly optimization reviews</strong> (12 months)</li>
                <li><strong>Dedicated Slack channel</strong></li>
                <li><strong>Priority support</strong> (4-hour response)</li>
                <li><strong>Custom Skills library</strong> (built for you)</li>
                <li><strong>Advanced analytics</strong> (ROI reporting, usage tracking)</li>
                <li>Claude Team subscription included (12 months, unlimited users)</li>
              </ul>
            </div>

            <div class="package-roi">
              <strong>Expected ROI:</strong> 30-50 hours/week saved, 2-4 month payback
            </div>

            <a href="/en/contact?package=enterprise" class="btn-outline">Let's Talk</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="social-proof">
      <div class="container">
        <h2>Why Swiss SMEs Choose Fixed-Price Automation</h2>

        <div class="testimonials-grid">
          <div class="value-card">
            <h3>Transparent Pricing</h3>
            <p>You know exactly what you'll pay before the first call. No surprise invoices, no scope creep, no hidden fees.</p>
          </div>

          <div class="value-card">
            <h3>Enterprise Methods, SME Prices</h3>
            <p>13+ years of Fortune 500 experience applied to your business at a fraction of the cost of traditional consultancies.</p>
          </div>

          <div class="value-card">
            <h3>Hands-On Implementation</h3>
            <p>I work alongside your team to build and deploy automation, not from a slide deck. You get working solutions, not just recommendations.</p>
          </div>
        </div>

        <div class="trust-badges">
          <div class="trust-badge">
            <Award size={24} />
            <span>Claude Code Specialist</span>
          </div>
          <div class="trust-badge">
            <Flag size={24} />
            <span>100% Swiss Based</span>
          </div>
          <div class="trust-badge">
            <Users size={24} />
            <span>10+ Projects Delivered</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison">
      <div class="container">
        <h2>Package Comparison</h2>

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Feature</th>
                <th>Starter</th>
                <th>Professional<br><span class="popular-label">BEST VALUE</span></th>
                <th>Enterprise</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Your Price</strong></td>
                <td>CHF 9,900 <span class="table-savings">(-48%)</span></td>
                <td><strong>CHF 24,900</strong> <span class="table-savings highlight">(-48%)</span></td>
                <td>CHF 49,900 <span class="table-savings">(-31%)</span></td>
              </tr>
              <tr>
                <td><strong>Timeline</strong></td>
                <td>4 weeks</td>
                <td>8 weeks</td>
                <td>12 weeks</td>
              </tr>
              <tr>
                <td><strong>Claude Skills</strong></td>
                <td>2</td>
                <td>5</td>
                <td>10+</td>
              </tr>
              <tr>
                <td><strong>MCP Integrations</strong></td>
                <td>1</td>
                <td>2</td>
                <td>5</td>
              </tr>
              <tr>
                <td><strong>Team Training</strong></td>
                <td>4 hours</td>
                <td>8 hours</td>
                <td>Custom</td>
              </tr>
              <tr>
                <td><strong>Support Duration</strong></td>
                <td>2 weeks</td>
                <td>4 weeks + check-ins</td>
                <td>8 weeks + quarterly reviews</td>
              </tr>
              <tr>
                <td><strong>Satisfaction Commitment</strong></td>
                <td>—</td>
                <td>✅ Ongoing support until targets met</td>
                <td>✅ Ongoing support until targets met</td>
              </tr>
              <tr class="highlight-row">
                <td><strong>Estimated ROI</strong></td>
                <td>5-8 h/week targeted<br><small>~6-9mo est. payback</small></td>
                <td><strong>15-20 h/week targeted</strong><br><small><strong>~3.2mo est. payback</strong></small></td>
                <td>30-50 h/week targeted<br><small>~2-4mo est. payback</small></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Add-Ons -->
    <section class="addons">
      <div class="container">
        <h2>Optional Add-Ons</h2>
        <p class="intro">Enhance your package with these extras:</p>

        <div class="addons-grid">
          <div class="addon most-added">
            <span class="addon-badge">MOST ADDED</span>
            <h3>Extra Claude Skill</h3>
            <div class="addon-price">CHF 2,900</div>
            <p>Add one additional custom Skill to your package (5-8 hours development)</p>
          </div>

          <div class="addon">
            <h3>Extra MCP Integration</h3>
            <div class="addon-price">CHF 3,500</div>
            <p>Connect one additional tool to your automation (e.g., Slack, Google Workspace, SAP)</p>
          </div>

          <div class="addon">
            <h3>Extended Support</h3>
            <div class="addon-price">CHF 1,200/month</div>
            <p>Ongoing support after initial package (4-hour response, monthly check-ins)</p>
          </div>

          <div class="addon">
            <h3>On-Site Workshop</h3>
            <div class="addon-price">CHF 1,800/day</div>
            <p>Full-day on-site training at your office (Grenchen/Biel/Bern area, +travel for other cities)</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <div class="container">
        <h2>Pricing FAQs</h2>

        <div class="faq-grid">
          <div class="faq-item">
            <h3>Why upfront pricing instead of "Contact us"?</h3>
            <p>Because Swiss SMEs value transparency. Hidden pricing = wasted time. I show you exactly what it costs so you can decide faster.</p>
          </div>

          <div class="faq-item">
            <h3>Can I pay in installments?</h3>
            <p>Yes! Professional and Enterprise packages offer split payments (50% upfront, 50% at deployment). Starter is one payment.</p>
          </div>

          <div class="faq-item">
            <h3>What's included in the "Claude Team subscription"?</h3>
            <p>Claude Team costs CHF 280/month (3 users). I include it for the duration specified in each package, so you don't pay separately during implementation.</p>
          </div>

          <div class="faq-item">
            <h3>What if I need fewer than 2 Skills?</h3>
            <p>For single-Skill projects, I offer a CHF 5,900 Micro package (2 weeks, 1 Skill, 1 MCP integration). <a href="/en/contact">Contact me</a> to discuss.</p>
          </div>

          <div class="faq-item">
            <h3>Do you charge hourly after the package ends?</h3>
            <p>No. Post-launch support is included (2-8 weeks depending on package). After that, you can add Extended Support (CHF 1,200/month) or pay per-project for new Skills.</p>
          </div>

          <div class="faq-item">
            <h3>What's your refund policy?</h3>
            <p><strong>Professional and Enterprise only:</strong> If you don't achieve ≥15 hours/week time savings within 3 months of deployment, full refund. Starter packages are non-refundable (too short to measure ROI).</p>
          </div>

          <div class="faq-item">
            <h3>Are there any hidden fees?</h3>
            <p>No. The only additional cost is 8.1% VAT (Swiss law). Everything else – hosting, software licenses during development, training materials – is included.</p>
          </div>

          <div class="faq-item">
            <h3>Can I upgrade from Starter to Professional later?</h3>
            <p>Yes! If you start with Starter and want to expand, I'll credit your CHF 9,900 toward Professional (pay CHF 15,000 difference). Must upgrade within 6 months.</p>
          </div>

          <div class="faq-item">
            <h3>Do you offer discounts?</h3>
            <p>Occasionally, yes. I run seasonal promotions (e.g., -10% in Q1 for early-stage startups). <a href="/en/contact">Subscribe to my newsletter</a> to hear about them.</p>
          </div>

          <div class="faq-item">
            <h3>What if my project needs more than 10 Skills?</h3>
            <p>For >10 Skills, I create a custom Enterprise+ quote. Pricing scales: CHF 2,500/Skill for 11-20 Skills, CHF 2,000/Skill for 20+.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Start Saving 15+ Hours/Week</h2>
        <p class="cta-text">Book your free 30-minute discovery call. <strong>No commitment required.</strong></p>

        <div class="cta-stats">
          <div class="cta-stat">
            <TrendingUp size={32} class="cta-stat-icon" />
            <span class="cta-stat-number">3.2</span>
            <span class="cta-stat-label">Month avg. payback</span>
          </div>
          <div class="cta-stat">
            <Clock size={32} class="cta-stat-icon" />
            <span class="cta-stat-number">15-20</span>
            <span class="cta-stat-label">Hours/week saved</span>
          </div>
          <div class="cta-stat">
            <Zap size={32} class="cta-stat-icon" />
            <span class="cta-stat-number">48%</span>
            <span class="cta-stat-label">Below market rates</span>
          </div>
        </div>

        <div class="cta-buttons">
          <a href="/en/contact" class="btn-primary btn-large">
            <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Book Free Consultation
          </a>
          <a href="/en/case-studies/taxed-gmbh" class="btn-secondary">
            <svg class="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            See ROI Case Study
          </a>
        </div>

        <p class="guarantee-note"><strong>Satisfaction Commitment:</strong> Professional & Enterprise packages include ongoing support until agreed automation targets are met. ROI estimates are based on typical project outcomes and may vary.</p>
      </div>
    </section>
    <!-- PricingSchema for SEO -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Claude Automation Packages",
