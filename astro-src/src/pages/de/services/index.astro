---
import MainLayout from '../../../layouts/MainLayout.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import LifecycleOrbitIllustration from '../../../components/illustrations/LifecycleOrbitIllustration.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, FileText, Cpu, Server, Calculator, BarChart3, Database, ClipboardCheck, Activity } from 'lucide-astro';

const lang = 'de';

// BUILD-stage services (ADVISE and RUN are rendered as feature rows)
const buildServices = [
  { icon: Cpu, title: "Claude Skills Entwicklung", desc: "Massgeschneiderte Claude Skills für Ihre spezifischen Workflows. Automatisieren Sie repetitive Aufgaben mit KI, die Ihr Geschäft versteht.", link: "/de/services/claude-skills/", badge: null, metric: "Kernbaustein jedes Pakets" },
  { icon: Server, title: "MCP Server Integration", desc: "Verbinden Sie Claude mit Ihren Geschäftssystemen über Model Context Protocol — Datenbanken, APIs und Unternehmenssoftware.", link: "/de/services/mcp-integration/", badge: null, metric: "bexio · Datenbanken · Microsoft 365" },
  { icon: Calculator, title: "Finanzprozess-Automatisierung", desc: "Monatsabschluss, Reporting und Abstimmungen automatisieren — KI-gestützt, mit bexio- und ABACUS-Integration.", link: "/de/services/finanzen-automatisierung/", badge: null, metric: "Monatsabschluss · Kreditoren · Reporting" },
  { icon: BarChart3, title: "Power BI Beratung", desc: "Individuelle Power BI Dashboards und Reports — von der Datenmodellierung bis zum Executive Dashboard.", link: "/de/services/power-bi/", badge: null, metric: "Dashboards · Excel-Migration" },
  { icon: Database, title: "Datenqualität mit Agentic AI", desc: "KI-Agenten, die Ihre Geschäftsdaten profilieren, bereinigen und überwachen — mit eingebauter menschlicher Kontrolle.", link: "/de/services/datenqualitaet/", badge: "Neu", metric: "Inklusive Live-Demo" },
];
---

<MainLayout
  title="Leistungen - KI-Automatisierung für Schweizer KMU | eflury.com"
  description="Sieben Leistungen entlang des Lebenszyklus Advise · Build · Run: KI-Audit, Claude Skills, MCP-Integration, Finanzautomatisierung, Power BI, Datenqualität und Managed AI Operations — mit Fixpreisen."
  keywords="Claude Skills, MCP Integration, Finanzautomatisierung, Power BI Beratung, KI-Audit, Schweizer KI-Services"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Leistungen" }]} />

  <main class="services-page">
    <section class="page-hero">
      <div class="container">
        <span class="hero-badge">7 Leistungen · Fixpreise · Ein Lebenszyklus</span>
        <h1 class="page-title">Leistungen.</h1>
        <p class="page-lead">Jede Leistung hat ihren Platz im Lebenszyklus: Wir beraten, bevor wir bauen — und betreiben, was wir gebaut haben.</p>
      </div>
    </section>

    <IllustrationShowcase>
      <LifecycleOrbitIllustration />
    </IllustrationShowcase>

    <section class="offer">
      <div class="container">

        <!-- ADVISE -->
        <div class="stage-head">
          <span class="stage-pill navy">Advise</span>
          <span class="stage-line">Verstehen & priorisieren</span>
        </div>
        <a href="/de/services/ki-audit/" class="feature-card">
          <div class="icon-tile"><ClipboardCheck size={26} /></div>
          <div class="feature-body">
            <div class="feature-top">
              <h2>KI-Audit</h2>
              <span class="start-badge">Hier starten</span>
            </div>
            <p>Eine Woche, Fixpreis: Prozessinventar mit Zeitkosten-Scoring, priorisierte Roadmap und ROI-Projektion pro Initiative — mit ehrlichem Go/No-Go am Ende.</p>
            <div class="feature-meta">
              <span class="metric">CHF 4'900 · voll angerechnet</span>
              <span class="sample-link"><FileText size={14} /> Musterbericht ansehen (PDF)</span>
            </div>
          </div>
          <span class="go"><ArrowRight size={18} /></span>
        </a>

        <!-- BUILD -->
        <div class="stage-head">
          <span class="stage-pill teal">Build</span>
          <span class="stage-line">Bauen & einführen</span>
        </div>
        <div class="services-grid">
          {buildServices.map((service) => (
            <a href={service.link} class="service-card">
              <div class="card-top">
                <div class="icon-tile"><service.icon size={24} /></div>
                {service.badge && <span class="new-badge">{service.badge}</span>}
              </div>
              <h2>{service.title}</h2>
              <p>{service.desc}</p>
              <div class="card-bottom">
                <span class="metric">{service.metric}</span>
                <span class="go"><ArrowRight size={16} /></span>
              </div>
            </a>
          ))}
        </div>

        <!-- RUN -->
        <div class="stage-head">
          <span class="stage-pill blue">Run</span>
          <span class="stage-line">Betreiben & verbessern</span>
        </div>
        <a href="/de/services/ki-betrieb/" class="feature-card">
          <div class="icon-tile"><Activity size={26} /></div>
          <div class="feature-body">
            <div class="feature-top">
              <h2>Managed AI Operations</h2>
            </div>
            <p>Wir betreiben, was wir bauen: Monitoring, monatlicher Kennzahlenbericht, Verbesserungs-Backlog und Re-Validierung nach Plattform-Updates.</p>
            <div class="feature-meta">
              <span class="metric">Ab CHF 1'200/Monat</span>
            </div>
          </div>
          <span class="go"><ArrowRight size={18} /></span>
        </a>

        <h2 class="explore-title">Mehr entdecken</h2>
        <div class="explore-grid">
          <a href="/de/pricing/" class="explore-card">
            <h3>Preise & Pakete</h3>
            <p>Transparente Festpreise — vom Micro-Projekt bis zum Enterprise-Paket.</p>
          </a>
          <a href="/de/skopaai/" class="explore-card">
            <h3>SkopaAI <span class="badge-new">Neu</span></h3>
            <p>Vorkonfigurierter Mac mini mit KI-Assistent. Auspacken, anschliessen, loslegen.</p>
          </a>
          <a href="/de/case-studies/" class="explore-card">
            <h3>Referenzen</h3>
            <p>Echte Projekte, messbare Resultate — inklusive der Taxed GmbH Fallstudie.</p>
          </a>
        </div>

        <section class="cta-section">
          <h2>Nicht sicher, welche Leistung passt?</h2>
          <p>Buchen Sie ein kostenloses 30-Minuten-Strategiegespräch. Wir analysieren Ihre Workflows und empfehlen den richtigen Ansatz.</p>
          <a href="/de/kontakt/" class="cta-button">
            Kostenloses Strategiegespräch buchen
            <ArrowRight size={18} />
          </a>
        </section>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-hero {
    padding: 3.5rem 0 3rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .page-lead {
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .offer {
    padding: 1rem 0 4rem;
  }

  .stage-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin: 3rem 0 1.25rem;
  }

  .stage-pill {
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
  }

  .stage-pill.navy { background: var(--surface-navy); }
  .stage-pill.teal { background: var(--action-teal); }
  .stage-pill.blue { background: var(--eflury-blue-mid); }

  .stage-line {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* Feature rows (Advise / Run) */
  .feature-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .feature-body {
    flex: 1;
    min-width: 0;
  }

  .feature-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .feature-card h2 {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .start-badge {
    background: var(--action-teal);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.28rem 0.7rem;
    border-radius: var(--radius-full);
  }

  .feature-card p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 0.85rem;
  }

  .feature-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .metric {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--teal-text);
  }

  .sample-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--link-color);
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
    flex-shrink: 0;
  }

  .go {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    color: var(--teal-text);
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .feature-card:hover .go,
  .service-card:hover .go {
    background: var(--action-teal);
    color: #fff;
  }

  /* Build grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .card-top .icon-tile {
    width: 46px;
    height: 46px;
  }

  .new-badge {
    background: var(--surface-navy);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.26rem 0.65rem;
    border-radius: var(--radius-full);
  }

  .service-card h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .service-card p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
    flex: 1;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--border-color);
    padding-top: 0.9rem;
  }

  .card-bottom .go {
    width: 32px;
    height: 32px;
  }

  /* Explore */
  .explore-title {
    text-align: center;
    font-size: 1.35rem;
    color: var(--text-primary);
    margin: 3.5rem 0 1.25rem;
  }

  .explore-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .explore-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.6rem;
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .explore-card:hover {
    border-color: var(--eflury-teal);
    transform: translateY(-2px);
  }

  .explore-card h3 {
    font-size: 1.02rem;
    color: var(--text-primary);
    margin: 0 0 0.4rem;
  }

  .explore-card p {
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0;
  }

  .badge-new {
    background: var(--action-teal);
    color: #fff;
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-full);
    vertical-align: middle;
    margin-left: 0.35rem;
  }

  /* CTA */
  .cta-section {
    margin-top: 3.5rem;
    text-align: center;
    background: var(--surface-navy);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
  }

  .cta-section h2 {
    color: #fff;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .cta-section p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    padding: 0.95rem 1.9rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-button:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .feature-card {
      flex-direction: column;
      align-items: flex-start;
    }

    .feature-card .go {
      display: none;
    }
  }
</style>
