    background: white;
    padding: 2rem;
    border-radius: 1rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .expertise-box.do {
    border-top: 4px solid var(--success-500);
  }

  .expertise-box.dont {
    border-top: 4px solid var(--error-500);
