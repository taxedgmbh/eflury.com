<script>
  // GSAP counter animation for impact stats
  if (typeof window !== 'undefined') {
    import('gsap').then(({ gsap }) => {
      import('gsap/ScrollTrigger').then(({ ScrollTrigger }) => {
        gsap.registerPlugin(ScrollTrigger);

        const counters = document.querySelectorAll('.stat-item .stat-value');

        counters.forEach((counter) => {
          const target = parseFloat(counter.getAttribute('data-target') || '0');
          const suffix = counter.getAttribute('data-suffix') || '';

          gsap.fromTo(
            { value: 0 },
            {
              value: target,
              duration: 2,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: counter.closest('.stat-item'),
                start: 'top 80%',
                toggleActions: 'play none none reverse',
              },
              onUpdate: function() {
                const val = this.targets()[0].value;
                counter.textContent = Math.round(val) + suffix;
              },
            }
          );
        });
      });
    });
  }
</script>
