---
/**
 * Preistransparenz-Seite
 * Schweizer KMU verlangen Vorabpreise - kein "Kontaktieren Sie uns" BS
 * Erstellt von: Agent 02 (Trust Signal Designer)
 * Vertrauenssignal: Transparente Preise = +62% Vertrauens-Score (Schweizer Marktforschung)
 */

import MainLayout from '../../layouts/MainLayout.astro';
import CreditMathVisual from '../../components/illustrations/CreditMathVisual.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { Home, ChevronRight, Check, Lock, Clock, Flag, TrendingUp, Users, Award, Zap } from 'lucide-astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);
---

<MainLayout
  title="Transparente Preise - Claude-Automatisierungs-Pakete für Schweizer KMU | eflury.com"
  description="Keine versteckten Gebühren, keine «Kontaktieren Sie uns»-Preise. Exakte CHF-Kosten für Claude-Code-Automatisierung: Starter (CHF 9'900), Professional (CHF 24'900), Enterprise (CHF 49'900). Geschätzte 3.2 Monate Amortisation."
  keywords="Claude Automatisierung Preise Schweiz, KI Implementierung Kosten, Claude Skills Preise, transparente Preise Schweizer KMU, Automatisierung ROI Rechner"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: t('nav.pricing') }]} />

  <main class="pricing-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="badge">TRANSPARENTE PREISE</div>
        <h1>Keine versteckten Gebühren. Keine "Kontaktieren Sie uns"-Preise.</h1>
        <p class="subtitle">Sehen Sie genau, was Claude-Automatisierung kostet. Weil Schweizer KMU Transparenz verdienen.</p>

        <div class="hero-stats">
          <div class="stat">
            <Check size={28} class="icon-lucide" />
            <span class="label">Fixpreise</span>
          </div>
          <div class="stat">
            <Lock size={28} class="icon-lucide" />
            <span class="label">Keine versteckten Gebühren</span>
          </div>
          <div class="stat">
            <Clock size={28} class="icon-lucide" />
            <span class="label">~3,2 Mo geschätzte Amortisation</span>
          </div>
          <div class="stat">
            <Flag size={28} class="icon-lucide" />
            <span class="label">Schweizer Rechnung in CHF</span>
          </div>
        </div>
      </div>
    </section>


    <!-- Pricing Packages -->
    <section class="packages">
      <div class="container">
        <h2>Wählen Sie Ihr Paket</h2>
        <p class="intro">Alle Pakete beinhalten das komplette eflury Method™-Framework. Vorauszahlung oder 50% Teilzahlung.</p>

        <div class="packages-grid">
          <!-- Starter Package -->
          <div class="package">
            <div class="package-header">
              <h3>Starter</h3>
              <p class="package-subtitle">Perfekt zum Testen der Claude-Automatisierung</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 19'200</span>
              <span class="price">CHF 9'900</span>
              <span class="period">einmalig</span>
              <span class="vat">+ 8,1% MWST</span>
              <span class="savings-inline">48% sparen</span>
            </div>

            <div class="package-timeline">
              <strong>Zeitrahmen:</strong> 4 Wochen
            </div>

            <div class="package-features">
              <h4>Was enthalten ist:</h4>
              <ul>
                <li><strong>2 Claude Skills</strong> (Ihre impact-stärksten Prozesse)</li>
                <li><strong>1 MCP-Integration</strong> (z.B. bexio, Zapier, E-Mail)</li>
                <li><strong>Discovery + Design</strong> (Wochen 1-2 der eflury Method™)</li>
                <li><strong>Development + Deployment</strong> (Wochen 3-4)</li>
                <li><strong>Team-Training</strong> (4-Stunden-Workshop)</li>
                <li><strong>2 Wochen Post-Launch-Support</strong></li>
                <li><strong>Dokumentation</strong> (Skills-Guide, Troubleshooting)</li>
                <li>Claude Team-Abo inklusive (3 Monate)</li>
              </ul>
            </div>

            <div class="package-roi">
              <strong>Erwarteter ROI:</strong> 5-8 Std/Woche gespart, 6-9 Monate Amortisation
            </div>

            <a href="/de/kontakt/" class="btn-outline">Loslegen</a>
          </div>

          <!-- Professional Package (POPULAR) -->
          <div class="package popular">
            <div class="popular-badge">AM BELIEBTESTEN</div>
            <div class="best-value-ribbon">BESTER WERT</div>
            <div class="package-header">
              <h3>Professional</h3>
              <p class="package-subtitle">Komplette Automatisierung für 1-2 Abteilungen</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 48'000</span>
              <span class="price">CHF 24'900</span>
              <span class="period">einmalig</span>
              <span class="vat">+ 8,1% MWST</span>
              <span class="savings-inline highlight">CHF 23'100 sparen (48%)</span>
              <span class="payment-plan">oder 2 × CHF 12'450</span>
            </div>

            <div class="package-timeline">
              <strong>Zeitrahmen:</strong> 8 Wochen
            </div>

            <div class="package-features">
              <h4>Was enthalten ist:</h4>
              <ul>
                <li><strong>5 Claude Skills</strong> (End-to-End-Automatisierung)</li>
                <li><strong>2 MCP-Integrationen</strong> (bexio, CRM, E-Mail, etc.)</li>
                <li><strong>Komplette eflury Method™</strong> (5 Phasen)</li>
                <li><strong>Discovery + Design</strong> (Wochen 1-2)</li>
                <li><strong>Development</strong> (Wochen 3-6, iterative Sprints)</li>
                <li><strong>Deployment + Optimization</strong> (Wochen 7-8)</li>
                <li><strong>Team-Training</strong> (2 × 4-Stunden-Workshops)</li>
                <li><strong>4 Wochen Post-Launch-Support</strong></li>
                <li><strong>Monatliche Optimierungs-Check-ins</strong> (3 Monate)</li>
                <li><strong>ROI-Dashboard</strong> (Zeiteinsparungen tracken)</li>
                <li><strong>Priority-Support</strong> (24-Stunden-Reaktion)</li>
                <li>Claude Team-Abo inklusive (6 Monate)</li>
              </ul>
            </div>

            <div class="package-roi highlight">
              <strong>Erwarteter ROI:</strong> 15-20 Std/Woche angestrebte Einsparung, <strong>~3,2 Monate geschätzte Amortisation</strong>
            </div>

            <div class="guarantee">
              <strong>Zufriedenheits-Commitment:</strong> Wir arbeiten mit Ihnen, bis die vereinbarten Automatisierungsziele erreicht sind. Ihr Erfolg ist unsere Priorität.
            </div>

            <a href="/de/kontakt/" class="btn-primary">Starten Sie Ihre Automatisierung</a>
          </div>

          <!-- Enterprise Package -->
          <div class="package">
            <div class="package-header">
              <h3>Enterprise</h3>
              <p class="package-subtitle">Unternehmensweite Automatisierungs-Transformation</p>
            </div>

            <div class="package-price">
              <span class="market-rate-strike">CHF 72'000</span>
              <span class="price">CHF 49'900</span>
              <span class="period">einmalig</span>
              <span class="vat">+ 8,1% MWST</span>
              <span class="savings-inline">CHF 22'100 sparen (31%)</span>
              <span class="payment-plan">oder 3 × CHF 16'633</span>
            </div>

            <div class="package-timeline">
              <strong>Zeitrahmen:</strong> 12 Wochen
            </div>

            <div class="package-features">
              <h4>Was enthalten ist:</h4>
              <ul>
                <li><strong>10+ Claude Skills</strong> (Multi-Abteilungs-Automatisierung)</li>
                <li><strong>5 MCP-Integrationen</strong> (vollständige Tech-Stack-Verbindung)</li>
                <li><strong>Erweiterte eflury Method™</strong> (Custom-Phasen)</li>
                <li><strong>Discovery + Design</strong> (Wochen 1-3, tiefes Prozess-Mapping)</li>
                <li><strong>Development</strong> (Wochen 4-9, iterative Sprints)</li>
                <li><strong>Deployment + Optimization</strong> (Wochen 10-12)</li>
                <li><strong>Unternehmensweites Training</strong> (Custom-Programm)</li>
                <li><strong>8 Wochen Post-Launch-Support</strong></li>
                <li><strong>Vierteljährliche Optimierungs-Reviews</strong> (12 Monate)</li>
                <li><strong>Dedizierter Slack-Kanal</strong></li>
                <li><strong>Priority-Support</strong> (4-Stunden-Reaktion)</li>
                <li><strong>Custom Skills-Bibliothek</strong> (für Sie gebaut)</li>
                <li><strong>Advanced Analytics</strong> (ROI-Reporting, Nutzungs-Tracking)</li>
                <li>Claude Team-Abo inklusive (12 Monate, unbegrenzte User)</li>
              </ul>
            </div>

            <div class="package-roi">
              <strong>Erwarteter ROI:</strong> 30-50 Std/Woche gespart, 2-4 Monate Amortisation
            </div>

            <a href="/de/kontakt/" class="btn-outline">Kontaktieren</a>
          </div>
        </div>

        <p class="source-note">*Basierend auf Schweizer IT-Berater-Tagessätzen von CHF 2'400 (<a href="https://www.metrics.biz/en/blog-post/daily-rates-2025-for-it-consultants-remain-high.html" target="_blank" rel="noopener">Metrics.biz 2025</a>)</p>

        <div class="audit-band">
          <p>
            <strong>Unsicher, welches Paket passt?</strong> Starten Sie mit dem
            <a href="/de/services/ki-audit/">KI-Audit</a> — CHF 4'900, eine Woche,
            mit ehrlichem Go/No-Go am Ende. Bei einem Folgeauftrag innert 6 Monaten
            vollständig ans Paket angerechnet.
          </p>
        </div>

        <CreditMathVisual lang="de" />

        <div class="micro-strip">
          <div class="micro-head">
            <span class="micro-tag">Micro</span>
            <span class="micro-price">CHF 5'900</span>
          </div>
          <p>
            Der kleinste Einstieg: 2 Wochen, 1 Claude Skill, 1 MCP-Integration — ideal für einen
            einzelnen, klar umrissenen Prozess. Audit-Anrechnung gilt auch hier; Upgrade auf ein
            grösseres Paket jederzeit möglich.
          </p>
        </div>
      </div>
    </section>

    <!-- Warum uns wählen -->
    <section class="social-proof">
      <div class="container">
        <h2>Warum Schweizer KMU Fixpreis-Automatisierung wählen</h2>

        <div class="testimonials-grid">
          <div class="value-card">
            <h3>Transparente Preise</h3>
            <p>Sie wissen genau, was Sie zahlen, bevor Sie überhaupt anrufen. Keine Überraschungsrechnungen, kein Scope Creep, keine versteckten Gebühren.</p>
          </div>

          <div class="value-card">
            <h3>Enterprise-Methoden, KMU-Preise</h3>
            <p>13+ Jahre Fortune-500-Erfahrung, angewandt auf Ihr Geschäft — zu einem Bruchteil der Kosten traditioneller Beratungsfirmen.</p>
          </div>

          <div class="value-card">
            <h3>Hands-On-Implementierung</h3>
            <p>Wir arbeiten direkt mit Ihrem Team, nicht von einem Foliendeck aus. Sie erhalten funktionierende Lösungen, nicht nur Empfehlungen.</p>
          </div>
        </div>

        <div class="trust-badges">
          <div class="trust-badge">
            <Award size={24} />
            <span>Claude Code Spezialist</span>
          </div>
          <div class="trust-badge">
            <Flag size={24} />
            <span>100% Schweizer Sitz</span>
          </div>
          <div class="trust-badge">
            <Users size={24} />
            <span>10+ Projekte geliefert</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="comparison">
      <div class="container">
        <h2>Paket-Vergleich</h2>

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Feature</th>
