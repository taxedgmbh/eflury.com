---
/**
 * Karriereportal — Initiativbewerbung (DE)
 * Generated by scratchpad/career/gen-career.py — do not hand-edit.
 * Job description centre, application intake right (owner-specified layout).
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { MapPin, Clock, Handshake, ArrowRight, Send } from 'lucide-astro';

const lang = 'de';
---

<MainLayout
  title="Initiativbewerbung — Karriere | eFlury Consulting"
  description="Bewerben Sie sich initiativ bei eFlury Consulting: KI- und Automatisierungs-Engineers, BI-Spezialisten und Finanz-Praktiker für Projekte mit Schweizer KMU. Strukturiertes Formular, persönliche Antwort."
  keywords="Initiativbewerbung eFlury, Jobs KI-Automatisierung Schweiz, Claude MCP Engineer, Power BI Spezialist, Karriere Grenchen"
  lang={lang}
>
  <Header lang={lang} languageSwitchUrl="/en/careers/spontaneous-application/" />

  <Breadcrumbs lang={lang} items={[{ label: 'Karriere', href: '/de/karriere/' }, { label: 'Initiativbewerbung' }]} />

  <main class="job-page">
    <!-- Hero -->
    <section class="job-hero">
      <div class="container">
        <span class="job-badge">Laufend offen</span>
        <h1>Initiativbewerbung</h1>
        <p class="job-sub">Spezialisten-Netzwerk für KI-, BI- und Finanz-Automatisierungsprojekte</p>
        <div class="job-meta">
          <div class="job-meta-item"><span class="jm-label">Standort</span><span class="jm-value">Grenchen SO · Remote (Schweiz)</span></div>
          <div class="job-meta-item"><span class="jm-label">Pensum</span><span class="jm-value">Nach Vereinbarung</span></div>
          <div class="job-meta-item"><span class="jm-label">Zusammenarbeit</span><span class="jm-value">Projektbasiert, Festanstellung möglich</span></div>
        </div>
        <a href="#bewerben" class="btn-apply-mobile">Jetzt bewerben <ArrowRight size={16} /></a>
      </div>
    </section>

    <section class="job-body">
      <div class="container job-grid">
        <!-- Description (centre) -->
        <article class="job-desc">
          <div class="honesty-note">
            <p>Ehrlich gesagt: Es gibt derzeit keine ausgeschriebene Stelle. Wir besetzen Projekte mit Spezialisten, wenn die Nachfrage wächst — und lernen gute Leute lieber kennen, bevor wir sie brauchen. Jede Bewerbung wird persönlich gelesen und beantwortet.</p>
          </div>

          <h2>Wie wir arbeiten</h2>
          <p set:html={`eFlury Consulting baut KI-Automatisierung für Schweizer KMU — Fixpreis-Projekte auf Claude, MCP und Power BI, geführt nach der publizierten <a href="/de/methode/">eflury Method™</a>: benannte Deliverables, Entscheidungs-Gates, Human-in-the-Loop, alles dokumentiert. Kundenprojekte werden von Spezialisten geliefert, die wir mit wachsendem Projektvolumen an Bord holen.`} />

          <h2>Wen wir kennenlernen möchten</h2>
          <ul class="who-list" set:html={`          <li><strong>KI- &amp; Automatisierungs-Engineers</strong> — Sie bauen mit Claude, MCP-Konnektoren und TypeScript oder Python, und Sie können es zeigen (Repos, Projekte, Write-ups).</li>
          <li><strong>BI- &amp; Daten-Spezialisten</strong> — Power-BI-Datenmodellierung, Reporting-Pipelines, Datenqualität.</li>
          <li><strong>Finanz-Praktiker</strong> — Sie kennen Monatsabschlüsse, Fakturierung oder bexio/ABACUS von innen und wollen sie lieber automatisieren als erdulden.</li>`} />
          <p>Unsere Kunden sind Schweizer KMU; Arbeitssprachen sind Deutsch und Englisch.</p>

          <h2>Was Sie erwarten können</h2>
          <p set:html={`Dieselben Prinzipien, die wir Kunden publizieren, gelten intern: Entscheidungen schriftlich, Dokumentation als Teil der Arbeit, fixe Scopes statt Heldentaten — und ehrliche No-Gos, wenn etwas nicht passt. Lesen Sie die <a href="/de/methode/">Methode</a> und die <a href="/de/sicherheit/">Vertrauensseite</a> — das ist die Arbeitskultur, publiziert.`} />

          <h2>So läuft es ab</h2>
          <ol class="process-steps">
          <li>
            <span class="step-num">1</span>
            <div>
              <h3>Bewerbung</h3>
              <p>Formular ausfüllen — Links schlagen Adjektive: Repos und Projekte sagen mehr als jedes Motivationsschreiben.</p>
            </div>
          </li>
          <li>
            <span class="step-num">2</span>
            <div>
              <h3>Persönliche Antwort</h3>
              <p>Jede Bewerbung liest und beantwortet die Person, die mit Ihnen arbeiten würde — kein System, kein Textbaustein.</p>
            </div>
          </li>
          <li>
            <span class="step-num">3</span>
            <div>
              <h3>Kennenlern-Gespräch</h3>
              <p>Passt das Profil zu kommenden Projekten, folgt ein unkompliziertes Gespräch (30–45 Min., remote).</p>
            </div>
          </li>
          <li>
            <span class="step-num">4</span>
            <div>
              <h3>Projekt-Pool</h3>
              <p>Passt es, nehmen wir Sie in den Spezialisten-Pool auf und melden uns, sobald ein konkretes Projekt ansteht.</p>
            </div>
          </li>
          </ol>

          <p class="alt-apply" set:html={`Lieber per E-Mail? <a href="mailto:me@eflury.com?subject=Initiativbewerbung">me@eflury.com</a> mit Betreff «Initiativbewerbung».`} />
        </article>

        <!-- Application form (right) -->
        <aside class="job-apply" id="bewerben">
          <form class="apply-form" id="applyForm" novalidate data-endpoint="/api/apply.php" data-job="Initiativbewerbung">
            <h2>Für diesen Job bewerben</h2>

            <fieldset>
              <legend>Persönliche Informationen</legend>
              <div class="af-row-2">
                <div class="af-field">
                  <label for="af-vorname">Vorname <em>*</em></label>
                  <input type="text" id="af-vorname" name="vorname" required autocomplete="given-name" />
                </div>
                <div class="af-field">
                  <label for="af-nachname">Nachname <em>*</em></label>
                  <input type="text" id="af-nachname" name="nachname" required autocomplete="family-name" />
                </div>
              </div>
              <div class="af-field">
                <label for="af-email">E-Mail <em>*</em></label>
                <input type="email" id="af-email" name="email" required autocomplete="email" />
              </div>
              <div class="af-field">
                <label for="af-telefon">Telefon</label>
                <input type="tel" id="af-telefon" name="telefon" autocomplete="tel" />
              </div>
            </fieldset>

            <fieldset>
              <legend>Berufliche Informationen</legend>
              <div class="af-field">
                <label for="af-cv">CV/Lebenslauf <em>*</em></label>
                <input type="file" id="af-cv" name="cv" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.zip" />
              </div>
              <div class="af-field">
                <label for="af-zeugnisse">Zeugnisse & Diplome <em>*</em></label>
                <input type="file" id="af-zeugnisse" name="zeugnisse[]" required multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.zip" />
              </div>
              <div class="af-field">
                <label for="af-anschreiben">Anschreiben</label>
                <input type="file" id="af-anschreiben" name="anschreiben" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.zip" />
              </div>
              <p class="af-hint">PDF, Word, JPG/PNG oder ZIP — max. 8 MB pro Datei</p>
            </fieldset>

            <fieldset>
              <legend>Weitere Informationen</legend>
              <div class="af-field">
                <label for="af-gehalt">Gehaltsvorstellung <em>*</em></label>
                <input type="text" id="af-gehalt" name="gehalt" required placeholder="z. B. CHF 110'000 / Jahr oder Stundensatz" />
              </div>
              <div class="af-field">
                <label for="af-pensum">Gewünschtes Pensum <em>*</em></label>
                <select id="af-pensum" name="pensum" required>
                  <option value="" disabled selected>Bitte wählen</option>
                <option value="100%">100%</option>
                <option value="80–100%">80–100%</option>
                <option value="60–80%">60–80%</option>
                <option value="40–60%">40–60%</option>
                <option value="Projektbasiert / nach Vereinbarung">Projektbasiert / nach Vereinbarung</option>
                </select>
              </div>
              <div class="af-field">
                <label for="af-empfohlen">Empfohlen von</label>
                <input type="text" id="af-empfohlen" name="empfohlen" />
              </div>
            </fieldset>

            <fieldset>
              <legend>Bestätigung</legend>
              <label class="af-check">
                <input type="checkbox" id="af-datenschutz" name="datenschutz" value="1" required />
                <span set:html={`Ich akzeptiere die <a href="/de/datenschutz/" target="_blank" rel="noopener">Datenschutzrichtlinien</a> <em>*</em>`} />
              </label>
            </fieldset>

            <input type="text" name="website" id="af-hp" tabindex="-1" autocomplete="off" aria-hidden="true" class="af-hp" />

            <p class="af-status" id="af-status" role="status"></p>

            <button type="submit" class="btn-submit" id="af-submit">
              <Send size={16} />
              Jetzt bewerben
            </button>
          </form>

          <div class="apply-success" id="applySuccess" hidden>
            <h2>Vielen Dank für Ihre Bewerbung!</h2>
            <p>Ihre Unterlagen sind eingegangen. Sie werden persönlich gelesen und beantwortet — von der Person, die mit Ihnen arbeiten würde.</p>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<script>
  const form = document.getElementById('applyForm') as HTMLFormElement | null;
  const statusEl = document.getElementById('af-status') as HTMLParagraphElement | null;
  const submitBtn = document.getElementById('af-submit') as HTMLButtonElement | null;
  const successEl = document.getElementById('applySuccess') as HTMLDivElement | null;
  const pageLang = document.documentElement.lang || 'en';

  const MSG = {
    required: pageLang === 'de'
      ? 'Bitte füllen Sie alle Pflichtfelder aus (mit * markiert).'
      : 'Please fill in all required fields (marked with *).',
    files: pageLang === 'de'
      ? 'Bitte laden Sie CV und Zeugnisse hoch (max. 8 MB pro Datei).'
      : 'Please upload your CV and certificates (max. 8 MB per file).',
    size: pageLang === 'de'
      ? 'Eine Datei ist grösser als 8 MB — bitte verkleinern.'
      : 'One file exceeds 8 MB — please reduce its size.',
    fail: pageLang === 'de'
      ? 'Übermittlung fehlgeschlagen. Bitte senden Sie Ihre Bewerbung direkt an me@eflury.com.'
      : 'Submission failed. Please send your application directly to me@eflury.com.',
    sending: pageLang === 'de' ? 'Wird gesendet …' : 'Sending …',
  };

  function setError(msg: string) {
    if (statusEl) {
      statusEl.className = 'af-status error';
      statusEl.textContent = msg;
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;

    const fd = new FormData(form);
    fd.append('job', form.dataset.job || '');
    fd.append('lang', pageLang);

    const required = ['vorname', 'nachname', 'email', 'gehalt', 'pensum'];
    for (const k of required) {
      if (!String(fd.get(k) || '').trim()) {
        setError(MSG.required);
        return;
      }
    }
    const email = String(fd.get('email') || '');
    if (!email.includes('@') || !email.includes('.')) {
      setError(MSG.required);
      return;
    }
    if (!(document.getElementById('af-datenschutz') as HTMLInputElement)?.checked) {
      setError(MSG.required);
      return;
    }

    const cv = (document.getElementById('af-cv') as HTMLInputElement)?.files;
    const zg = (document.getElementById('af-zeugnisse') as HTMLInputElement)?.files;
    if (!cv?.length || !zg?.length) {
      setError(MSG.files);
      return;
    }
    const all = [
      ...Array.from(cv),
      ...Array.from(zg),
      ...Array.from((document.getElementById('af-anschreiben') as HTMLInputElement)?.files || []),
    ];
    if (all.some((f) => f.size > 8 * 1024 * 1024)) {
      setError(MSG.size);
      return;
    }

    if (statusEl) {
      statusEl.className = 'af-status';
      statusEl.textContent = MSG.sending;
    }
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch(form.dataset.endpoint || '/api/apply.php', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.ok) throw new Error(data.message || String(res.status));
      form.hidden = true;
      if (successEl) successEl.hidden = false;
      successEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      if ((window as any).trackEvent) {
        (window as any).trackEvent('Conversion', 'job_application', form.dataset.job || 'career');
      }
    } catch (err) {
      console.error('Application submit failed:', err);
      setError(MSG.fail);
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

<style>
  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .job-hero {
    padding: 2.75rem 0 2.25rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
  }

  .job-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border-radius: var(--radius-full);
    background: var(--action-teal);
    color: white;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 1rem;
  }

  .job-hero h1 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    letter-spacing: -0.02em;
  }

  .job-sub {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }

  .job-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2.25rem;
  }

  .job-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .jm-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--teal-text);
  }

  .jm-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .btn-apply-mobile {
    display: none;
    margin-top: 1.5rem;
  }

  /* Body grid: description centre, form right */
  .job-body {
    padding: 3rem 0 4rem;
  }

  .job-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 400px;
    gap: 3rem;
    align-items: start;
  }

  .job-desc h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
  }

  .job-desc h2:first-of-type {
    margin-top: 2rem;
  }

  .job-desc p,
  .job-desc li {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .job-desc p {
    margin-bottom: 1rem;
  }

  .job-desc :global(a) {
    color: var(--teal-text);
  }

  .honesty-note {
    padding: 1rem 1.3rem;
    background: var(--card-bg);
    border-left: 4px solid var(--action-teal);
    border-radius: 0 12px 12px 0;
    box-shadow: var(--shadow-sm);
  }

  .honesty-note p {
    margin: 0;
    font-size: 0.95rem;
  }

  .who-list {
    padding-left: 1.2rem;
    margin-bottom: 1rem;
  }

  .who-list :global(li) {
    margin-bottom: 0.6rem;
  }

  .process-steps {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 1rem;
  }

  .process-steps li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
  }

  .step-num {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--action-teal);
    color: white;
    font-weight: 800;
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .process-steps h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .process-steps p {
    margin: 0;
    font-size: 0.92rem;
  }

  .alt-apply {
    margin-top: 2rem;
    font-size: 0.9rem;
    color: var(--text-tertiary);
  }

  /* Form */
  .job-apply {
    position: sticky;
    top: calc(var(--header-height, 76px) + 1.25rem);
  }

  .apply-form,
  .apply-success {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
  }

  .apply-form h2,
  .apply-success h2 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
  }

  .apply-form fieldset {
    border: none;
    padding: 0;
    margin: 0 0 1.4rem;
  }

  .apply-form legend {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--teal-text);
    margin-bottom: 0.7rem;
    padding: 0;
  }

  .af-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .af-field {
    margin-bottom: 0.85rem;
  }

  .af-field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.3rem;
  }

  .af-field label em,
  .af-check em {
    color: var(--teal-text);
    font-style: normal;
  }

  .af-field input[type='text'],
  .af-field input[type='email'],
  .af-field input[type='tel'],
  .af-field select {
    width: 100%;
    padding: 0.65rem 0.85rem;
    font-size: 1.0625rem;
    font-family: inherit;
    color: var(--text-primary);
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
  }

  .af-field input[type='file'] {
    width: 100%;
    font-size: 0.85rem;
    color: var(--text-secondary);
    padding: 0.45rem 0;
  }

  .af-field input:focus,
  .af-field select:focus {
    outline: 2px solid var(--action-teal);
    outline-offset: 1px;
    border-color: var(--action-teal);
  }

  .af-hint {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    margin: 0.1rem 0 0;
  }

  .af-check {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .af-check input {
    margin-top: 0.2rem;
    width: 17px;
    height: 17px;
    accent-color: var(--action-teal);
    flex-shrink: 0;
  }

  .af-check :global(a) {
    color: var(--teal-text);
  }

  .af-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .af-status {
    min-height: 1.2em;
    font-size: 0.85rem;
    margin: 0 0 0.75rem;
    color: var(--text-secondary);
  }

  .af-status.error {
    color: var(--warning-700);
  }

  .btn-submit,
  .btn-apply-mobile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: var(--action-teal);
    color: white;
    border: none;
    border-radius: 12px;
    font-family: inherit;
    font-size: 1.0625rem;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-submit:hover,
  .btn-apply-mobile:hover {
    background: var(--success-700);
    transform: translateY(-1px);
  }

  .btn-submit:disabled {
    opacity: 0.6;
    cursor: wait;
    transform: none;
  }

  /* Hero apply button: mobile/tablet only (declared after the shared
     button rule so display:none wins on desktop) */
  .btn-apply-mobile {
    display: none;
  }

  .apply-success p {
    color: var(--text-secondary);
    line-height: 1.65;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .job-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .job-apply {
      position: static;
      max-width: 560px;
    }

    .btn-apply-mobile {
      display: inline-flex;
      width: auto;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .af-row-2 {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }
</style>
