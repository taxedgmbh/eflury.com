---
import MainLayout from '../../layouts/MainLayout.astro';
import SwissMapIllustration from '../../components/illustrations/SwissMapIllustration.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { MapPin, Check, ExternalLink, MessageCircle } from 'lucide-astro';

const lang = "de";

const steps = [
  {
    title: "Sie melden sich",
    text: "Über das Formular unten, per E-Mail, Telefon oder WhatsApp — wie es Ihnen passt.",
  },
  {
    title: "Antwort innerhalb von 24 Stunden",
    text: "Direkt von Emanuel Flury — von der Person, die die Systeme baut, nicht von einer Vorzimmer-Instanz.",
  },
  {
    title: "Kostenloses 30-Minuten-Gespräch",
    text: "Wir gehen Ihren Fall gemeinsam durch. Passt Automatisierung nicht, sagen wir das offen — ein klares Nein ist auch ein sauberes Ergebnis.",
  },
];

const reachItems = [
  "Vor Ort: Raum Solothurn · Biel · Bern · Basel · Zürich",
  "Remote: ganze Schweiz & EU",
  "Antwort innerhalb von 24 Stunden, Termine meist innerhalb von 3 Tagen",
];

const mapsUrl = "https://www.google.com/maps/search/?api=1&query=Keltenweg+4%2C+2540+Grenchen%2C+Schweiz";
---

<MainLayout
  title="Kontakt - eFlury Consulting"
  description="Kontakt zu eFlury Consulting in Grenchen: Formular, E-Mail, Telefon oder WhatsApp. Antwort innerhalb von 24 Stunden, danach ein kostenloses 30-Minuten-Gespräch — vor Ort oder remote in der ganzen Schweiz."
  keywords="Kontakt eFlury Consulting, KI-Automatisierung Beratung, kostenloses Strategiegespräch, Grenchen Schweiz"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Kontakt" }]} />

  <main class="contact-page">
    <section class="contact-hero">
      <div class="container">
        <span class="hero-badge">Kontakt · Antwort < 24 h · Kostenlos</span>
        <h1>Sprechen wir.</h1>
        <p class="lead">Ob Sie einen konkreten Prozess im Kopf haben oder erst sondieren — Sie erhalten innerhalb von 24 Stunden eine Antwort, von der Person, die die Systeme baut.</p>
      </div>
    </section>

    <section class="next-steps">
      <div class="container">
        <h2>So geht es weiter</h2>
        <ol class="steps-grid">
          {steps.map((step, i) => (
            <li class="step-card">
              <span class="step-number">{i + 1}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <Contact lang={lang} showHeader={false} />

    <section class="location">
      <div class="container">
        <h2 class="section-title">Standort & Erreichbarkeit</h2>
        <p class="section-sub">Zuhause im Mittelland, im Einsatz in der ganzen Schweiz — vor Ort oder remote.</p>
        <div class="location-grid">
          <div class="map-panel">
            <SwissMapIllustration lang={lang} />
          </div>
          <div class="addr-panel">
            <div class="addr-head">
              <span class="addr-icon"><MapPin size={20} /></span>
              <span class="addr-label">Adresse</span>
            </div>
            <address>
              <strong>eFlury Consulting</strong><br />
              Keltenweg 4<br />
              2540 Grenchen, Schweiz
            </address>
            <p class="addr-note">Termine nach Vereinbarung — bei Ihnen im Betrieb, in Grenchen oder remote.</p>
            <ul class="reach-list">
              {reachItems.map((item) => (
                <li><Check size={15} /><span>{item}</span></li>
              ))}
            </ul>
            <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="directions-btn">
              Route planen (Google Maps)
              <ExternalLink size={15} />
            </a>
            <p class="effi-hint"><MessageCircle size={15} /> Schnelle Frage ausserhalb der Bürozeiten? Effi, unser Chat unten rechts, antwortet sofort.</p>
          </div>
        </div>
        <p class="legal-note" set:html={`Vollständige Firmenangaben im <a href="/de/impressum/">Impressum</a> · Wie wir mit Ihren Daten arbeiten: <a href="/de/sicherheit/">Sicherheit &amp; Vertrauen</a>`} />
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .contact-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .contact-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .contact-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
  }

  .next-steps {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-primary);
  }

  .next-steps h2 {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xl);
  }

  .steps-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-lg);
  }

  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    background: var(--action-teal);
    color: var(--eflury-white);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
  }

  .step-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .step-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  /* Location & map */
  .location {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-primary);
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  .section-sub {
    text-align: center;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto var(--spacing-xl);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: var(--spacing-lg);
    align-items: stretch;
  }

  .map-panel {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    align-items: center;
  }

  .addr-panel {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
  }

  .addr-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .addr-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
  }

  .addr-label {
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  address {
    font-style: normal;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--text-primary);
    margin-bottom: 0.9rem;
  }

  .addr-note {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
  }

  .reach-list {
    list-style: none;
    margin: 0 0 1.4rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-grow: 1;
  }

  .reach-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-primary);
  }

  .reach-list li :global(svg) {
    color: var(--teal-text);
    flex-shrink: 0;
    margin-top: 0.18rem;
  }

  .directions-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.8rem 1.4rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .directions-btn:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  .effi-hint {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-tertiary);
    margin: 1.1rem 0 0;
  }

  .effi-hint :global(svg) {
    flex-shrink: 0;
    margin-top: 0.15rem;
    color: var(--teal-text);
  }

  .legal-note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-tertiary);
    margin: var(--spacing-xl) 0 0;
  }

  .legal-note :global(a) {
    color: var(--link-color);
    text-decoration: none;
  }

  .legal-note :global(a:hover) {
    text-decoration: underline;
  }

  @media (max-width: 900px) {
    .location-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .contact-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .contact-hero .lead {
      font-size: 1.05rem;
    }

    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }

    .step-card {
      padding: var(--spacing-lg);
    }

    .map-panel {
      padding: 1rem;
    }
  }
</style>
