---
/**
 * SkopaAI Product Landing Page (German)
 * Pre-configured Mac Mini with AI assistant - Made in Switzerland
 * Brand: SkopaAI (skopa.ai)
 */

import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Footer from '../../components/Footer.astro';
import AIChatbot from '../../components/AIChatbot.astro';
import { useTranslations } from '../../i18n/utils';
import {
  Sparkles, ArrowRight, CheckCircle2, Monitor, Cpu, Zap, Moon,
  Mail, Calendar, Search, FolderOpen, Receipt, FileEdit,
  Server, Code2, Link, GraduationCap, Headphones, Shield, Clock, Users,
  Home, ChevronRight
} from 'lucide-astro';

const lang = 'de';
const t = useTranslations(lang);
---

<MainLayout
  title={t('skopaai.meta.title')}
  description={t('skopaai.meta.description')}
  keywords="SkopaAI, KI-Assistent Hardware, Mac Mini AI, vorkonfigurierter KI-Agent, WhatsApp AI Bot, Schweizer KI-Automatisierung, Moltbot Setup, KI-Mitarbeiter Schweiz"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: t('nav.skopaai') }]} />

  <main class="skopaai-page">
    <!-- Breadcrumb Navigation -->

    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="container">
        <div class="hero-content">
          <div class="hero-badge">
            <Sparkles size={14} />
            <span>{t('skopaai.hero.badge')}</span>
          </div>
          <h1 class="hero-title">{t('skopaai.hero.title')}</h1>
          <p class="hero-subtitle">{t('skopaai.hero.subtitle')}</p>

          <div class="hero-cta">
            <a href="#pricing" class="btn btn-primary">
              {t('skopaai.hero.cta_primary')}
              <ArrowRight size={18} />
            </a>
            <a href="#solution" class="btn btn-secondary">
              {t('skopaai.hero.cta_secondary')}
            </a>
          </div>

          <div class="trust-badges">
            <span class="trust-badge">
              <Shield size={16} />
              {t('skopaai.trust.first_in_switzerland')}
            </span>
            <span class="trust-badge">
              <Server size={16} />
              {t('skopaai.trust.swiss_data')}
            </span>
            <span class="trust-badge">
              <Monitor size={16} />
              {t('skopaai.trust.no_cloud')}
            </span>
          </div>
        </div>

        <div class="hero-visual">
          <div class="mac-mini-mockup">
            <div class="device">
              <div class="device-top"></div>
              <div class="device-body">
                <div class="led"></div>
              </div>
            </div>
            <div class="chat-bubbles">
              <div class="bubble incoming">
                <span class="app-icon">💬</span>
                <span>"Plane ein Meeting mit Thomas für nächsten Dienstag"</span>
              </div>
              <div class="bubble outgoing">
                <span class="ai-icon"><Cpu size={18} /></span>
                <span>Erledigt! Meeting am Dienstag um 10:00 mit Thomas geplant. Kalendereinladung wurde gesendet.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="problem" id="problem">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.problem.title')}</h2>
          <p class="section-subtitle">{t('skopaai.problem.subtitle')}</p>
        </div>

        <div class="problems-grid">
          {t('skopaai.problem.problems').map((problem: string, i: number) => {
            const icons = [Mail, Calendar, FolderOpen, Search];
            const IconComponent = icons[i];
            return (
              <div class="problem-card">
                <div class="card-icon">
                  <IconComponent size={24} />
                </div>
                <p>{problem}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="solution" id="solution">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.solution.title')}</h2>
          <p class="section-subtitle">{t('skopaai.solution.subtitle')}</p>
        </div>

        <div class="features-grid">
          {t('skopaai.solution.features').map((feature: {title: string, description: string}, i: number) => {
            const icons = [Link, Monitor, Zap, Moon];
            const IconComponent = icons[i];
            return (
              <div class="feature-card">
                <div class="feature-icon">
                  <IconComponent size={28} />
                </div>
                <h3>{feature.title}</h3>
                <p>{feature.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Use Cases Section -->
    <section class="use-cases" id="use-cases">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.use_cases.title')}</h2>
          <p class="section-subtitle">{t('skopaai.use_cases.subtitle')}</p>
        </div>

        <div class="use-cases-grid">
          {t('skopaai.use_cases.cases').map((useCase: {title: string, description: string}, i: number) => {
            const icons = [Mail, Calendar, Search, FolderOpen, Receipt, FileEdit];
            const IconComponent = icons[i];
            return (
              <div class="use-case-card">
                <div class="use-case-icon">
                  <IconComponent size={24} />
                </div>
                <h3>{useCase.title}</h3>
                <p>{useCase.description}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing" id="pricing">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.pricing.title')}</h2>
          <p class="section-subtitle">{t('skopaai.pricing.subtitle')}</p>
        </div>

        <div class="pricing-grid">
          <!-- Cloud Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <h3>{t('skopaai.pricing.tiers.cloud.name')}</h3>
              <p class="tier-description">{t('skopaai.pricing.tiers.cloud.description')}</p>
            </div>
            <div class="card-price">
              <div class="price-row">
                <span class="label">{t('skopaai.pricing.one_time_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.cloud.one_time')}</span>
              </div>
              <div class="price-row monthly">
                <span class="label">{t('skopaai.pricing.monthly_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.cloud.monthly')}</span>
              </div>
            </div>
            <div class="card-features">
              <h4>{t('skopaai.pricing.includes_label')}</h4>
              <ul>
                {t('skopaai.pricing.tiers.cloud.features').map((feature: string) => (
                  <li><CheckCircle2 size={16} /><span>{feature}</span></li>
                ))}
              </ul>
            </div>
            <div class="card-best-for">
              <Users size={14} />
              <span><strong>{t('skopaai.pricing.best_for_label')}:</strong> {t('skopaai.pricing.tiers.cloud.best_for')}</span>
            </div>
            <a href="#contact" class="btn btn-outline">{t('skopaai.pricing.cta')}</a>
          </div>

          <!-- Mini Tier (Popular) -->
          <div class="pricing-card popular">
            <div class="popular-badge">{t('skopaai.pricing.tiers.mini.badge')}</div>
            <div class="card-header">
              <h3>{t('skopaai.pricing.tiers.mini.name')}</h3>
              <p class="tier-description">{t('skopaai.pricing.tiers.mini.description')}</p>
            </div>
            <div class="card-price">
              <div class="price-row">
                <span class="label">{t('skopaai.pricing.one_time_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.mini.one_time')}</span>
              </div>
              <div class="price-row monthly">
                <span class="label">{t('skopaai.pricing.monthly_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.mini.monthly')}</span>
              </div>
            </div>
            <div class="card-features">
              <h4>{t('skopaai.pricing.includes_label')}</h4>
              <ul>
                {t('skopaai.pricing.tiers.mini.features').map((feature: string) => (
                  <li><CheckCircle2 size={16} /><span>{feature}</span></li>
                ))}
              </ul>
            </div>
            <div class="card-best-for">
              <Users size={14} />
              <span><strong>{t('skopaai.pricing.best_for_label')}:</strong> {t('skopaai.pricing.tiers.mini.best_for')}</span>
            </div>
            <a href="#contact" class="btn btn-primary">{t('skopaai.pricing.cta')}</a>
          </div>

          <!-- Enterprise Tier -->
          <div class="pricing-card">
            <div class="card-header">
              <h3>{t('skopaai.pricing.tiers.enterprise.name')}</h3>
              <p class="tier-description">{t('skopaai.pricing.tiers.enterprise.description')}</p>
            </div>
            <div class="card-price">
              <div class="price-row">
                <span class="label">{t('skopaai.pricing.one_time_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.enterprise.one_time')}</span>
              </div>
              <div class="price-row monthly">
                <span class="label">{t('skopaai.pricing.monthly_label')}</span>
                <span class="price">{t('skopaai.pricing.tiers.enterprise.monthly')}</span>
              </div>
            </div>
            <div class="card-features">
              <h4>{t('skopaai.pricing.includes_label')}</h4>
              <ul>
                {t('skopaai.pricing.tiers.enterprise.features').map((feature: string) => (
                  <li><CheckCircle2 size={16} /><span>{feature}</span></li>
                ))}
              </ul>
            </div>
            <div class="card-best-for">
              <Users size={14} />
              <span><strong>{t('skopaai.pricing.best_for_label')}:</strong> {t('skopaai.pricing.tiers.enterprise.best_for')}</span>
            </div>
            <a href="#contact" class="btn btn-outline">{t('skopaai.pricing.cta')}</a>
          </div>
        </div>
      </div>
    </section>

    <!-- What's Included Section -->
    <section class="included" id="included">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.included.title')}</h2>
        </div>

        <div class="included-grid">
          <div class="included-card">
            <div class="included-icon"><Server size={24} /></div>
            <h3>{t('skopaai.included.hardware.title')}</h3>
            <ul>
              {t('skopaai.included.hardware.items').map((item: string) => (
                <li><CheckCircle2 size={14} /><span>{item}</span></li>
              ))}
            </ul>
          </div>

          <div class="included-card">
            <div class="included-icon"><Code2 size={24} /></div>
            <h3>{t('skopaai.included.software.title')}</h3>
            <ul>
              {t('skopaai.included.software.items').map((item: string) => (
                <li><CheckCircle2 size={14} /><span>{item}</span></li>
              ))}
            </ul>
          </div>

          <div class="included-card">
            <div class="included-icon"><Link size={24} /></div>
            <h3>{t('skopaai.included.integrations.title')}</h3>
            <ul>
              {t('skopaai.included.integrations.items').map((item: string) => (
                <li><CheckCircle2 size={14} /><span>{item}</span></li>
              ))}
            </ul>
          </div>

          <div class="included-card">
            <div class="included-icon"><GraduationCap size={24} /></div>
            <h3>{t('skopaai.included.training.title')}</h3>
            <ul>
              {t('skopaai.included.training.items').map((item: string) => (
                <li><CheckCircle2 size={14} /><span>{item}</span></li>
              ))}
            </ul>
          </div>

          <div class="included-card">
            <div class="included-icon"><Headphones size={24} /></div>
            <h3>{t('skopaai.included.support.title')}</h3>
            <ul>
              {t('skopaai.included.support.items').map((item: string) => (
                <li><CheckCircle2 size={14} /><span>{item}</span></li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq" id="faq">
      <div class="container">
        <div class="section-header">
          <h2>{t('skopaai.faq.title')}</h2>
        </div>

        <div class="faq-grid">
          {t('skopaai.faq.questions').map((faq: {question: string, answer: string}) => (
            <div class="faq-item">
              <h3>{faq.question}</h3>
              <p>{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta" id="contact">
      <div class="container">
        <div class="cta-content">
          <h2>{t('skopaai.cta.title')}</h2>
          <p class="cta-subtitle">{t('skopaai.cta.subtitle')}</p>

          <a href="/de#contact" class="btn btn-cta">
            {t('skopaai.cta.button')}
            <ArrowRight size={18} />
          </a>

          <p class="cta-note">{t('skopaai.cta.note')}</p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* ========================================
     SkopaAI Page - Premium Apple-Style Design
     ======================================== */

  .skopaai-page {
    padding-top: var(--header-height, 80px);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ========================================
     Breadcrumb Navigation
     ======================================== */
  .breadcrumb {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    padding: 0.75rem 0;
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--eflury-teal);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--eflury-navy);
  }

  :global([data-theme="dark"]) .breadcrumb-link:hover {
    color: white;
  }

  .breadcrumb-separator {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .breadcrumb-current {
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
  }

  @media (max-width: 480px) {
    .breadcrumb {
      padding: 0.5rem 0;
    }

    .breadcrumb-link,
    .breadcrumb-current {
      font-size: 0.8125rem;
    }
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ========================================
     Hero Section
     ======================================== */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(13, 148, 136, 0.12), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(2, 37, 84, 0.08), transparent);
    pointer-events: none;
  }

  :global([data-theme="dark"]) .hero-bg {
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(13, 148, 136, 0.2), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(20, 144, 208, 0.15), transparent);
  }

  .hero .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 560px;
    background: linear-gradient(135deg, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.5) 100%);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-radius: var(--radius-xl, 20px);
    padding: var(--spacing-xl, 32px);
    border: 1px solid rgba(255,255,255,0.2);
    box-shadow: var(--shadow-lg);
  }

  :global([data-theme="dark"]) .hero-content {
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.4) 100%);
    border-color: rgba(255,255,255,0.1);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1.5px solid var(--eflury-teal);
    border-radius: 100px;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--eflury-teal);
    margin-bottom: 1.5rem;
    animation: subtle-pulse 3s ease-in-out infinite;
  }

  @keyframes subtle-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(13, 148, 136, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(13, 148, 136, 0); }
  }

  .hero-title {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1rem;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm, 8px);
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    padding: 6px 12px;
    border-radius: var(--radius-full, 9999px);
    border: 1px solid var(--border-color);
  }

  .trust-badge :global(svg) {
    color: var(--eflury-teal);
    flex-shrink: 0;
  }

  /* Hero Visual */
  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mac-mini-mockup {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .device {
    width: 140px;
  }

  .device-top {
    height: 10px;
    background: linear-gradient(to bottom, #e8e8e8 0%, #c8c8c8 100%);
    border-radius: 6px 6px 0 0;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.5);
  }

  .device-body {
    height: 40px;
    background: linear-gradient(to bottom, #b8b8b8 0%, #909090 100%);
    border-radius: 0 0 10px 10px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .led {
    width: 8px;
    height: 8px;
    background: var(--eflury-teal);
    border-radius: 50%;
    box-shadow: 0 0 12px var(--eflury-teal);
    animation: led-pulse 2s infinite;
  }

  @keyframes led-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 12px var(--eflury-teal); }
    50% { opacity: 0.6; box-shadow: 0 0 6px var(--eflury-teal); }
  }

  .chat-bubbles {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    max-width: 400px;
  }

  .bubble {
    padding: 1rem 1.25rem;
    border-radius: 1rem;
    font-size: 0.9rem;
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    animation: bubble-in 0.5s ease-out;
  }

  @keyframes bubble-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .bubble.incoming {
    background: var(--card-bg, white);
    border: 1px solid var(--border-color);
    border-bottom-left-radius: 4px;
    align-self: flex-start;
    box-shadow: var(--shadow-sm);
    animation-delay: 0.2s;
  }

  .bubble.outgoing {
    background: var(--eflury-teal);
    color: white;
    border-bottom-right-radius: 4px;
    align-self: flex-end;
    box-shadow: var(--shadow-md);
    animation-delay: 0.6s;
  }

  .app-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
  }

  .ai-icon {
    flex-shrink: 0;
    opacity: 0.9;
  }

  /* ========================================
     Buttons
     ======================================== */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--eflury-navy);
    color: white;
    box-shadow: 0 4px 14px rgba(2, 37, 84, 0.25);
  }

  .btn-primary:hover {
    background: var(--eflury-teal);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(13, 148, 136, 0.35);
  }

  .btn-secondary {
    background: transparent;
    color: var(--eflury-navy);
    border: 2px solid var(--border-color);
  }

  :global([data-theme="dark"]) .btn-secondary {
    color: var(--text-primary);
  }

  .btn-secondary:hover {
    border-color: var(--eflury-teal);
    color: var(--eflury-teal);
    background: rgba(13, 148, 136, 0.05);
  }

  .btn-outline {
    background: transparent;
    color: var(--eflury-teal);
    border: 2px solid var(--eflury-teal);
  }

  .btn-outline:hover {
    background: var(--eflury-teal);
    color: white;
    transform: translateY(-2px);
  }

  .btn-cta {
    background: white;
