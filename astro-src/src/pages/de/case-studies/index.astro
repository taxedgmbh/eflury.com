---
/**
 * Case Studies Index Page (German)
 * Showcases all client success stories
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import ResultsWallVisual from '../../../components/illustrations/ResultsWallVisual.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, Clock, TrendingUp, Building2, Home, ChevronRight } from 'lucide-astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'de';
const t = useTranslations(lang);

const caseStudies = [
  {
    slug: 'taxed-gmbh',
    title: 'Taxed GmbH',
    subtitle: 'Wie ich meine eigene Treuhandfirma automatisiert habe',
    industry: 'Steuerberatung',
    badge: 'Eigene Firma',
    badgeClass: 'own',
    statsList: [
      { value: '27.5h/Woche', label: 'Zeit gespart' },
      { value: 'CHF 24K/Jahr', label: 'Jährliche Einsparung' },
      { value: '3.2 Monate', label: 'Amortisation' },
    ],
    description: 'Vollständige Automatisierung von Kunden-Onboarding, Berichtserstellung, E-Mail-Antworten und Steuerberechnungen mit Claude Skills und MCP-Integration mit bexio.',
  },
  {
    slug: 'finance-automation',
    title: 'Finanzprozess-Automatisierung',
    subtitle: 'Monatsabschluss-Optimierung',
    industry: 'Fertigung',
    badge: 'Kundenprojekt',
    badgeClass: 'client',
    statsList: [
      { value: '40h/Monat', label: 'Zeit gespart' },
      { value: 'CHF 48K/Jahr', label: 'Jährliche Einsparung' },
      { value: '4.1 Monate', label: 'Amortisation' },
    ],
    description: 'Automatisierte Abstimmung, Abweichungsanalyse und Berichterstattung für ein Schweizer Fertigungsunternehmen, Reduktion des Monatsabschlusses von 12 auf 5 Tage.',
  },
  {
    slug: 'power-bi-reporting',
    title: 'Power BI Executive Dashboard',
    subtitle: 'Echtzeit Business Intelligence',
    industry: 'Professionelle Dienstleistungen',
    badge: 'Kundenprojekt',
    badgeClass: 'client',
    statsList: [
      { value: '15h/Woche', label: 'Zeit gespart' },
      { value: 'CHF 36K/Jahr', label: 'Jährliche Einsparung' },
      { value: '2.8 Monate', label: 'Amortisation' },
    ],
    description: 'Umfassende Power BI-Lösung mit Anbindung an 7 Datenquellen für Echtzeit-KPI-Tracking und automatisierte Kundenberichterstattung.',
  },
  {
    slug: 'llm-pipeline-showcase',
    title: 'Drei LLMs, ein Mahnlauf',
    subtitle: 'Wie ein Python-Skript KI Zeile für Zeile arbeiten lässt',
    industry: 'Tech-Showcase',
    badge: 'Code öffentlich',
    badgeClass: 'tech',
    statsList: [
      { value: '3 Anbieter', label: 'Claude · GPT · Gemini' },
      { value: '40 Posten', label: 'Zeile für Zeile verarbeitet' },
      { value: '< $1', label: 'API-Kosten pro Lauf (Projektion)' },
    ],
    description: 'Kein Kundenprojekt, sondern ein lauffähiges Lehrstück: Ein Python-Skript beurteilt offene Posten mit Claude, erzwingt JSON mit GPT-5 mini und entwirft Mahn-E-Mails mit Gemini — Code, echte Modell-Ausgaben und Kostenrechnung offen publiziert.',
  },
];
---

<MainLayout
  title="Fallstudien - KI-Automatisierung Erfolgsgeschichten | Emanuel Flury"
  description="Dokumentierte KI-Automatisierungsprojekte aus Schweizer Unternehmen: geschätzte Einsparungen von CHF 24K-48K pro Jahr, Amortisation in 2.8-4.1 Monaten — Zahlen pro Projekt ausgewiesen."
  keywords="KI-Automatisierung Fallstudien, Schweizer Geschäftsautomatisierung, Claude AI Implementierung, RPA Erfolgsgeschichten, Power BI Beratung"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: t('nav.case_studies') }]} />

  <main class="case-studies-page">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">

        <h1>Fallstudien</h1>
        <p class="subtitle">Echte Ergebnisse von echten Schweizer Unternehmen</p>

        <div class="hero-stats">
          <div class="stat">
            <Clock size={24} />
            <span class="value">~220 h/Monat</span>
            <span class="label">Geschätzte Zeitersparnis, kombiniert</span>
          </div>
          <div class="stat">
            <TrendingUp size={24} />
            <span class="value">~CHF 108K</span>
            <span class="label">Geschätzte Jahresersparnis, kombiniert</span>
          </div>
          <div class="stat">
            <Building2 size={24} />
            <span class="value">2.8–4.1 Monate</span>
            <span class="label">Geschätzte Amortisation, pro Projekt</span>
          </div>
        </div>
        <p class="stats-basis">
          Aggregiert aus den drei Automatisierungsprojekten unten — jede Zahl ist pro Projekt in der jeweiligen Fallstudie dokumentiert. Der Tech-Showcase (synthetische Daten) ist nicht eingerechnet.
        </p>
      </div>
    </section>

    <!-- Case Studies Grid -->
    <section class="case-studies-grid">
      <div class="container">
        {caseStudies.map((study) => (
          <a href={`/de/case-studies/${study.slug}`} class="case-study-card">
            <div class="card-header">
              <span class={`badge ${study.badgeClass}`}>
                {study.badge}
              </span>
              <span class="industry">{study.industry}</span>
            </div>

            <h2>{study.title}</h2>
            <p class="card-subtitle">{study.subtitle}</p>
            <p class="description">{study.description}</p>

            <div class="stats-row">
              {study.statsList.map((s) => (
                <div class="stat-item">
                  <span class="stat-value">{s.value}</span>
                  <span class="stat-label">{s.label}</span>
                </div>
              ))}
            </div>

            <div class="card-cta">
              Fallstudie lesen <ArrowRight size={16} />
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="results-wall-section">
      <div class="container">
        <ResultsWallVisual lang="de" />
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Möchten Sie ähnliche Ergebnisse?</h2>
        <p>Buchen Sie eine kostenlose 30-minütige Bewertung, um Ihr Automatisierungspotenzial zu entdecken.</p>
        <a href="/de/kontakt/" class="btn-primary">
          Jetzt starten
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .case-studies-page {
    /* padding-top handled by breadcrumb */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Breadcrumb Navigation */
  .breadcrumb {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    padding: 0.75rem 0;
    margin-top: var(--header-height, 70px);
  }

  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--teal-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .breadcrumb-link:hover {
    color: var(--eflury-navy);
  }

  :global([data-theme="dark"]) .breadcrumb-link:hover {
    color: white;
  }

  .breadcrumb-separator {
    color: var(--text-tertiary);
    flex-shrink: 0;
  }

  .breadcrumb-current {
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .breadcrumb {
      padding: 0.5rem 0;
    }

    .breadcrumb-link,
    .breadcrumb-current {
      font-size: 0.8125rem;
    }
  }

  /* Hero Section */
  .hero {
    padding: 3rem 0 4rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .hero .subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .hero-stats .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 1.5rem;
    background: var(--card-bg);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .stats-basis {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 1.25rem 0 0;
  }

  .hero-stats .stat :global(svg) {
    color: var(--teal-text);
    margin-bottom: 0.75rem;
  }

  .hero-stats .value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--eflury-navy);
  }

  .hero-stats .label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* Case Studies Grid */
  .case-studies-grid {
    padding: 4rem 0;
  }

  .case-studies-grid .container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
  }

  .case-study-card {
    background: var(--card-bg);
    border-radius: 16px;
    padding: 2rem;
    border: 1px solid var(--border-color);
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .case-study-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    border-color: var(--teal-text);
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge.own {
    background: var(--action-teal);
    color: white;
  }

  .badge.client {
    background: var(--surface-navy);
    color: white;
  }

  .badge.tech {
    background: transparent;
    border: 1.5px solid var(--action-teal);
    color: var(--teal-text);
  }

  .industry {
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .case-study-card h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .card-subtitle {
    font-size: 1rem;
    color: var(--teal-text);
    margin-bottom: 1rem;
  }

  .description {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1.5rem;
  }

  .stat-item {
    text-align: center;
  }

  .stat-value {
    display: block;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--eflury-navy);
  }

  .stat-label {
    display: block;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .card-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--teal-text);
    font-weight: 600;
    font-size: 0.95rem;
  }

  .case-study-card:hover .card-cta {
    gap: 0.75rem;
  }

  /* CTA Section */
  .cta {
    padding: 4rem 0;
    background: var(--surface-navy);
    text-align: center;
  }

  .cta h2 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    color: white;
    margin-bottom: 0.75rem;
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--action-teal);
    color: white;
    border-radius: 12px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    background: #0f766e;
    transform: translateY(-2px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hero {
      padding: 2rem 0 3rem;
    }

    .hero-stats {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .hero-stats .stat {
      flex-direction: row;
      justify-content: space-between;
      padding: 1rem 1.5rem;
    }

    .hero-stats .stat :global(svg) {
      margin-bottom: 0;
      margin-right: 1rem;
    }

    .case-studies-grid .container {
      grid-template-columns: 1fr;
    }

    .stats-row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .stat-item {
      display: flex;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
