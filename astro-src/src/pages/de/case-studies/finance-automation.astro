---
/**
 * Case Study: Finance Process Automation (German)
 * Month-End Close Optimization for Swiss Manufacturing
 */

import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, Clock, TrendingUp, CheckCircle2, AlertCircle } from 'lucide-astro';

const lang = 'de';
---

<MainLayout
  title="Fallstudie: Finanzautomatisierung - 40 Stunden/Monat gespart | Emanuel Flury"
  description="Wie ein Schweizer Fertigungsunternehmen den Monatsabschluss von 12 auf 5 Tage reduzierte und CHF 48'000/Jahr mit KI-gestützter Abstimmung und Berichtsautomatisierung einsparte."
  keywords="Finanzautomatisierung Fallstudie, Monatsabschluss Automatisierung, Schweizer Fertigung, KI Abstimmung, ERP Automatisierung"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Fallstudien', href: `/${lang}/case-studies` }, { label: 'Finanzautomatisierung' }]} />

  <main class="case-study">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">

        <div class="hero-content">
          <div class="badge-row">
            <span class="badge client">Kundenprojekt</span>
            <span class="badge industry">Fertigung</span>
          </div>

          <h1>Finanzprozess-Automatisierung</h1>
          <p class="subtitle">Monatsabschluss-Optimierung für Schweizer Fertigung</p>

          <blockquote class="hero-quote">
            Der Monatsabschluss wurde von einem 12-Tage-Marathon zu einem optimierten 5-Tage-Prozess.
            <cite>— Anonymisierter Kunde, Präzisionsfertigung, Region Zürich</cite>
          </blockquote>

          <div class="disclaimer-banner">
            <p>Kundendaten auf Wunsch anonymisiert. Kennzahlen sind Schätzungen basierend auf Projektdaten und spiegeln möglicherweise nicht die exakten Ergebnisse wider.</p>
          </div>
          <div class="hero-stats">
            <div class="stat">
              <span class="value">~40h</span>
              <span class="label">Geschätzte monatliche Zeitersparnis</span>
            </div>
            <div class="stat">
              <span class="value">~CHF 48K</span>
              <span class="label">Geschätzte jährliche Einsparung</span>
            </div>
            <div class="stat">
              <span class="value">~4.1 Mo</span>
              <span class="label">Geschätzte Amortisationszeit</span>
            </div>
            <div class="stat">
              <span class="value">~58%</span>
              <span class="label">Geschätzte Reduktion Abschlusszeit</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Executive Summary -->
    <section class="executive-summary">
      <div class="container">
        <h2>Zusammenfassung</h2>

        <div class="company-info">
          <div class="info-grid">
            <div class="info-item">
              <strong>Branche:</strong> Präzisionsfertigung
            </div>
            <div class="info-item">
              <strong>Standort:</strong> Kanton Zürich, Schweiz
            </div>
            <div class="info-item">
              <strong>Unternehmensgrösse:</strong> 85 Mitarbeiter, CHF 18 Mio. Umsatz
            </div>
            <div class="info-item">
              <strong>Finanzteam:</strong> 4 Personen (1 CFO, 2 Buchhalter, 1 Controller)
            </div>
            <div class="info-item">
              <strong>ERP-System:</strong> SAP Business One
            </div>
            <div class="info-item">
              <strong>Implementierung:</strong> Claude AI + Python-Skripte + Power BI
            </div>
          </div>
        </div>

        <h3>Geschätzte Ergebnisse</h3>
        <div class="results-table-wrapper">
          <table class="results-table">
            <thead>
              <tr>
                <th>Metrik</th>
                <th>Vorher</th>
                <th>Nachher</th>
                <th>Verbesserung</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Monatsabschluss</strong></td>
                <td>12 Tage</td>
                <td>5 Tage</td>
                <td class="positive"><strong>-58%</strong></td>
              </tr>
              <tr>
                <td><strong>Abstimmungszeit</strong></td>
                <td>16 Stunden</td>
                <td>4 Stunden</td>
                <td class="positive"><strong>-75%</strong></td>
              </tr>
              <tr>
                <td><strong>Abweichungsanalyse</strong></td>
                <td>8 Stunden</td>
                <td>1.5 Stunden</td>
                <td class="positive"><strong>-81%</strong></td>
              </tr>
              <tr>
                <td><strong>Berichtserstellung</strong></td>
                <td>6 Stunden</td>
                <td>30 Min.</td>
                <td class="positive"><strong>-92%</strong></td>
              </tr>
              <tr>
                <td><strong>Fehlerquote</strong></td>
                <td>4.2%</td>
                <td>0.3%</td>
                <td class="positive"><strong>-93%</strong></td>
              </tr>
              <tr>
                <td><strong>Jährliche Kosteneinsparung</strong></td>
                <td>—</td>
                <td><strong>CHF 48'000</strong></td>
                <td>—</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- The Challenge -->
    <section class="challenge">
      <div class="container">
        <h2>Die Herausforderung</h2>
        <p class="intro">Ein Präzisionsfertigungsunternehmen mit 40+ Jahren Geschichte kämpfte mit veralteten Monatsabschlussprozessen:</p>

        <div class="pain-points">
          <div class="pain-point">
            <div class="pain-header">
              <AlertCircle size={24} />
              <h3>Manuelle Abstimmung</h3>
            </div>
            <p>Bankabstimmung über 3 Konten, Kreditoren-/Debitoren-Abgleich mit 200+ Lieferanten und Kunden, Bestandsabstimmung gegen physische Zählungen—alles in Excel mit manuellem Querverweisen.</p>
            <div class="time-cost">16 Stunden/Monat nur für Abstimmung</div>
          </div>

          <div class="pain-point">
            <div class="pain-header">
              <AlertCircle size={24} />
              <h3>Engpass bei Abweichungsanalyse</h3>
            </div>
            <p>Budget-Ist-Analyse erforderte Datenexport aus SAP, Neuformatierung in Excel, manuelle Identifikation von Abweichungen und Schreiben von Erklärungen. Der Controller verbrachte Tage damit.</p>
            <div class="time-cost">8 Stunden/Monat mit häufigen Fehlern</div>
          </div>

          <div class="pain-point">
            <div class="pain-header">
              <AlertCircle size={24} />
              <h3>Chaos bei Berichtszusammenstellung</h3>
            </div>
            <p>Executive-Berichte wurden aus 7 verschiedenen Datenquellen zusammengestellt. Jeden Monat erstellte der CFO manuell GuV, Bilanz, Cashflow und KPI-Berichte in PowerPoint.</p>
            <div class="time-cost">6 Stunden/Monat Copy-Paste-Arbeit</div>
          </div>

          <div class="pain-point">
            <div class="pain-header">
              <AlertCircle size={24} />
              <h3>Im Blindflug</h3>
            </div>
            <p>Management traf Entscheidungen nach Bauchgefühl, weil Daten zu schwer zugänglich waren. Auslastungsraten, Pipeline-Gesundheit und Rentabilität nach Geschäftsbereich waren bis zu Quartalsberichten Rätsel.</p>
            <div class="time-cost">12 Tage durchschnittliche Abschlusszeit</div>
          </div>
        </div>

        <div class="breaking-point">
          <h3>Der Wendepunkt</h3>
          <p>Als die Controllerin ihre Pensionierung ankündigte, erkannte der CFO, dass das institutionelle Wissen in Excel-Makros und manuellen Prozessen verloren gehen würde. Sie mussten systematisieren und automatisieren, bevor es zu spät war.</p>
        </div>
      </div>
    </section>

    <!-- The Solution -->
    <section class="solution">
      <div class="container">
        <h2>Die Lösung</h2>
        <p class="intro">Mit der eflury Method™ implementierten wir einen phasenweisen Automatisierungsansatz über 8 Wochen.</p>

        <div class="solution-phases">
          <div class="phase">
            <div class="phase-marker">
              <span class="phase-number">1</span>
            </div>
            <div class="phase-content">
              <h3>Automatisierte Abstimmungs-Engine</h3>
              <p>Wir bauten ein Claude-gestütztes Abstimmungssystem, das:</p>
              <ul>
                <li>Bankauszüge automatisch via SWIFT/MT940 importiert</li>
                <li>Transaktionen mittels Fuzzy-Logik gegen SAP-Einträge abgleicht</li>
                <li>Ausnahmen zur manuellen Prüfung markiert statt manuell abzugleichen</li>
                <li>Abstimmungsberichte mit Abweichungserklärungen generiert</li>
              </ul>
              <div class="phase-result">
                <CheckCircle2 size={18} />
                <span>Abstimmungszeit von 16 auf 4 Stunden reduziert</span>
              </div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-marker">
              <span class="phase-number">2</span>
            </div>
            <div class="phase-content">
              <h3>Intelligente Abweichungsanalyse</h3>
              <p>Wir erstellten einen Claude Skill, der:</p>
              <ul>
                <li>Budget- und Ist-Daten automatisch aus SAP abruft</li>
                <li>Abweichungen nach Kostenstelle, Projekt und Sachkonto berechnet</li>
                <li>Natürlichsprachliche Erklärungen für signifikante Abweichungen generiert</li>
                <li>Untersuchungsprioritäten basierend auf Wesentlichkeit vorschlägt</li>
              </ul>
              <div class="phase-result">
                <CheckCircle2 size={18} />
                <span>Abweichungsanalyse von 8 auf 1.5 Stunden reduziert</span>
              </div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-marker">
              <span class="phase-number">3</span>
            </div>
            <div class="phase-content">
              <h3>Executive-Reporting-Dashboard</h3>
              <p>Implementierung von Power BI mit KI-gestützter Narrativgenerierung:</p>
              <ul>
                <li>Echtzeit-Verbindung zu SAP Business One</li>
                <li>Automatisierte GuV, Bilanz und Cashflow-Statements</li>
                <li>KPI-Dashboard mit Drill-Down-Fähigkeit</li>
                <li>Claude-generierte Zusammenfassung für jeden Bericht</li>
              </ul>
              <div class="phase-result">
                <CheckCircle2 size={18} />
                <span>Berichtserstellung von 6 Stunden auf 30 Minuten reduziert</span>
              </div>
            </div>
          </div>

          <div class="phase">
            <div class="phase-marker">
              <span class="phase-number">4</span>
            </div>
            <div class="phase-content">
              <h3>Abschlusskalender-Automatisierung</h3>
              <p>Wir bauten ein Workflow-Orchestrierungssystem:</p>
              <ul>
                <li>Automatisierte Aufgabenplanung und Abhängigkeiten</li>
                <li>Slack-Benachrichtigungen für Aufgabenabschluss und Blocker</li>
                <li>Fortschritts-Tracking-Dashboard für CFO-Visibilität</li>
                <li>Historische Abschlussmetriken für kontinuierliche Verbesserung</li>
              </ul>
              <div class="phase-result">
                <CheckCircle2 size={18} />
                <span>Monatsabschluss von 12 auf 5 Tage reduziert</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="results">
      <div class="container">
        <h2>Detaillierte Ergebnisse</h2>

        <div class="results-grid">
          <div class="result-card">
            <h3>Zeitersparnis</h3>
            <div class="result-metric">
              <span class="big-number">40</span>
              <span class="unit">Stunden/Monat</span>
            </div>
            <p>Das Team konzentriert sich jetzt auf Analyse und Strategie statt auf Dateneingabe und Abstimmung.</p>
          </div>

          <div class="result-card">
            <h3>Finanzielle Auswirkung</h3>
            <div class="result-metric">
              <span class="big-number">CHF 48K</span>
              <span class="unit">jährliche Einsparung</span>
            </div>
            <p>Reduzierte Überstunden, eliminierte Temporärkräfte beim Abschluss, vermiedene Nachbesetzung der pensionierten Controllerin.</p>
          </div>

          <div class="result-card">
            <h3>Datenqualität</h3>
            <div class="result-metric">
              <span class="big-number">93%</span>
              <span class="unit">Fehlerreduktion</span>
            </div>
            <p>Von 4.2% auf 0.3% Fehlerquote. Prüfer notierten "signifikant verbesserte Kontrollen" in der Jahresprüfung.</p>
          </div>

          <div class="result-card">
            <h3>Entscheidungsgeschwindigkeit</h3>
            <div class="result-metric">
              <span class="big-number">7</span>
              <span class="unit">Tage schneller</span>
            </div>
            <p>Management erhält Finanzdaten jetzt bis Tag 5 statt Tag 12—ermöglicht schnellere strategische Entscheidungen.</p>
          </div>
        </div>

        <div class="roi-summary">
          <h3>Return on Investment</h3>
          <div class="roi-grid">
            <div class="roi-item">
              <span class="label">Implementierungskosten</span>
              <span class="value">CHF 16'500</span>
            </div>
            <div class="roi-item">
              <span class="label">Jährliche Einsparung</span>
              <span class="value">CHF 48'000</span>
            </div>
            <div class="roi-item">
              <span class="label">Amortisationszeit</span>
              <span class="value">4.1 Monate</span>
            </div>
            <div class="roi-item highlight">
              <span class="label">Jahr 1 ROI</span>
              <span class="value">191%</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Kundenfeedback -->
    <section class="testimonial">
      <div class="container">
        <div class="feedback-summary">
          <p>Das Finanzteam des Kunden berichtete von erheblichen Zeiteinsparungen nach der Implementierung, wodurch der Fokus von manueller Monatsabschluss-Verarbeitung auf strategische Finanzanalyse verlagert werden konnte.</p>
          <p class="disclaimer-text"><em>Kundendaten auf Wunsch anonymisiert. Dies ist eine Zusammenfassung berichteter Ergebnisse, kein direktes Zitat. Implementierung abgeschlossen Q2 2024.</em></p>
        </div>
      </div>
    </section>

    <!-- Technical Details -->
    <section class="technical">
      <div class="container">
        <h2>Technische Umsetzung</h2>

        <div class="tech-stack">
          <div class="tech-item">
            <strong>KI-Engine:</strong> Claude Sonnet 4 für Abweichungsanalyse und Narrativgenerierung
          </div>
          <div class="tech-item">
            <strong>Daten-Pipeline:</strong> Python-Skripte für SAP-Datenextraktion und Transformation
          </div>
          <div class="tech-item">
            <strong>Visualisierung:</strong> Power BI Premium für Echtzeit-Dashboards
          </div>
          <div class="tech-item">
            <strong>Orchestrierung:</strong> Microsoft Power Automate für Workflow-Management
          </div>
          <div class="tech-item">
            <strong>Hosting:</strong> Azure Schweiz Nord (Datenresidenz-konform)
          </div>
        </div>

        <div class="security-note">
          <h3>Datensicherheit</h3>
          <p>Alle Finanzdaten verbleiben in der Schweiz (Azure Schweiz Nord). Die Implementierung entspricht dem Schweizer DSG, der DSGVO und den branchenüblichen SOC-2-Kontrollen. Keine Finanzdaten werden an externe KI-Anbieter gesendet—Claude verarbeitet nur anonymisierte Abweichungsbeschreibungen.</p>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta">
      <div class="container">
        <h2>Bereit, Ihre Finanzprozesse zu transformieren?</h2>
        <p>Wenn Ihr Finanzteam mehr Zeit mit Dateneingabe als mit Analyse verbringt, können wir helfen.</p>
        <div class="cta-buttons">
          <a href="/de#contact" class="btn-primary">
            Kostenlose Bewertung buchen
            <ArrowRight size={18} />
          </a>
          <a href="/de/case-studies" class="btn-secondary">
            Weitere Fallstudien ansehen
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero Section */
  .hero {
    padding: 3rem 0 4rem;
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
  }

  .breadcrumb {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--primary-600);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    text-decoration: underline;
  }

  .badge-row {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge.client {
    background: var(--eflury-navy, #022554);
    color: white;
  }

  .badge.industry {
    background: var(--eflury-teal, #0d9488);
    color: white;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .hero .subtitle {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .hero-quote {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--eflury-navy, #022554);
    border-left: 4px solid var(--eflury-teal, #0d9488);
    padding-left: 1.5rem;
    margin: 2rem 0;
  }

  .hero-quote cite {
    display: block;
    font-style: normal;
    font-size: 0.875rem;
    margin-top: 0.5rem;
    color: var(--text-secondary);
  }

  .disclaimer-banner {
    background: var(--warning-50, #fffbeb);
    border: 1px solid var(--warning-200, #fde68a);
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--warning-800, #92400e);
  }

  .disclaimer-banner p {
    margin: 0;
  }

  .disclaimer-text {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 1rem;
  }

  .feedback-summary {
    max-width: 700px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .hero-stats .stat {
    text-align: center;
    background: white;
    padding: 1.25rem;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .hero-stats .value {
    display: block;
    font-size: 2rem;
    font-weight: 800;
    color: var(--eflury-teal, #0d9488);
    line-height: 1;
  }

  .hero-stats .label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
  }

  /* Executive Summary */
  .executive-summary {
    padding: 4rem 0;
  }

  .executive-summary h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: 2rem;
    color: var(--eflury-navy, #022554);
  }

  .company-info {
    margin-bottom: 3rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    background: var(--bg-secondary);
    padding: 1.5rem;
    border-radius: 12px;
  }

  .info-item {
    font-size: 0.9rem;
  }

  .info-item strong {
    color: var(--eflury-teal, #0d9488);
  }

  .executive-summary h3 {
    font-size: 1.25rem;
    margin: 2rem 0 1rem;
    color: var(--eflury-navy, #022554);
  }

  .results-table-wrapper {
    overflow-x: auto;
  }

  .results-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .results-table thead {
    background: var(--eflury-navy, #022554);
    color: white;
  }

  .results-table th,
  .results-table td {
    padding: 1rem;
    text-align: left;
  }

  .results-table tbody tr:nth-child(even) {
    background: var(--bg-secondary);
  }

  .results-table .positive {
    color: var(--eflury-teal, #0d9488);
    font-weight: 600;
  }

  /* Challenge Section */
  .challenge {
    padding: 4rem 0;
    background: var(--bg-secondary);
  }

  .challenge h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    margin-bottom: 1rem;
    color: var(--eflury-navy, #022554);
  }

  .challenge .intro {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }

  .pain-points {
    display: grid;
    gap: 1.5rem;
  }

  .pain-point {
    background: white;
    padding: 1.5rem;
    border-radius: 12px;
    border-left: 4px solid #ef4444;
  }

  .pain-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .pain-header :global(svg) {
    color: #ef4444;
    flex-shrink: 0;
  }

  .pain-header h3 {
    font-size: 1.1rem;
    color: var(--text-primary);
    margin: 0;
  }

  .pain-point p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .time-cost {
    font-size: 0.85rem;
    font-weight: 600;
    color: #ef4444;
  }

  .breaking-point {
    margin-top: 2rem;
    padding: 1.5rem;
    background: white;
    border-radius: 12px;
    border-left: 4px solid var(--eflury-teal, #0d9488);
  }

  .breaking-point h3 {
    color: var(--eflury-navy, #022554);
    margin-bottom: 0.5rem;
  }

  .breaking-point p {
    color: var(--text-secondary);
    margin: 0;
  }

  /* Solution Section */
  .solution {
    padding: 4rem 0;
  }

  .solution h2 {
