<script>
  import { submitHubSpotForm, HUBSPOT_FORMS } from '../../../scripts/hubspot-forms';

  const gate = document.getElementById('zipGate') as HTMLDivElement | null;
  const form = document.getElementById('zgForm') as HTMLFormElement | null;
  const emailInput = document.getElementById('zg-email') as HTMLInputElement | null;
  const submitBtn = document.getElementById('zg-submit') as HTMLButtonElement | null;
  const status = document.getElementById('zg-status') as HTMLParagraphElement | null;
  const success = document.getElementById('zgSuccess') as HTMLDivElement | null;
  const pageLang = document.documentElement.lang || 'en';

  // Bot protection: honeypot + lazily rendered Turnstile (same pattern as the footer)
  let zgToken: string | null = null;
  let zgWidgetRendered = false;

  function renderZgTurnstile() {
    const ts = (window as any).turnstile;
    const container = document.getElementById('zg-turnstile');
    if (!ts || !container || zgWidgetRendered) return;
    zgWidgetRendered = true;
    ts.render(container, {
      sitekey: gate?.dataset.sitekey,
      appearance: 'interaction-only',
      callback: (token: string) => { zgToken = token; },
      'expired-callback': () => { zgToken = null; },
    });
  }

  function ensureTurnstileLoaded() {
    if ((window as any).turnstile) {
      renderZgTurnstile();
      return;
    }
    if (!document.querySelector('script[src*="challenges.cloudflare.com"]')) {
      const s = document.createElement('script');
      s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
      s.async = true;
      s.defer = true;
      document.head.appendChild(s);
    }
    const poll = setInterval(() => {
      if ((window as any).turnstile) {
        clearInterval(poll);
        renderZgTurnstile();
      }
    }, 250);
    setTimeout(() => clearInterval(poll), 10000);
  }

  emailInput?.addEventListener('focus', ensureTurnstileLoaded, { once: true });

  function startDownload() {
    const zip = gate?.dataset.zip;
    if (!zip) return;
    const a = document.createElement('a');
    a.href = zip;
    a.setAttribute('download', '');
    document.body.appendChild(a);
    a.click();
    a.remove();
  }

  function showSuccess() {
    if (form) form.hidden = true;
    if (success) success.hidden = false;
    startDownload();
    if ((window as any).trackEvent) {
      (window as any).trackEvent('Conversion', 'zip_download_lead', 'LLM Showcase');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot: bots fill hidden fields — pretend success, submit nothing.
    const honeypot = (document.getElementById('zg-hp') as HTMLInputElement | null)?.value;
    if (honeypot) {
      showSuccess();
      return;
    }

    const email = emailInput?.value?.trim() || '';
    if (!email || !email.includes('@') || !email.includes('.')) {
      if (status) {
        status.className = 'zg-status error';
        status.textContent = pageLang === 'de'
          ? 'Bitte geben Sie eine gültige E-Mail-Adresse ein.'
          : 'Please enter a valid email address.';
      }
      return;
    }

    // Turnstile gate: widget rendered but unsolved -> ask to complete.
    // Script never loaded (blocked) -> fail open; HubSpot filters spam too.
    if (!zgToken && zgWidgetRendered) {
      if (status) {
        status.className = 'zg-status error';
        status.textContent = pageLang === 'de'
          ? 'Bitte schliessen Sie kurz die Sicherheitsprüfung ab.'
          : 'Please complete the quick security check.';
      }
      return;
    }

    if (submitBtn) submitBtn.disabled = true;

    try {
      await submitHubSpotForm(
        HUBSPOT_FORMS.contact,
        {
          email,
          message: '[Lead via ZIP-Download] Tech-Showcase LLM-Pipeline (Mahnlauf) — ' + window.location.pathname,
        },
        'ZIP download gate (LLM showcase)',
      );
      showSuccess();
    } catch (error) {
      // Fail open: the visitor still gets the file, we just lose the lead.
      console.error('ZIP gate lead submission failed:', error);
      showSuccess();
    } finally {
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>

