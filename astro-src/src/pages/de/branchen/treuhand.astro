---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, FileInput, Receipt, MailCheck, Database } from 'lucide-astro';

const lang = 'de';

const pains = [
  {
    title: 'Preisdruck auf Standardleistungen',
    text: 'Buchhaltung, Lohn und MWST-Abrechnung werden zur Massenware — Mandanten vergleichen Preise, nicht Aufwand.',
  },
  {
    title: 'Qualifiziertes Personal ist knapp',
    text: 'Offene Stellen bleiben offen. Das bestehende Team verbringt zu viele Stunden mit Routinearbeit, die kein Fachurteil braucht.',
  },
  {
    title: 'Mehr Regulierung, höhere Erwartungen',
    text: 'Die Compliance wächst, während Mandanten schnellere Antworten und digitalen Service erwarten — beides drückt auf die Marge.',
  },
];

const automations = [
  {
    icon: FileInput,
    title: 'Mandanten-Onboarding',
    text: 'Dokumenteneingang, Checklisten und strukturierte Mandantendossiers — von der KI vorbereitet, von Ihrem Team freigegeben.',
    href: '/de/blog/ki-kunden-onboarding-treuhand/',
    linkLabel: 'So funktioniert KI-Onboarding',
  },
  {
    icon: Receipt,
    title: 'Kreditoren & Buchhaltungsroutine',
    text: 'Rechnungserfassung, Kontierungsvorschläge und Abstimmungsvorbereitung — angebunden an bexio oder ABACUS über MCP mit Lesezugriff.',
    href: '/de/services/finanzen-automatisierung/',
    linkLabel: 'Service Finanzautomatisierung',
  },
  {
    icon: MailCheck,
    title: 'E-Mail- & Dokumenten-Triage',
    text: 'Eingehende Mandantenpost sortiert, priorisiert und mit Antwortentwurf — nichts geht ohne menschliche Prüfung raus.',
    href: '/de/blog/ki-email-triage-agent-professionals/',
    linkLabel: 'Das Triage-Muster im Detail',
  },
  {
    icon: Database,
    title: 'Stammdaten & Reporting',
    text: 'Dubletten, fehlende Identifikatoren und Formatabweichungen bereinigt mit Freigabe-Gates — anschliessend Reporting in Power BI.',
    href: '/de/services/datenqualitaet/',
    linkLabel: 'Service Datenqualität',
  },
];
---

<MainLayout
  title="KI für Treuhand & Buchhaltung - eFlury Consulting"
  description="KI-Automatisierung für Schweizer Treuhand- und Buchhaltungsfirmen: Mandanten-Onboarding, Kreditoren, E-Mail-Triage und Stammdaten — mit Freigabe-Gates, erprobt in einer echten Praxis."
  keywords="KI Treuhand, Treuhand Automatisierung, Buchhaltung KI Schweiz, bexio Automatisierung, ABACUS Integration, Mandanten-Onboarding KI"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Branchen', href: '/de/branchen/' }, { label: 'Treuhand & Buchhaltung' }]} />

  <main class="industry-page">
    <section class="industry-hero">
      <div class="container">
        <p class="eyebrow">Branchen · Treuhand &amp; Buchhaltung</p>
        <h1>KI für Treuhand und Buchhaltung.</h1>
        <p class="lead">
          Ihre Marge lebt von Stunden — und zu viele davon fliessen in Routinearbeit.
          Wir automatisieren die repetitiven Teile des Mandats, damit die Zeit Ihres Teams
          dorthin geht, wo Mandanten wirklich für Fachurteil bezahlen.
        </p>
      </div>
    </section>

    <section class="pains">
      <div class="container">
        <h2>Der Druck ist strukturell</h2>
        <div class="card-grid three">
          {pains.map((pain) => (
            <div class="plain-card">
              <h3>{pain.title}</h3>
              <p>{pain.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="automations">
      <div class="container">
        <h2>Was wir in einer Treuhandpraxis automatisieren</h2>
        <p class="section-lead">
          Jedes System folgt derselben Regel: Die KI schlägt vor, Ihr Team gibt frei.
          Mandantendaten bleiben in Ihren Systemen — Agenten greifen über MCP-Konnektoren lesend zu.
        </p>
        <div class="card-grid two">
          {automations.map((item) => (
            <div class="auto-card">
              <div class="auto-icon"><item.icon size={22} /></div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a href={item.href} class="card-link">{item.linkLabel} <ArrowRight size={14} /></a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="proof">
      <div class="container">
        <h2>Erprobt, wo es weh tut: in einer echten Praxis</h2>
        <div class="proof-card">
          <p>
            Diese Systeme wurden in einer echten Schweizer Treuhandfirma gebaut und betrieben — unserer eigenen.
            Die Fallstudie dokumentiert Aufbau, Freigabe-Gates und die geschätzten Effekte:
            ~27.5 h/Woche Zeitersparnis, ~CHF 24K projizierte Jahresersparnis, ~3.2 Monate Amortisation.
          </p>
          <a href="/de/case-studies/taxed-gmbh/" class="card-link">Zur Fallstudie <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="insights-band">
      <div class="container">
        <p>
          Vier vertiefende Artikel zu KI in Treuhand und Buchhaltung —
          <a href="/de/blog/#treuhand">im Insights-Hub lesen</a>.
        </p>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>Welcher Mandatsschritt kostet Sie die meisten Stunden?</h2>
        <p>Kostenloses 30-Minuten-Gespräch — wir gehen Ihre Praxis durch, nicht ein Foliendeck.</p>
        <a href="/de/kontakt/" class="btn-primary">
          Kontakt aufnehmen
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .industry-hero {
    padding: var(--spacing-4xl) 0 var(--spacing-2xl);
    background: var(--bg-primary);
  }

  .eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--eflury-teal);
    margin-bottom: var(--spacing-md);
  }

  .industry-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    max-width: 800px;
  }

  .industry-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
  }

  section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: var(--spacing-xl);
  }

  .pains {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .automations {
    padding: var(--spacing-3xl) 0;
    background: var(--bg-primary);
  }

  .card-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .card-grid.three {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid.two {
    grid-template-columns: repeat(2, 1fr);
  }

  .plain-card,
  .auto-card,
  .proof-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .plain-card h3,
  .auto-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .plain-card p,
  .auto-card p,
  .proof-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .auto-card p {
    margin-bottom: var(--spacing-md);
  }

  .auto-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--eflury-teal);
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--primary-light);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .proof {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-secondary);
  }

  .proof-card p {
    font-size: 1.02rem;
    margin-bottom: var(--spacing-md);
  }

  .insights-band {
    padding: var(--spacing-xl) 0;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .insights-band p {
    font-size: 1rem;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  .insights-band a {
    display: inline-flex;
    align-items: center;
    color: var(--primary-light);
    font-weight: 600;
    text-decoration: none;
  }

  .insights-band a:hover {
    text-decoration: underline;
  }

  .cta {
    padding: var(--spacing-3xl) 0;
    background: var(--eflury-navy);
    text-align: center;
  }

  .cta h2 {
    color: var(--eflury-white);
    margin-bottom: var(--spacing-sm);
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    margin-bottom: var(--spacing-xl);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--eflury-teal);
    color: var(--eflury-white);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .card-grid.three,
    .card-grid.two {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .industry-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .industry-hero .lead {
      font-size: 1.05rem;
    }

    .pains,
    .automations,
    .proof {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
