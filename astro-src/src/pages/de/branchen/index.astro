---
import MainLayout from '../../../layouts/MainLayout.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import FloorPlanIllustration from '../../../components/illustrations/FloorPlanIllustration.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import { ArrowRight, Check, Calculator, BarChart3, Briefcase } from 'lucide-astro';

const lang = "de";

const areas = [
  {
    icon: Calculator,
    title: "Finanzen & Back Office",
    tagline: "Damit der Abschluss nicht das halbe Monatsende kostet.",
    proof: "2 dokumentierte Projekte",
    ticks: ["Kreditorenerfassung & Freigabe", "Monatsabschluss & Abstimmungen", "Mahnwesen & Zahlungserinnerungen", "Finanz-Stammdaten & Kontrollen"],
    href: "/de/branchen/finanzteams/",
  },
  {
    icon: Briefcase,
    title: "Kundenkommunikation & Annahme",
    tagline: "Damit Kundenarbeit nicht in der Administration versickert.",
    proof: "1 dokumentiertes Projekt",
    ticks: ["E-Mail-Triage & Antwortentwürfe", "Telefonannahme & Rückrufe", "WhatsApp-Geschäftskommunikation", "Offertanfragen & Auftragsannahme"],
    href: "/de/branchen/dienstleister/",
  },
  {
    icon: BarChart3,
    title: "Reporting & Daten",
    tagline: "Zahlen, denen Sie trauen — und die sich selbst aktualisieren.",
    proof: "1 dokumentiertes Projekt",
    ticks: ["Power-BI-Dashboards statt Handarbeit", "Excel-Migration & Datenmodell", "Datenqualität mit KI-Agenten", "Automatische Report-Verteilung"],
    href: "/de/branchen/reporting-daten/",
  },
];

const proofs = [
  {
    value: "~40",
    unit: "Std./Monat",
    area: "Finanzen",
    label: "Finanzprozesse eines KMU automatisiert: Abstimmung, Abweichungsanalyse, Berichte.",
    href: "/de/case-studies/finance-automation/",
  },
  {
    value: "~15",
    unit: "Std./Woche",
    area: "Reporting",
    label: "Manuelles Reporting durch Power-BI-Dashboards ersetzt — inklusive Kundenberichte.",
    href: "/de/case-studies/power-bi-reporting/",
  },
  {
    value: "~27.5",
    unit: "Std./Woche",
    area: "Kommunikation & Admin",
    label: "Im eigenen Unternehmen (Taxed GmbH): E-Mail, Onboarding und Recherche automatisiert.",
    href: "/de/case-studies/taxed-gmbh/",
  },
];

const stages = [
  { cls: "navy", name: "Advise", text: "KI-Audit mit Prozessinventar, Roadmap und ROI-Projektion — mit ehrlichem Go/No-Go." },
  { cls: "teal", name: "Build", text: "Claude Skills, Integrationen und Dashboards — in Wochen, nicht Monaten." },
  { cls: "blue", name: "Run", text: "Managed AI Operations: Monitoring, Kennzahlenbericht und laufende Verbesserung." },
];
---

<MainLayout
  title="Einsatzbereiche - eFlury Consulting"
  description="Die drei Geschäftsbereiche, in denen wir für Schweizer KMU automatisieren: Finanzen & Back Office, Kundenkommunikation & Annahme, Reporting & Daten — verankert in dokumentierten Projekten mit publizierten Schätzungen."
  keywords="KI-Automatisierung Branchen, Finanzteam Automatisierung, Dienstleister KI, Schweizer KMU"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: "Einsatzbereiche" }]} />

  <main class="industries-page">
    <section class="hub-hero">
      <div class="container">
        <span class="hero-badge">3 Geschäftsbereiche · Jede Branche · Dokumentiert</span>
        <h1>Einsatzbereiche.</h1>
        <p class="lead">Dieselben Prozesse fressen in jeder Branche Zeit: Rechnungen kommen, E-Mails stapeln sich, Reports werden von Hand gebaut. Deshalb ordnen wir unsere Arbeit nicht nach Branchen, sondern nach Geschäftsbereichen.</p>
      </div>
    </section>

    <IllustrationShowcase>
      <FloorPlanIllustration lang={lang} />
    </IllustrationShowcase>

    <section class="hub-areas">
      <div class="container">
        <h2 class="section-title">Drei Bereiche, ein Ziel: Zeit zurück.</h2>
        <p class="section-sub">Jede Karte führt zur Detailseite mit Prozessen, Werkzeugen und den passenden Projekten.</p>
        <div class="area-grid">
          {areas.map((area) => (
            <a href={area.href} class="area-card">
              <div class="card-top">
                <div class="icon-tile"><area.icon size={24} /></div>
                <span class="proof-chip">{area.proof}</span>
              </div>
              <h3>{area.title}</h3>
              <p class="tagline">{area.tagline}</p>
              <ul class="tick-list">
                {area.ticks.map((tick) => (
                  <li><Check size={15} /><span>{tick}</span></li>
                ))}
              </ul>
              <div class="card-bottom">
                <span class="card-link">Was wir automatisieren</span>
                <span class="go"><ArrowRight size={16} /></span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="hub-proof">
      <div class="container">
        <h2 class="section-title">Verankert in dokumentierten Projekten.</h2>
        <p class="section-sub">Was diese Bereiche in echten Projekten gebracht haben — jede Zahl führt zur vollständigen Fallstudie.</p>
        <div class="proof-grid">
          {proofs.map((proof) => (
            <a href={proof.href} class="proof-card">
              <span class="proof-area">{proof.area}</span>
              <div class="proof-value">{proof.value}<span class="proof-unit"> {proof.unit}</span></div>
              <p>{proof.label}</p>
              <span class="proof-link">Fallstudie lesen <ArrowRight size={14} /></span>
            </a>
          ))}
        </div>
        <p class="proof-note">Publizierte Schätzungen — Annahmen und Details stehen in der jeweiligen Fallstudie.</p>
      </div>
    </section>

    <section class="hub-method">
      <div class="container">
        <h2 class="section-title">In jedem Bereich derselbe Weg.</h2>
        <div class="stage-grid">
          {stages.map((stage) => (
            <div class="stage-col">
              <span class:list={['stage-pill', stage.cls]}>{stage.name}</span>
              <p>{stage.text}</p>
            </div>
          ))}
        </div>
        <div class="method-links">
          <a href="/de/methode/">Die eFlury-Methode im Detail <ArrowRight size={14} /></a>
          <a href="/de/services/">Alle 7 Leistungen ansehen <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="hub-cta">
      <div class="container">
        <div class="cta-band">
          <h2>Ihre Branche ist nicht aufgeführt? Ihr Prozess vermutlich schon.</h2>
          <p>Die meisten KMU-Prozesse ähneln sich über Branchen hinweg. Erzählen Sie uns in 30 Minuten, wo bei Ihnen Zeit versickert — wir sagen ehrlich, ob sich Automatisierung lohnt.</p>
          <a href="/de/kontakt/" class="cta-button">
            Kostenloses Strategiegespräch buchen
            <ArrowRight size={18} />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  /* Generated for en/ and de/ from one template — edit both together. */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hub-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: 1.25rem;
  }

  .hub-hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
  }

  .hub-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  .section-title {
    text-align: center;
    font-size: clamp(1.6rem, 3.5vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin: 0 0 0.6rem;
  }

  .section-sub {
    text-align: center;
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 620px;
    margin: 0 auto 2.25rem;
  }

  /* Area cards */
  .hub-areas {
    padding: var(--spacing-2xl) 0 var(--spacing-2xl);
    background: var(--bg-secondary);
  }

  .area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
  }

  .area-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.7rem;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .area-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .icon-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    border: 1px solid var(--primary-100);
    color: var(--teal-text);
    flex-shrink: 0;
  }

  .proof-chip {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    padding: 0.28rem 0.7rem;
    white-space: nowrap;
  }

  .area-card h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.35rem;
  }

  .tagline {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--text-secondary);
    margin: 0 0 1.1rem;
  }

  .tick-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    flex-grow: 1;
  }

  .tick-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: 0.92rem;
    line-height: 1.45;
    color: var(--text-primary);
  }

  .tick-list li :global(svg) {
    color: var(--teal-text);
    flex-shrink: 0;
    margin-top: 0.18rem;
  }

  .card-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-top: 1px solid var(--border-color);
    padding-top: 1rem;
  }

  .card-link {
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .go {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    color: var(--teal-text);
    flex-shrink: 0;
    transition: all var(--transition-fast);
  }

  .area-card:hover .go {
    background: var(--action-teal);
    color: #fff;
  }

  /* Proof strip */
  .hub-proof {
    padding: var(--spacing-2xl) 0;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
  }

  .proof-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.5rem 1.7rem;
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
  }

  .proof-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--eflury-teal);
  }

  .proof-area {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--teal-text);
    margin-bottom: 0.6rem;
  }

  .proof-value {
    font-size: 2.1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }

  .proof-unit {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .proof-card p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0 0 1rem;
    flex-grow: 1;
  }

  .proof-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.88rem;
  }

  .proof-note {
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--text-tertiary);
    text-align: center;
  }

  /* Method band */
  .hub-method {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .stage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-lg);
  }

  .stage-col {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 1.4rem 1.6rem;
  }

  .stage-pill {
    display: inline-block;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    margin-bottom: 0.75rem;
  }

  .stage-pill.navy { background: var(--surface-navy); }
  .stage-pill.teal { background: var(--action-teal); }
  .stage-pill.blue { background: var(--eflury-blue-mid); }

  .stage-col p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin: 0;
  }

  .method-links {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .method-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }

  .method-links a:hover {
    text-decoration: underline;
  }

  /* CTA */
  .hub-cta {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
  }

  .cta-band {
    text-align: center;
    background: var(--surface-navy);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
  }

  .cta-band h2 {
    color: #fff;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin: 0 0 0.75rem;
  }

  .cta-band p {
    color: rgba(255, 255, 255, 0.8);
    max-width: 560px;
    margin: 0 auto 1.75rem;
    line-height: 1.6;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--action-teal);
    color: #fff;
    font-weight: 600;
    padding: 0.95rem 1.9rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .cta-button:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .hub-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .hub-hero .lead {
      font-size: 1.05rem;
    }

    .method-links {
      flex-direction: column;
      align-items: center;
      gap: 0.9rem;
    }
  }
</style>
