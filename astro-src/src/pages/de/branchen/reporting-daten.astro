---
import MainLayout from '../../../layouts/MainLayout.astro';
import Header from '../../../components/Header.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import Footer from '../../../components/Footer.astro';
import AIChatbot from '../../../components/AIChatbot.astro';
import IllustrationShowcase from '../../../components/IllustrationShowcase.astro';
import DashboardIllustration from '../../../components/illustrations/DashboardIllustration.astro';
import { ArrowRight, BarChart3, FileSpreadsheet, Database, Send } from 'lucide-astro';

const lang = 'de';

const pains = [
  {
    title: 'Reports werden jeden Monat neu gebaut',
    text: 'Die Zahlen existieren — aber sie aus Exporten und Tabellen zusammenzusetzen kostet Tage, jeden einzelnen Monat.',
  },
  {
    title: 'Keine einzige Wahrheit',
    text: 'ERP, CRM, Banking, Excel — dieselbe Kennzahl hat drei Werte, je nachdem, wen man fragt. Und keiner traut keinem.',
  },
  {
    title: 'Entscheide warten auf Daten',
    text: 'Managementfragen brauchen Stunden, weil die Daten zuerst gesucht und abgeglichen werden müssen.',
  },
];

const automations = [
  {
    icon: BarChart3,
    title: 'Power-BI-Dashboards',
    text: 'Live-Dashboards, verbunden mit Ihren Quellsystemen — die Zahlen aktualisieren sich selbst, statt neu gebaut zu werden.',
    href: '/de/services/power-bi/',
    linkLabel: 'Power-BI-Service',
  },
  {
    icon: FileSpreadsheet,
    title: 'Excel-zu-Power-BI-Migration',
    text: 'Strukturierte Migration gewachsener Excel-Reports — mit Checkliste für die typischen Stolperfallen.',
    href: '/de/blog/excel-zu-power-bi-migration/',
    linkLabel: 'Der Migrations-Guide',
  },
  {
    icon: Database,
    title: 'Datenqualität',
    text: 'Dubletten, Formatabweichungen und fehlende Identifikatoren bereinigt — mit menschlicher Freigabe, damit Ihre Reports sich nicht mehr widersprechen.',
    href: '/de/services/datenqualitaet/',
    linkLabel: 'Datenqualitäts-Service',
  },
  {
    icon: Send,
    title: 'Report-Verteilung',
    text: 'Wiederkehrende Kunden- und Management-Reports automatisch entworfen und verteilt — geprüft von einem Menschen, bevor etwas das Haus verlässt.',
    href: '/de/services/finanzen-automatisierung/',
    linkLabel: 'Finanzautomatisierungs-Service',
  },
];
---

<MainLayout
  title="Reporting & Daten automatisieren - eFlury Consulting"
  description="Automatisierung für Reporting und Daten in Schweizer KMU: Power-BI-Dashboards, Excel-Migration, Datenqualität und automatische Report-Verteilung — dokumentiert in einem Kundenprojekt."
  keywords="Power BI Schweizer KMU, Reporting Automatisierung, Excel Power BI Migration, Datenqualität, Dashboard"
  lang={lang}
>
  <Header lang={lang} />

  <Breadcrumbs lang={lang} items={[{ label: 'Einsatzbereiche', href: '/de/branchen/' }, { label: 'Reporting & Daten' }]} />

  <main class="industry-page">
    <section class="industry-hero">
      <div class="container">
        <p class="eyebrow">Einsatzbereiche · Reporting &amp; Daten</p>
        <h1>Reporting &amp; Daten.</h1>
        <p class="lead">
          Zahlen, denen Sie trauen — auf Bildschirmen, die sich selbst aktualisieren.
          Wir verbinden Ihre Systeme, bereinigen die Daten darunter und automatisieren die Reports darüber.
        </p>
      </div>
    </section>

    <section class="pains">
      <div class="container">
        <h2>Wohin die Stunden verschwinden</h2>
        <div class="card-grid three">
          {pains.map((pain) => (
            <div class="plain-card">
              <h3>{pain.title}</h3>
              <p>{pain.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <IllustrationShowcase>
      <DashboardIllustration />
    </IllustrationShowcase>

    <section class="automations">
      <div class="container">
        <h2>Was wir rund um Reporting &amp; Daten automatisieren</h2>
        <p class="section-lead">
          Für jedes System gilt dieselbe Regel: KI schlägt vor, Ihr Team gibt frei.
          Ihre Daten bleiben in Ihren Systemen — Agenten greifen über MCP-Konnektoren nur lesend zu.
        </p>
        <div class="card-grid two">
          {automations.map((item) => (
            <div class="auto-card">
              <div class="auto-icon"><item.icon size={22} /></div>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
              <a href={item.href} class="card-link">{item.linkLabel} <ArrowRight size={14} /></a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="proof">
      <div class="container">
        <h2>Dokumentiert in einem Kundenprojekt</h2>
        <div class="proof-card">
          <p>
            Für ein Dienstleistungsunternehmen haben wir eine Power-BI-Lösung gebaut, die sieben
            Datenquellen in einem Management-Dashboard verbindet — dokumentiert mit ~15 h/Woche
            geschätzter Zeitersparnis und ~2.8 Monaten geschätzter Amortisation.
          </p>
          <a href="/de/case-studies/power-bi-reporting/" class="card-link">Power-BI-Fallstudie <ArrowRight size={14} /></a>
        </div>
        <div class="proof-card">
          <p>
            Wie unsere Datenqualitäts-Agenten über Dubletten und Konflikte entscheiden, zeigen wir
            live — mit illustrativen Daten — in der interaktiven Demo auf der Datenqualitäts-Seite.
          </p>
          <a href="/de/services/datenqualitaet/" class="card-link">Zur Live-Demo <ArrowRight size={14} /></a>
        </div>
      </div>
    </section>

    <section class="insights-band">
      <div class="container">
        <p>
          Vertiefende Artikel zu Power BI und Reporting —
          <a href="/de/blog/#powerbi">im Insights-Hub lesen</a>.
        </p>
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>Wie lange dauert Ihr Monatsreport?</h2>
        <p>Kostenloses 30-Minuten-Gespräch — wir schauen Ihre Reporting-Kette an, kein Foliensatz.</p>
        <a href="/de/kontakt/" class="btn-primary">
          Kontakt aufnehmen
          <ArrowRight size={18} />
        </a>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
  <AIChatbot />
</MainLayout>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .industry-hero {
    padding: var(--spacing-3xl) 0 var(--spacing-2xl);
    background: linear-gradient(135deg, var(--primary-50) 0%, var(--secondary-50) 100%);
    border-bottom: 1px solid var(--border-color);
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(13, 148, 136, 0.1);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-text);
    margin-bottom: var(--spacing-lg);
  }

  .industry-hero h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin: 0 auto var(--spacing-md);
    max-width: 800px;
  }

  .industry-hero .lead {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
  }

  section h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-lg);
  }

  .section-lead {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin-bottom: var(--spacing-xl);
  }

  .pains {
    padding: var(--spacing-2xl) 0;
    background: var(--bg-secondary);
  }

  .automations {
    padding: var(--spacing-3xl) 0;
    background: var(--bg-primary);
  }

  .card-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .card-grid.three {
    grid-template-columns: repeat(3, 1fr);
  }

  .card-grid.two {
    grid-template-columns: repeat(2, 1fr);
  }

  .plain-card,
  .auto-card,
  .proof-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    box-shadow: var(--shadow-sm);
  }

  .plain-card h3,
  .auto-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
  }

  .plain-card p,
  .auto-card p,
  .proof-card p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--text-secondary);
    margin: 0;
  }

  .auto-card p {
    margin-bottom: var(--spacing-md);
  }

  .auto-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--primary-50);
    color: var(--teal-text);
    margin-bottom: var(--spacing-md);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--link-color);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .proof {
    padding: var(--spacing-2xl) 0 var(--spacing-3xl);
    background: var(--bg-secondary);
  }

  .proof-card p {
    font-size: 1.02rem;
    margin-bottom: var(--spacing-md);
  }

  .proof-card + .proof-card {
    margin-top: var(--spacing-lg);
  }

  .insights-band {
    padding: var(--spacing-xl) 0;
    background: var(--bg-primary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .insights-band p {
    font-size: 1rem;
    color: var(--text-secondary);
    text-align: center;
    margin: 0;
  }

  .insights-band a {
    display: inline-flex;
    align-items: center;
    color: var(--link-color);
    font-weight: 600;
    text-decoration: none;
  }

  .insights-band a:hover {
    text-decoration: underline;
  }

  .cta {
    padding: var(--spacing-3xl) 0;
    background: var(--surface-navy);
    text-align: center;
  }

  .cta h2 {
    color: var(--eflury-white);
    margin-bottom: var(--spacing-sm);
  }

  .cta p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    margin-bottom: var(--spacing-xl);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--action-teal);
    color: var(--eflury-white);
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .btn-primary:hover {
    background: var(--primary-700);
    transform: translateY(-2px);
  }

  @media (max-width: 900px) {
    .card-grid.three,
    .card-grid.two {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1.5rem;
    }

    .industry-hero {
      padding: var(--spacing-3xl) 0 var(--spacing-xl);
    }

    .industry-hero .lead {
      font-size: 1.05rem;
    }

    .pains,
    .automations,
    .proof {
      padding: var(--spacing-xl) 0;
    }
  }
</style>
