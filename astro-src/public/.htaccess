# eflury.com — host canonicalization and cache policy

# www -> apex (301)
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^ https://eflury.com%{REQUEST_URI} [R=301,L]
</IfModule>

<IfModule mod_headers.c>
  # HTML: always revalidate so deploys are visible immediately
  <FilesMatch "\.html$">
    Header set Cache-Control "max-age=0, must-revalidate"
  </FilesMatch>

  # Hashed bundles + fonts: immutable
  <FilesMatch "\.(css|js|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Service worker + manifest must never be cached long (overrides js rule)
  <FilesMatch "^(sw\.js|manifest\.json)$">
    Header set Cache-Control "max-age=0, must-revalidate"
  </FilesMatch>

  # Images: one day
  <FilesMatch "\.(png|jpe?g|webp|svg|ico|gif)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Sitemap, feeds, robots, llms.txt: one hour
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "max-age=3600"
  </FilesMatch>
</IfModule>
